@page "/models"
@using StableDiffusionStudio.Application.Commands
@using StableDiffusionStudio.Application.DTOs
@using StableDiffusionStudio.Application.Services
@using StableDiffusionStudio.Application.Interfaces
@using StableDiffusionStudio.Domain.Enums
@inject IModelCatalogService ModelCatalogService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject ILogger<Models> Logger

@if (_loadError is not null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4" ShowCloseIcon="true"
              CloseIconClicked="() => _loadError = null">
        @_loadError
    </MudAlert>
}

<MudText Typo="Typo.h4" Class="mb-4">Models</MudText>

<MudTabs Elevation="1" Rounded="true" @bind-ActivePanelIndex="_activeTabIndex">
    <MudTabPanel Text="Local Catalog" Icon="@Icons.Material.Filled.Folder">
        @* Local catalog toolbar *@
        <MudToolBar Dense="true" Class="mb-4 mt-3 px-0">
            <MudTextField @bind-Value="_searchTerm" Placeholder="Search models..."
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                          Immediate="true" DebounceInterval="300" OnDebounceIntervalElapsed="LoadModels"
                          Variant="Variant.Outlined" Margin="Margin.Dense" Class="mr-2" />
            <MudSelect T="ModelFamily?" Label="Family" Value="_familyFilter" ValueChanged="OnFamilyChanged"
                       Variant="Variant.Outlined" Margin="Margin.Dense" Class="mr-2" Style="max-width: 180px;"
                       Clearable="true">
                @foreach (var family in Enum.GetValues<ModelFamily>())
                {
                    <MudSelectItem T="ModelFamily?" Value="@family">@family</MudSelectItem>
                }
            </MudSelect>
            <MudSelect T="ModelType?" Label="Type" Value="_typeFilter" ValueChanged="OnTypeChanged"
                       Variant="Variant.Outlined" Margin="Margin.Dense" Class="mr-2" Style="max-width: 180px;"
                       Clearable="true">
                @foreach (var type in Enum.GetValues<ModelType>())
                {
                    <MudSelectItem T="ModelType?" Value="@type">@type</MudSelectItem>
                }
            </MudSelect>
            <MudSpacer />
            <MudButton Variant="Variant.Outlined" Color="Color.Default"
                       StartIcon="@Icons.Material.Filled.CreateNewFolder" OnClick="AddDirectory" Class="mr-2">
                Add Directory
            </MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Refresh" OnClick="ScanNow" Disabled="_scanning">
                @if (_scanning)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    <span>Scanning...</span>
                }
                else
                {
                    <span>Scan Now</span>
                }
            </MudButton>
        </MudToolBar>

        @if (_scanning && _models is null)
        {
            <MudProgressLinear Indeterminate="true" />
        }
        else if (_models is null || _models.Count == 0)
        {
            <EmptyState Title="No models discovered"
                        Subtitle="Add a model directory and scan to discover your models"
                        Icon="@Icons.Material.Filled.ViewInAr"
                        ActionText="Add Directory"
                        OnAction="AddDirectory" />
        }
        else
        {
            <MudGrid>
                @foreach (var model in _models)
                {
                    <MudItem xs="12" sm="6" md="4" lg="3">
                        <ModelCard Model="model" OnClick="ShowModelDetail" />
                    </MudItem>
                }
            </MudGrid>
        }
    </MudTabPanel>

    @if (_remoteProviders is not null)
    {
        @foreach (var provider in _remoteProviders)
        {
            <MudTabPanel Text="@provider.DisplayName" Icon="@Icons.Material.Filled.Cloud">
                <MudToolBar Dense="true" Class="mb-4 mt-3 px-0">
                    <MudTextField @bind-Value="_remoteSearchTerm" Placeholder="@($"Search {provider.DisplayName}...")"
                                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" Class="mr-2"
                                  OnKeyDown="@(async (e) => { if (e.Key == "Enter") await SearchRemote(provider.ProviderId); })" />
                    <MudSelect T="ModelType?" Label="Type" Value="_remoteTypeFilter" ValueChanged="OnRemoteTypeChanged"
                               Variant="Variant.Outlined" Margin="Margin.Dense" Class="mr-2" Style="max-width: 180px;"
                               Clearable="true">
                        @foreach (var type in Enum.GetValues<ModelType>())
                        {
                            <MudSelectItem T="ModelType?" Value="@type">@type</MudSelectItem>
                        }
                    </MudSelect>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Search"
                               OnClick="() => SearchRemote(provider.ProviderId)"
                               Disabled="_remoteSearching">
                        Search
                    </MudButton>
                </MudToolBar>

                @if (_remoteSearching)
                {
                    <MudProgressLinear Indeterminate="true" />
                }
                else if (_remoteResults is null || _remoteResults.Count == 0)
                {
                    <EmptyState Title="No results"
                                Subtitle="@($"Search {provider.DisplayName} to find models")"
                                Icon="@Icons.Material.Filled.CloudDownload" />
                }
                else
                {
                    <MudGrid>
                        @foreach (var model in _remoteResults)
                        {
                            <MudItem xs="12" sm="6" md="4" lg="3">
                                <MudCard Elevation="1">
                                    <MudCardContent>
                                        <MudText Typo="Typo.subtitle1" Class="mb-1">@model.Title</MudText>
                                        <div class="d-flex gap-2 flex-wrap mb-2">
                                            <MudChip T="string" Size="Size.Small" Color="Color.Tertiary">@model.Type</MudChip>
                                            <MudChip T="string" Size="Size.Small" Color="Color.Primary">@model.Family</MudChip>
                                            <MudChip T="string" Size="Size.Small" Color="Color.Secondary">@model.Format</MudChip>
                                        </div>
                                        @if (!string.IsNullOrWhiteSpace(model.Description))
                                        {
                                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2"
                                                     Style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                                @model.Description
                                            </MudText>
                                        }
                                        @if (model.FileSize.HasValue)
                                        {
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                @FormatFileSize(model.FileSize.Value)
                                            </MudText>
                                        }
                                    </MudCardContent>
                                    <MudCardActions>
                                        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                                   StartIcon="@Icons.Material.Filled.Download" Size="Size.Small"
                                                   OnClick="() => OpenDownloadDialog(model, provider.ProviderId)">
                                            Download
                                        </MudButton>
                                    </MudCardActions>
                                </MudCard>
                            </MudItem>
                        }
                    </MudGrid>
                    @if (_remoteHasMore)
                    {
                        <div class="d-flex justify-center mt-4">
                            <MudButton Variant="Variant.Outlined" OnClick="() => LoadMoreRemote(provider.ProviderId)">
                                Load More
                            </MudButton>
                        </div>
                    }
                }
            </MudTabPanel>
        }
    }
</MudTabs>

@code {
    // Local catalog state
    private IReadOnlyList<ModelRecordDto>? _models;
    private string? _searchTerm;
    private ModelFamily? _familyFilter;
    private ModelType? _typeFilter;
    private bool _scanning;
    private string? _loadError;

    // Tab state
    private int _activeTabIndex;
    private IReadOnlyList<ModelProviderInfo>? _remoteProviders;

    // Remote search state
    private string? _remoteSearchTerm;
    private ModelType? _remoteTypeFilter;
    private bool _remoteSearching;
    private IReadOnlyList<RemoteModelInfo>? _remoteResults;
    private bool _remoteHasMore;
    private int _remotePage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var providers = ModelCatalogService.GetProviders();
            _remoteProviders = providers.Where(p => p.Capabilities.CanSearch).ToList();
            await LoadModels();
        }
        catch (Exception ex)
        {
            _loadError = $"Failed to load models: {ex.Message}";
            Logger.LogError(ex, "Failed to load models");
        }
    }

    private async Task LoadModels()
    {
        _models = await ModelCatalogService.ListAsync(
            new ModelFilter(SearchTerm: _searchTerm, Family: _familyFilter, Type: _typeFilter));
    }

    private async Task OnFamilyChanged(ModelFamily? family)
    {
        _familyFilter = family;
        await LoadModels();
    }

    private async Task OnTypeChanged(ModelType? type)
    {
        _typeFilter = type;
        await LoadModels();
    }

    private async Task OnRemoteTypeChanged(ModelType? type)
    {
        _remoteTypeFilter = type;
    }

    private async Task SearchRemote(string providerId)
    {
        _remoteSearching = true;
        _remotePage = 0;
        StateHasChanged();
        try
        {
            var query = new ModelSearchQuery(providerId, _remoteSearchTerm, _remoteTypeFilter, Page: _remotePage);
            var result = await ModelCatalogService.SearchAsync(query);
            _remoteResults = result.Models;
            _remoteHasMore = result.HasMore;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Search failed: {ex.Message}", MudBlazor.Severity.Error);
            _remoteResults = null;
        }
        finally
        {
            _remoteSearching = false;
        }
    }

    private async Task LoadMoreRemote(string providerId)
    {
        _remotePage++;
        _remoteSearching = true;
        StateHasChanged();
        try
        {
            var query = new ModelSearchQuery(providerId, _remoteSearchTerm, _remoteTypeFilter, Page: _remotePage);
            var result = await ModelCatalogService.SearchAsync(query);
            var combined = new List<RemoteModelInfo>(_remoteResults ?? []);
            combined.AddRange(result.Models);
            _remoteResults = combined;
            _remoteHasMore = result.HasMore;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load more: {ex.Message}", MudBlazor.Severity.Error);
        }
        finally
        {
            _remoteSearching = false;
        }
    }

    private async Task OpenDownloadDialog(RemoteModelInfo model, string providerId)
    {
        var parameters = new DialogParameters<Dialogs.DownloadModelDialog>
        {
            { x => x.Model, model },
            { x => x.ProviderId, providerId }
        };
        var dialog = await DialogService.ShowAsync<Dialogs.DownloadModelDialog>($"Download: {model.Title}", parameters);
        var result = await dialog.Result;
        if (result is not null && !result.Canceled)
        {
            // Download was started successfully
        }
    }

    private async Task AddDirectory()
    {
        var dialog = await DialogService.ShowAsync<Dialogs.AddStorageRootDialog>("Add Model Directory");
        var result = await dialog.Result;
        if (result is not null && !result.Canceled)
        {
            Snackbar.Add("Directory added. Click Scan Now to discover models.", MudBlazor.Severity.Info);
        }
    }

    private async Task ScanNow()
    {
        _scanning = true;
        StateHasChanged();
        try
        {
            var result = await ModelCatalogService.ScanAsync(new ScanModelsCommand(null));
            await LoadModels();
            Snackbar.Add($"Scan complete: {result.NewCount} new, {result.UpdatedCount} updated", MudBlazor.Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Scan failed: {ex.Message}", MudBlazor.Severity.Error);
        }
        finally
        {
            _scanning = false;
        }
    }

    private async Task ShowModelDetail(ModelRecordDto model)
    {
        var parameters = new DialogParameters<Dialogs.ModelDetailDialog>
        {
            { x => x.Model, model }
        };
        await DialogService.ShowAsync<Dialogs.ModelDetailDialog>(model.Title, parameters);
    }

    private static string FormatFileSize(long bytes) => bytes switch
    {
        >= 1_000_000_000 => $"{bytes / 1_000_000_000.0:F1} GB",
        >= 1_000_000 => $"{bytes / 1_000_000.0:F1} MB",
        _ => $"{bytes / 1_000.0:F1} KB"
    };
}
