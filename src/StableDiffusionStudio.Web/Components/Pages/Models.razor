@page "/models"
@using StableDiffusionStudio.Application.Commands
@using StableDiffusionStudio.Application.DTOs
@using StableDiffusionStudio.Application.Services
@using StableDiffusionStudio.Application.Interfaces
@using StableDiffusionStudio.Domain.Enums
@using Microsoft.JSInterop
@inject IModelCatalogService ModelCatalogService
@inject IAppPaths AppPaths
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@inject ILogger<Models> Logger
@implements IAsyncDisposable

@if (_loadError is not null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4" ShowCloseIcon="true"
              CloseIconClicked="() => _loadError = null">
        @_loadError
    </MudAlert>
}

<MudText Typo="Typo.h4" Class="mb-4">Models</MudText>

@* Filter bar *@
<ModelFilterBar SearchTerm="@_searchTerm" SearchTermChanged="OnSearchTermChanged"
               SelectedSource="@_selectedSource" SelectedSourceChanged="OnSourceChanged"
               TypeFilter="@CurrentState.TypeFilter" TypeFilterChanged="OnTypeChanged"
               FamilyFilter="@CurrentState.FamilyFilter" FamilyFilterChanged="OnFamilyChanged"
               SortOrder="@CurrentState.SortOrder" SortOrderChanged="OnSortChanged"
               BaseModel="@CurrentState.BaseModel" BaseModelChanged="OnBaseModelChanged"
               ViewModeList="@_listView" ViewModeListChanged="v => { _listView = v; StateHasChanged(); }" />

@* Local source toolbar *@
@if (_selectedSource == "local")
{
    <MudToolBar Dense="true" Class="mb-3 px-0">
        <MudSpacer />
        <MudButton Variant="Variant.Outlined" Color="Color.Default"
                   StartIcon="@Icons.Material.Filled.CreateNewFolder" OnClick="AddDirectory" Class="mr-2">
            Add Directory
        </MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Refresh" OnClick="ScanNow" Disabled="_scanning">
            @if (_scanning)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                <span>Scanning...</span>
            }
            else
            {
                <span>Scan Now</span>
            }
        </MudButton>
    </MudToolBar>
}

@* Loading indicator *@
@if (CurrentState.IsLoading)
{
    <MudProgressLinear Indeterminate="true" />
}

@* Results area *@
@if (CurrentState.Results.Count == 0 && !CurrentState.IsLoading)
{
    @if (_selectedSource == "local")
    {
        <EmptyState Title="No models discovered"
                    Subtitle="Add a model directory and scan to discover your models"
                    Icon="@Icons.Material.Filled.ViewInAr"
                    ActionText="Add Directory"
                    OnAction="AddDirectory" />
    }
    else
    {
        <EmptyState Title="No results"
                    Subtitle="Search to find models from this source"
                    Icon="@Icons.Material.Filled.CloudDownload" />
    }
}
else if (!_listView)
{
    @* Card grid view *@
    <MudGrid>
        @foreach (var model in CurrentState.Results)
        {
            <MudItem xs="12" sm="6" md="4" lg="3">
                <ModelCardUnified Model="model" OnClick="OnModelClicked" />
            </MudItem>
        }
    </MudGrid>
}
else
{
    @* List view *@
    <MudTable Items="CurrentState.Results" Dense="true" Hover="true" Elevation="1">
        <HeaderContent>
            <MudTh></MudTh>
            <MudTh>Title</MudTh>
            <MudTh>Family</MudTh>
            <MudTh>Type</MudTh>
            <MudTh>Format</MudTh>
            <MudTh>Size</MudTh>
            <MudTh>Source</MudTh>
        </HeaderContent>
        <RowTemplate>
            <ModelListRow Model="context" OnClick="OnModelClicked" />
        </RowTemplate>
    </MudTable>
}

@* Infinite scroll sentinel for remote sources *@
@if (_selectedSource != "local" && CurrentState.HasMore && CurrentState.Results.Count > 0)
{
    <div id="@_sentinelId" class="d-flex justify-center pa-4">
        @if (CurrentState.IsLoading)
        {
            <MudProgressCircular Size="Size.Small" Indeterminate="true" />
        }
    </div>
}
else if (_selectedSource != "local" && !CurrentState.HasMore && CurrentState.Results.Count > 0)
{
    <MudText Typo="Typo.caption" Color="Color.Secondary" Align="Align.Center" Class="pa-4">
        All results loaded
    </MudText>
}

@* Detail drawer *@
<ModelDetailDrawer Open="@_drawerOpen" OpenChanged="v => _drawerOpen = v"
                  Model="@_selectedModel" LocalModel="@_selectedLocalModel" RemoteModel="@_selectedRemoteModel"
                  OnDeleted="OnModelDeleted" />

@code {
    // Per-source state
    private class SourceState
    {
        public string? SearchTerm { get; set; }
        public ModelType? TypeFilter { get; set; }
        public ModelFamily? FamilyFilter { get; set; }
        public SortOrder SortOrder { get; set; } = SortOrder.Relevance;
        public string? BaseModel { get; set; }
        public List<ModelCardViewModel> Results { get; set; } = [];
        public int Page { get; set; }
        public bool HasMore { get; set; }
        public bool IsLoading { get; set; }
    }

    private readonly Dictionary<string, SourceState> _sourceStates = new()
    {
        ["local"] = new(),
        ["civitai"] = new() { SortOrder = SortOrder.MostDownloaded },
        ["huggingface"] = new() { SortOrder = SortOrder.MostDownloaded }
    };

    private string _selectedSource = "local";
    private string? _searchTerm;
    private bool _listView;
    private bool _scanning;
    private string? _loadError;
    private readonly string _sentinelId = $"scroll-sentinel-{Guid.NewGuid():N}";
    private DotNetObjectReference<Models>? _dotnetRef;
    private bool _isLoadingMore;

    // Drawer state
    private bool _drawerOpen;
    private ModelCardViewModel? _selectedModel;
    private ModelRecordDto? _selectedLocalModel;
    private RemoteModelInfo? _selectedRemoteModel;

    // Cached remote results for detail lookups
    private readonly Dictionary<string, RemoteModelInfo> _remoteModelCache = new();
    private readonly Dictionary<Guid, ModelRecordDto> _localModelCache = new();

    private SourceState CurrentState => _sourceStates[_selectedSource];

    protected override async Task OnInitializedAsync()
    {
        _dotnetRef = DotNetObjectReference.Create(this);
        try
        {
            await LoadLocalModels();
        }
        catch (Exception ex)
        {
            _loadError = $"Failed to load models: {ex.Message}";
            Logger.LogError(ex, "Failed to load models");
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Re-observe the sentinel whenever there are more results to load
        if (_dotnetRef is not null && _selectedSource != "local" && CurrentState.HasMore && CurrentState.Results.Count > 0)
        {
            try
            {
                await JS.InvokeVoidAsync("infiniteScroll.observe", _sentinelId, _dotnetRef);
            }
            catch (JSDisconnectedException) { }
            catch (InvalidOperationException) { } // SSR/prerender
        }
    }

    [JSInvokable]
    public async Task OnSentinelVisible()
    {
        if (_isLoadingMore || !CurrentState.HasMore || CurrentState.IsLoading)
            return;

        _isLoadingMore = true;
        try
        {
            await LoadMore();
        }
        finally
        {
            _isLoadingMore = false;
        }
    }

    private async Task OnSourceChanged(string source)
    {
        _selectedSource = source;
        _searchTerm = CurrentState.SearchTerm;

        if (source == "local" && CurrentState.Results.Count == 0)
            await LoadLocalModels();
        else if (source != "local" && CurrentState.Results.Count == 0)
            await SearchRemote();
    }

    private async Task OnSearchTermChanged(string? term)
    {
        _searchTerm = term;
        CurrentState.SearchTerm = term;

        if (_selectedSource == "local")
            await LoadLocalModels();
        else
            await SearchRemote();
    }

    private async Task OnTypeChanged(ModelType? type)
    {
        CurrentState.TypeFilter = type;
        if (_selectedSource == "local")
            await LoadLocalModels();
        else
            await SearchRemote();
    }

    private async Task OnFamilyChanged(ModelFamily? family)
    {
        CurrentState.FamilyFilter = family;
        if (_selectedSource == "local")
            await LoadLocalModels();
        else
            await SearchRemote();
    }

    private async Task OnSortChanged(SortOrder sort)
    {
        CurrentState.SortOrder = sort;
        if (_selectedSource != "local")
            await SearchRemote();
    }

    private async Task OnBaseModelChanged(string? baseModel)
    {
        CurrentState.BaseModel = baseModel;
        if (_selectedSource != "local")
            await SearchRemote();
    }

    private async Task LoadLocalModels()
    {
        var state = _sourceStates["local"];
        state.IsLoading = true;
        StateHasChanged();

        try
        {
            var filter = new ModelFilter(
                SearchTerm: state.SearchTerm,
                Family: state.FamilyFilter,
                Type: state.TypeFilter);
            var models = await ModelCatalogService.ListAsync(filter);

            _localModelCache.Clear();
            foreach (var m in models)
                _localModelCache[m.Id] = m;

            state.Results = models.Select(m => ModelCardViewModel.FromLocal(m, AppPaths)).ToList();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load models: {ex.Message}", MudBlazor.Severity.Error);
        }
        finally
        {
            state.IsLoading = false;
        }
    }

    private async Task SearchRemote()
    {
        var state = CurrentState;
        state.Page = 0;
        state.IsLoading = true;
        StateHasChanged();

        try
        {
            var query = new ModelSearchQuery(
                _selectedSource,
                state.SearchTerm,
                state.TypeFilter,
                state.FamilyFilter,
                Sort: state.SortOrder,
                Page: 0,
                BaseModel: state.BaseModel);
            var result = await ModelCatalogService.SearchAsync(query);

            foreach (var m in result.Models)
                _remoteModelCache[m.ExternalId] = m;

            state.Results = result.Models
                .Select(m => ModelCardViewModel.FromRemote(m, _selectedSource))
                .ToList();
            state.HasMore = result.HasMore;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Search failed: {ex.Message}", MudBlazor.Severity.Error);
            state.Results = [];
        }
        finally
        {
            state.IsLoading = false;
        }
    }

    private async Task LoadMore()
    {
        var state = CurrentState;
        state.Page++;
        state.IsLoading = true;
        StateHasChanged();

        try
        {
            var query = new ModelSearchQuery(
                _selectedSource,
                state.SearchTerm,
                state.TypeFilter,
                state.FamilyFilter,
                Sort: state.SortOrder,
                Page: state.Page,
                BaseModel: state.BaseModel);
            var result = await ModelCatalogService.SearchAsync(query);

            foreach (var m in result.Models)
                _remoteModelCache[m.ExternalId] = m;

            state.Results.AddRange(
                result.Models.Select(m => ModelCardViewModel.FromRemote(m, _selectedSource)));
            state.HasMore = result.HasMore;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load more: {ex.Message}", MudBlazor.Severity.Error);
        }
        finally
        {
            state.IsLoading = false;
        }
    }

    private async Task OnModelClicked(ModelCardViewModel model)
    {
        _selectedModel = model;
        _selectedLocalModel = null;
        _selectedRemoteModel = null;

        if (model.IsLocal && Guid.TryParse(model.Id, out var id))
        {
            _localModelCache.TryGetValue(id, out _selectedLocalModel);
            _selectedLocalModel ??= await ModelCatalogService.GetByIdAsync(id);
        }
        else
        {
            _remoteModelCache.TryGetValue(model.Id, out _selectedRemoteModel);
        }

        _drawerOpen = true;
    }

    private async Task OnModelDeleted()
    {
        _drawerOpen = false;
        await LoadLocalModels();
        Snackbar.Add("Model removed from catalog.", MudBlazor.Severity.Info);
    }

    private async Task AddDirectory()
    {
        var dialog = await DialogService.ShowAsync<Dialogs.AddStorageRootDialog>("Add Model Directory");
        var result = await dialog.Result;
        if (result is not null && !result.Canceled)
        {
            Snackbar.Add("Directory added. Click Scan Now to discover models.", MudBlazor.Severity.Info);
        }
    }

    private async Task ScanNow()
    {
        _scanning = true;
        StateHasChanged();
        try
        {
            var result = await ModelCatalogService.ScanAsync(new ScanModelsCommand(null));
            await LoadLocalModels();
            Snackbar.Add($"Scan complete: {result.NewCount} new, {result.UpdatedCount} updated", MudBlazor.Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Scan failed: {ex.Message}", MudBlazor.Severity.Error);
        }
        finally
        {
            _scanning = false;
        }
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            if (_dotnetRef is not null)
                await JS.InvokeVoidAsync("infiniteScroll.unobserve", _sentinelId);
        }
        catch (JSDisconnectedException) { }
        catch (InvalidOperationException) { } // SSR/prerender
        _dotnetRef?.Dispose();
    }
}
