@page "/generate"
@using StableDiffusionStudio.Application.Commands
@using StableDiffusionStudio.Application.DTOs
@using StableDiffusionStudio.Application.Interfaces
@inject IProjectService ProjectService
@inject NavigationManager Navigation

<MudText Typo="Typo.h4" Class="mb-4">Quick Generate</MudText>

@if (_projectId is null)
{
    <MudProgressLinear Indeterminate="true" />
}
else
{
    <GenerationWorkspace ProjectId="_projectId.Value" ProjectName="Quick Generate"
                         InitialCheckpointId="_initialModelId" />
}

@code {
    private Guid? _projectId;
    private Guid? _initialModelId;

    private const string QuickGenerateProjectName = "Quick Generate";

    protected override async Task OnInitializedAsync()
    {
        // Parse ?model= query parameter
        var uri = new Uri(Navigation.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        var modelParam = query["model"];
        if (Guid.TryParse(modelParam, out var modelId))
            _initialModelId = modelId;

        await EnsureQuickGenerateProject();
    }

    private async Task EnsureQuickGenerateProject()
    {
        // Find or create the Quick Generate project
        var projects = await ProjectService.ListAsync(new ProjectFilter());
        var quickProject = projects.FirstOrDefault(p => p.Name == QuickGenerateProjectName);

        if (quickProject is null)
        {
            quickProject = await ProjectService.CreateAsync(
                new CreateProjectCommand(QuickGenerateProjectName, "Auto-created project for quick generation"));
        }

        _projectId = quickProject.Id;
    }
}
