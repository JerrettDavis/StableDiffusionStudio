@page "/jobs"
@using StableDiffusionStudio.Application.DTOs
@using StableDiffusionStudio.Application.Interfaces
@using StableDiffusionStudio.Domain.Enums
@using StableDiffusionStudio.Web.Components.Dialogs
@using Microsoft.AspNetCore.SignalR.Client
@inject IJobQueue JobQueue
@inject IGenerationService GenerationService
@inject IDataManagementService DataManagement
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IAppPaths AppPaths
@inject NavigationManager Nav
@inject ILogger<Jobs> Logger
@implements IAsyncDisposable

<MudText Typo="Typo.h4" Class="mb-4">Jobs</MudText>

<div class="d-flex align-center justify-space-between flex-wrap mb-4 gap-2">
    <MudChipSet T="string" @bind-SelectedValue="_filter" SelectionMode="SelectionMode.SingleSelection">
        <MudChip T="string" Value="@("all")" Color="Color.Default">All @(_allCount)</MudChip>
        <MudChip T="string" Value="@("active")" Color="Color.Primary">Active @(_activeCount)</MudChip>
        <MudChip T="string" Value="@("completed")" Color="Color.Success">Completed @(_completedCount)</MudChip>
        <MudChip T="string" Value="@("failed")" Color="Color.Error">Failed @(_failedCount)</MudChip>
    </MudChipSet>
    <div class="d-flex gap-2">
        <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Default"
                   OnClick="ClearCompleted" Disabled="_completedCount == 0">Clear Completed</MudButton>
        <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Error"
                   OnClick="ClearFailed" Disabled="_failedCount == 0">Clear Failed</MudButton>
    </div>
</div>

@if (_jobs is null)
{
    <MudProgressLinear Indeterminate="true" />
}
else if (GetFilteredJobs().Count == 0)
{
    <EmptyState Title="No jobs"
                Subtitle="Jobs appear when you generate images, scan models, or download files"
                Icon="@Icons.Material.Filled.WorkHistory" />
}
else
{
    <MudTable Items="GetFilteredJobs()" Dense="true" Hover="true" Striped="true"
              RowClass="cursor-pointer" OnRowClick="OnRowClick" T="JobRecordDto">
        <HeaderContent>
            <MudTh Style="width:50px"></MudTh>
            <MudTh>Type</MudTh>
            <MudTh>Status</MudTh>
            <MudTh Style="width:200px">Progress</MudTh>
            <MudTh>Phase</MudTh>
            <MudTh>Started</MudTh>
            <MudTh>Duration</MudTh>
            <MudTh Style="width:80px"></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>
                @{
                    var previewUrl = GetJobPreviewUrl(context);
                }
                @if (previewUrl is not null)
                {
                    <div style="width:40px;height:40px;border-radius:4px;overflow:hidden;background:var(--mud-palette-background-gray);">
                        <img src="@previewUrl" alt="" style="width:100%;height:100%;object-fit:cover;display:block;" loading="lazy" />
                    </div>
                }
                else
                {
                    <div style="width:40px;height:40px;border-radius:4px;background:var(--mud-palette-background-gray);display:flex;align-items:center;justify-content:center;">
                        <MudIcon Icon="@GetJobIcon(context.Type)" Size="Size.Small" Color="Color.Default" />
                    </div>
                }
            </MudTd>
            <MudTd>
                <MudText Typo="Typo.body2">@context.Type</MudText>
            </MudTd>
            <MudTd>
                <MudChip T="string" Size="Size.Small" Color="GetStatusColor(context.Status)">
                    @context.Status
                </MudChip>
            </MudTd>
            <MudTd>
                @if (context.Status is JobStatus.Running)
                {
                    <MudProgressLinear Value="context.Progress" Max="100" Color="Color.Primary"
                                       Size="Size.Small" Striped="true" />
                }
                else if (context.Status is JobStatus.Completed)
                {
                    <MudProgressLinear Value="100" Max="100" Color="Color.Success" Size="Size.Small" />
                }
                else if (context.Status is JobStatus.Failed)
                {
                    <MudProgressLinear Value="context.Progress" Max="100" Color="Color.Error" Size="Size.Small" />
                }
            </MudTd>
            <MudTd>
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    @(context.Phase ?? "-")
                </MudText>
            </MudTd>
            <MudTd>
                <MudText Typo="Typo.caption">
                    @(context.StartedAt?.ToString("HH:mm:ss") ?? "-")
                </MudText>
            </MudTd>
            <MudTd>
                <MudText Typo="Typo.caption" Class="param-value">
                    @FormatDuration(context.StartedAt, context.CompletedAt ?? (context.Status == JobStatus.Running ? DateTimeOffset.UtcNow : null))
                </MudText>
            </MudTd>
            <MudTd>
                @if (context.Type == "generation" && context.Status == JobStatus.Completed)
                {
                    <div @onclick:stopPropagation="true">
                        <MudIconButton Icon="@Icons.Material.Filled.Replay" Size="Size.Small"
                                       Color="Color.Primary" Title="Reuse settings in Generate"
                                       OnClick="() => ReuseGenerationSettings(context)" />
                    </div>
                }
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    private IReadOnlyList<JobRecordDto>? _jobs;
    private string _filter = "all";
    private int _allCount, _activeCount, _completedCount, _failedCount;
    private HubConnection? _hubConnection;
    private Timer? _refreshTimer;

    // Cache of job ID → first image preview URL (loaded lazily)
    private readonly Dictionary<Guid, string?> _previewCache = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadJobs();

        // Live updates via SignalR for generation jobs
        try
        {
            _hubConnection = new HubConnectionBuilder()
                .WithUrl(Nav.ToAbsoluteUri("/hubs/studio"))
                .WithAutomaticReconnect()
                .Build();

            _hubConnection.On<string, string, int>("GenerationStatus",
                (_, _, _) => InvokeAsync(async () =>
                {
                    await LoadJobs();
                    StateHasChanged();
                }));

            _hubConnection.On<string, int, int, string>("GenerationPreview",
                (_, step, totalSteps, _) => InvokeAsync(async () =>
                {
                    await LoadJobs();
                    StateHasChanged();
                }));

            _hubConnection.On<string>("GenerationComplete",
                _ => InvokeAsync(async () =>
                {
                    await LoadJobs();
                    StateHasChanged();
                }));

            _hubConnection.On<string, string>("GenerationFailed",
                (_, _) => InvokeAsync(async () =>
                {
                    await LoadJobs();
                    StateHasChanged();
                }));

            await _hubConnection.StartAsync();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to connect to SignalR hub for live job updates");
        }

        // Also poll every 3 seconds for non-generation job updates
        _refreshTimer = new Timer(_ =>
        {
            _ = InvokeAsync(async () =>
            {
                try
                {
                    await LoadJobs();
                    StateHasChanged();
                }
                catch (ObjectDisposedException)
                {
                    // Component disposed during callback — ignore
                }
                catch (Exception ex)
                {
                    Logger.LogWarning(ex, "Failed to refresh jobs");
                }
            });
        }, null, TimeSpan.FromSeconds(3), TimeSpan.FromSeconds(3));
    }

    private async Task LoadJobs()
    {
        _jobs = await JobQueue.ListAsync(activeOnly: false);
        _allCount = _jobs?.Count ?? 0;
        _activeCount = _jobs?.Count(j => j.Status is JobStatus.Pending or JobStatus.Running) ?? 0;
        _completedCount = _jobs?.Count(j => j.Status is JobStatus.Completed) ?? 0;
        _failedCount = _jobs?.Count(j => j.Status is JobStatus.Failed) ?? 0;
    }

    private List<JobRecordDto> GetFilteredJobs()
    {
        if (_jobs is null) return [];
        return _filter switch
        {
            "active" => _jobs.Where(j => j.Status is JobStatus.Pending or JobStatus.Running).ToList(),
            "completed" => _jobs.Where(j => j.Status is JobStatus.Completed).ToList(),
            "failed" => _jobs.Where(j => j.Status is JobStatus.Failed).ToList(),
            _ => _jobs.ToList()
        };
    }

    private async Task OnRowClick(TableRowClickEventArgs<JobRecordDto> args)
    {
        if (args.Item is null) return;

        var parameters = new DialogParameters<JobDetailDialog>
        {
            { x => x.Job, args.Item }
        };
        var dialog = await DialogService.ShowAsync<JobDetailDialog>("Job Details", parameters,
            new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true });
        var result = await dialog.Result;
        if (result is not null && !result.Canceled)
            await LoadJobs();
    }

    private static Color GetStatusColor(JobStatus status) => status switch
    {
        JobStatus.Pending => Color.Default,
        JobStatus.Running => Color.Primary,
        JobStatus.Completed => Color.Success,
        JobStatus.Failed => Color.Error,
        JobStatus.Cancelled => Color.Warning,
        _ => Color.Default
    };

    private static string FormatDuration(DateTimeOffset? start, DateTimeOffset? end)
    {
        if (start is null || end is null) return "-";
        var d = end.Value - start.Value;
        if (d.TotalMinutes >= 1) return $"{(int)d.TotalMinutes}m {d.Seconds}s";
        return $"{d.TotalSeconds:F1}s";
    }

    private async Task ClearCompleted()
    {
        var count = await DataManagement.DeleteCompletedJobRecordsAsync();
        Snackbar.Add($"Cleared {count} completed job(s)", Severity.Info);
        await LoadJobs();
    }

    private async Task ClearFailed()
    {
        var count = await DataManagement.DeleteFailedJobRecordsAsync();
        Snackbar.Add($"Cleared {count} failed job(s)", Severity.Info);
        await LoadJobs();
    }

    private string? GetJobPreviewUrl(JobRecordDto job)
    {
        if (job.Type != "generation" || job.Status != JobStatus.Completed)
            return null;

        if (_previewCache.TryGetValue(job.Id, out var cached))
            return cached;

        // Parse the generation job ID from the job data and look up the first image
        try
        {
            if (string.IsNullOrEmpty(job.Data)) return null;
            var data = System.Text.Json.JsonSerializer.Deserialize<System.Text.Json.JsonElement>(job.Data);
            if (data.TryGetProperty("GenerationJobId", out var jobIdProp))
            {
                var genJobId = jobIdProp.GetGuid();
                // Fire-and-forget async load — will populate on next render
                _ = LoadPreviewAsync(job.Id, genJobId);
            }
        }
        catch { }

        _previewCache[job.Id] = null; // Mark as loading
        return null;
    }

    private async Task LoadPreviewAsync(Guid jobRecordId, Guid generationJobId)
    {
        try
        {
            var genJob = await GenerationService.GetJobAsync(generationJobId);
            if (genJob?.Images.Count > 0)
            {
                var firstImage = genJob.Images[0];
                var url = firstImage.FilePath.StartsWith(AppPaths.AssetsDirectory, StringComparison.OrdinalIgnoreCase)
                    ? AppPaths.GetImageUrl(firstImage.FilePath)
                    : $"/api/model-preview/{generationJobId}"; // fallback
                _previewCache[jobRecordId] = url;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch { }
    }

    private static string GetJobIcon(string type) => type switch
    {
        "generation" => Icons.Material.Filled.Image,
        "experiment" => Icons.Material.Filled.Science,
        "model-scan" => Icons.Material.Filled.Search,
        "model-download" => Icons.Material.Filled.Download,
        "workflow-run" => Icons.Material.Filled.AccountTree,
        _ => Icons.Material.Filled.Work
    };

    private async Task ReuseGenerationSettings(JobRecordDto job)
    {
        try
        {
            if (string.IsNullOrEmpty(job.Data)) return;
            var data = System.Text.Json.JsonSerializer.Deserialize<System.Text.Json.JsonElement>(job.Data);
            if (!data.TryGetProperty("GenerationJobId", out var jobIdProp)) return;

            var genJobId = jobIdProp.GetGuid();
            var genJob = await GenerationService.GetJobAsync(genJobId);
            if (genJob is null) return;

            // Navigate to generate page with the job's parameters encoded as query params
            var p = genJob.Parameters;
            var queryParams = new Dictionary<string, string?>
            {
                ["model"] = p.CheckpointModelId.ToString(),
                ["prompt"] = p.PositivePrompt,
                ["negative"] = p.NegativePrompt,
                ["steps"] = p.Steps.ToString(),
                ["cfg"] = p.CfgScale.ToString(System.Globalization.CultureInfo.InvariantCulture),
                ["width"] = p.Width.ToString(),
                ["height"] = p.Height.ToString(),
                ["seed"] = p.Seed.ToString(),
                ["sampler"] = p.Sampler.ToString(),
                ["clipSkip"] = p.ClipSkip.ToString(),
                ["denoise"] = p.DenoisingStrength.ToString(System.Globalization.CultureInfo.InvariantCulture)
            };

            var qs = string.Join("&", queryParams
                .Where(kv => kv.Value is not null)
                .Select(kv => $"{kv.Key}={Uri.EscapeDataString(kv.Value!)}"));

            Nav.NavigateTo($"/generate?{qs}");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load settings: {ex.Message}", Severity.Error);
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_refreshTimer is not null)
            await _refreshTimer.DisposeAsync();
        if (_hubConnection is not null)
            await _hubConnection.DisposeAsync();
    }
}
