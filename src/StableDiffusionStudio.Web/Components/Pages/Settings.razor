    private static string FormatBytes(long bytes)
    {
        const long kb = 1024;
        const long mb = 1024 * 1024;
        const long gb = 1024 * 1024 * 1024;

        if (bytes >= gb) return $"{bytes / (double)gb:F2} GB";
        if (bytes >= mb) return $"{bytes / (double)mb:F1} MB";
        if (bytes >= kb) return $"{bytes / (double)kb:F1} KB";
        return $"{bytes} B";
    }

    // Database health check
    private string? _dbHealthStatus;
    private bool _dbHealthy;
    private bool _checkingDbHealth;
    private List<(string Table, int Count, string? Error)>? _dbTableCounts;

    private async Task CheckDatabaseHealth()
    {
        _checkingDbHealth = true;
        StateHasChanged();

        try
        {
            var tables = new (string Name, Func<Task<int>> CountFn)[]
            {
                ("Projects", () => DbContext.Projects.CountAsync()),
                ("ModelRecords", () => DbContext.ModelRecords.CountAsync()),
                ("JobRecords", () => DbContext.JobRecords.CountAsync()),
                ("Settings", () => DbContext.Settings.CountAsync()),
                ("GenerationJobs", () => DbContext.GenerationJobs.CountAsync()),
                ("GeneratedImages", () => DbContext.GeneratedImages.CountAsync()),
                ("GenerationPresets", () => DbContext.GenerationPresets.CountAsync()),
                ("PromptHistories", () => DbContext.PromptHistories.CountAsync()),
            };

            _dbTableCounts = new List<(string, int, string?)>();
            var hasErrors = false;

            foreach (var (name, countFn) in tables)
            {
                try
                {
                    var count = await countFn();
                    _dbTableCounts.Add((name, count, null));
                }
                catch (Exception ex)
                {
                    _dbTableCounts.Add((name, 0, ex.Message));
                    hasErrors = true;
                }
            }

            _dbHealthy = !hasErrors;
            _dbHealthStatus = hasErrors
                ? "Database has schema issues — some tables are inaccessible"
                : $"All {tables.Length} tables accessible and healthy";
        }
        catch (Exception ex)
        {
            _dbHealthy = false;
            _dbHealthStatus = $"Database unreachable: {ex.Message}";
            Logger.LogError(ex, "Database health check failed");
        }
        finally
        {
            _checkingDbHealth = false;
        }
    }
