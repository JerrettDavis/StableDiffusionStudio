@page "/settings"
@using StableDiffusionStudio.Application.DTOs
@using StableDiffusionStudio.Application.Interfaces
@using StableDiffusionStudio.Application.Services
@using StableDiffusionStudio.Domain.Enums
@using StableDiffusionStudio.Domain.ValueObjects
@inject IStorageRootProvider StorageRootProvider
@inject IDataManagementService DataManagement
@inject IProjectService ProjectService
@inject IProviderCredentialStore CredentialStore
@inject IInferenceSettingsProvider InferenceSettingsProvider
@inject IModelRuleService ModelRuleService
@inject IModelCatalogService CatalogService
@inject IContentSafetyService ContentSafety
@inject IOutputSettingsProvider OutputSettingsProvider
@inject IImageInterrogator ImageInterrogator
@inject IPromptAssistantService PromptAssistant
@inject ISettingsProvider SettingsProvider
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject ILogger<Settings> Logger
@inject IJSRuntime JS
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.JSInterop
@using Microsoft.EntityFrameworkCore
@inject StableDiffusionStudio.Infrastructure.Persistence.AppDbContext DbContext
@inject ISettingsExportService SettingsExportService
@inject IPluginManager PluginManager

@if (_loadError is not null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4" ShowCloseIcon="true"
              CloseIconClicked="() => _loadError = null">
        @_loadError
    </MudAlert>
}

<MudText Typo="Typo.h4" Class="mb-4">Settings</MudText>

<MudTabs Elevation="1" Rounded="true">
    <MudTabPanel Text="Storage Roots" Icon="@Icons.Material.Filled.Folder">
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
            Point the app at folders containing your model files (checkpoints, LoRAs, VAEs, embeddings).
            These are the same folders used by A1111/Forge/ComfyUI — you can share them.
            Tag a folder with a model type to help auto-classification during scanning.
        </MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add" OnClick="AddRoot" Class="mb-4">
            Add Directory
        </MudButton>

        @if (_roots is null)
        {
            <MudProgressLinear Indeterminate="true" />
        }
        else if (_roots.Count == 0)
        {
            <EmptyState Title="No directories configured"
                        Subtitle="Add a model directory to get started scanning for models"
                        Icon="@Icons.Material.Filled.FolderOff" />
        }
        else
        {
            <MudList T="StorageRoot">
                @foreach (var root in _roots)
                {
                    <MudListItem T="StorageRoot" Icon="@Icons.Material.Filled.Folder">
                        <div class="d-flex align-center justify-space-between" style="width: 100%;">
                            <div class="d-flex align-center gap-2">
                                <div>
                                    <MudText Typo="Typo.subtitle1">@root.DisplayName</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@root.Path</MudText>
                                </div>
                                @if (root.ModelTypeTag.HasValue)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Primary">@root.ModelTypeTag</MudChip>
                                }
                            </div>
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
                                           Size="Size.Small" OnClick="() => RemoveRoot(root)" />
                        </div>
                    </MudListItem>
                }
            </MudList>
        }
        @* Download Locations *@
        <MudDivider Class="my-4" />
        <MudText Typo="Typo.h6" Class="mb-2">Download Locations</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
            Configure where downloaded models are saved for each provider.
            Models are automatically organized into subfolders by type (Checkpoints/, LoRA/, VAE/, Embeddings/, ControlNet/).
        </MudText>

        @foreach (var provider in new[] { ("civitai", "CivitAI"), ("huggingface", "Hugging Face") })
        {
            <MudCard Elevation="1" Class="mb-3">
                <MudCardContent>
                    <MudText Typo="Typo.subtitle1" Class="mb-2">@provider.Item2</MudText>
                    <MudTextField Value="@GetDownloadRoot(provider.Item1)"
                                  ValueChanged="@((string val) => SetDownloadRoot(provider.Item1, val))"
                                  Label="Download root path"
                                  HelperText="Leave empty to use the default downloads folder"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2" />
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">
                        Auto-created subfolders: Checkpoints/ &bull; LoRA/ &bull; VAE/ &bull; Embeddings/ &bull; ControlNet/
                    </MudText>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                               OnClick="SaveDownloadLocations">
                        Save
                    </MudButton>
                </MudCardContent>
            </MudCard>
        }
    </MudTabPanel>

    <MudTabPanel Text="Model Sources" Icon="@Icons.Material.Filled.Cloud">
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
            Add API keys for remote model providers so you can search and download models directly from the app.
            Tokens are stored locally in the database — they are never sent anywhere except the provider's own API.
        </MudText>

        @if (_providerInfos is not null)
        {
            @foreach (var provider in _providerInfos.Where(p => p.Capabilities.CanSearch))
            {
                <MudCard Elevation="1" Class="mb-3">
                    <MudCardContent>
                        <div class="d-flex align-center justify-space-between mb-2">
                            <MudText Typo="Typo.subtitle1">@provider.DisplayName</MudText>
                            <MudChip T="string" Size="Size.Small"
                                     Color="@(HasToken(provider.ProviderId) ? Color.Success : Color.Default)">
                                @(HasToken(provider.ProviderId) ? "Connected" : "Not configured")
                            </MudChip>
                        </div>
                        <MudTextField Value="@GetTokenValue(provider.ProviderId)"
                                      ValueChanged="@((string val) => SetTokenValue(provider.ProviderId, val))"
                                      Label="@(provider.ProviderId == "huggingface" ? "HF Token" : "API Key")"
                                      InputType="InputType.Password"
                                      Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2" />
                        <div class="d-flex gap-2">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                       OnClick="() => SaveToken(provider.ProviderId)">Save</MudButton>
                            <MudButton Variant="Variant.Outlined" Size="Size.Small"
                                       OnClick="() => ValidateToken(provider.ProviderId)"
                                       Disabled="_validating">Validate</MudButton>
                            @if (HasToken(provider.ProviderId))
                            {
                                <MudButton Variant="Variant.Text" Color="Color.Error" Size="Size.Small"
                                           OnClick="() => RemoveToken(provider.ProviderId)">Remove</MudButton>
                            }
                        </div>
                    </MudCardContent>
                </MudCard>
            }
        }
    </MudTabPanel>

    <MudTabPanel Text="Model Rules" Icon="@Icons.Material.Filled.Tune">
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
            Define default generation settings per model family or individual checkpoint.
            Rules cascade: App Defaults → Family Rule → Checkpoint Rule.
            Only set values you want to override — leave others blank to inherit.
        </MudText>

        @* Family Rules *@
        <MudText Typo="Typo.h6" Class="mb-2">Family Rules</MudText>
        <div class="d-flex gap-2 mb-3">
            <MudAutocomplete T="string" Label="Add/Edit Family Rule" @bind-Value="_ruleEditFamily"
                             SearchFunc="SearchFamilies" Variant="Variant.Outlined" Margin="Margin.Dense"
                             Style="max-width:300px;" CoerceText="false" CoerceValue="false" />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                       OnClick="EditFamilyRule" Disabled="string.IsNullOrWhiteSpace(_ruleEditFamily)">
                Edit
            </MudButton>
        </div>

        @if (_familyRules is not null && _familyRules.Count > 0)
        {
            <MudSimpleTable Dense="true" Striped="true" Class="mb-4">
                <thead>
                    <tr>
                        <th>Family</th>
                        <th>Steps</th>
                        <th>CFG</th>
                        <th>Size</th>
                        <th>Sampler</th>
                        <th>Clip Skip</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var (family, rule) in _familyRules)
                    {
                        <tr>
                            <td><strong>@family</strong></td>
                            <td>@(rule.Steps?.ToString() ?? "-")</td>
                            <td>@(rule.CfgScale?.ToString("F1") ?? "-")</td>
                            <td>@(rule.Width.HasValue ? $"{rule.Width}x{rule.Height}" : "-")</td>
                            <td>@(rule.Sampler?.ToString() ?? "-")</td>
                            <td>@(rule.ClipSkip?.ToString() ?? "-")</td>
                            <td>
                                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                               OnClick="() => EditFamilyRuleByName(family)" />
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                               OnClick="() => DeleteFamilyRule(family)" />
                            </td>
                        </tr>
                    }
                </tbody>
            </MudSimpleTable>
        }

        @* Rule Editor Dialog (inline) *@
        @if (_editingRule is not null)
        {
            <MudPaper Class="pa-4 mb-4" Elevation="2" Style="border:2px solid var(--mud-palette-primary);">
                <MudText Typo="Typo.subtitle1" Class="mb-3">
                    Editing: @(_editingRuleTarget ?? "New Rule")
                    @if (_editingRuleIsCheckpoint) { <MudChip T="string" Size="Size.Small" Color="Color.Info">Checkpoint</MudChip> }
                    else { <MudChip T="string" Size="Size.Small" Color="Color.Primary">Family</MudChip> }
                </MudText>
                <MudGrid>
                    <MudItem xs="3">
                        <MudNumericField T="int?" @bind-Value="_editingRule.Steps" Label="Steps"
                                         Variant="Variant.Outlined" Margin="Margin.Dense" Min="1" Max="150" />
                    </MudItem>
                    <MudItem xs="3">
                        <MudNumericField T="double?" @bind-Value="_editingRule.CfgScale" Label="CFG Scale"
                                         Variant="Variant.Outlined" Margin="Margin.Dense" Min="0" Max="30" Step="0.5" />
                    </MudItem>
                    <MudItem xs="3">
                        <MudSelect T="Domain.Enums.Sampler?" @bind-Value="_editingRule.Sampler" Label="Sampler"
                                   Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true">
                            @foreach (var s in Enum.GetValues<Domain.Enums.Sampler>())
                            {
                                <MudSelectItem T="Domain.Enums.Sampler?" Value="@s">@s</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="3">
                        <MudSelect T="Domain.Enums.Scheduler?" @bind-Value="_editingRule.Scheduler" Label="Scheduler"
                                   Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true">
                            @foreach (var s in Enum.GetValues<Domain.Enums.Scheduler>())
                            {
                                <MudSelectItem T="Domain.Enums.Scheduler?" Value="@s">@s</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="3">
                        <MudNumericField T="int?" @bind-Value="_editingRule.Width" Label="Width"
                                         Variant="Variant.Outlined" Margin="Margin.Dense" Min="64" Step="64" />
                    </MudItem>
                    <MudItem xs="3">
                        <MudNumericField T="int?" @bind-Value="_editingRule.Height" Label="Height"
                                         Variant="Variant.Outlined" Margin="Margin.Dense" Min="64" Step="64" />
                    </MudItem>
                    <MudItem xs="3">
                        <MudNumericField T="int?" @bind-Value="_editingRule.ClipSkip" Label="Clip Skip"
                                         Variant="Variant.Outlined" Margin="Margin.Dense" Min="1" Max="12" />
                    </MudItem>
                    <MudItem xs="3">
                        <MudNumericField T="double?" @bind-Value="_editingRule.Eta" Label="Eta"
                                         Variant="Variant.Outlined" Margin="Margin.Dense" Min="0" Max="1" Step="0.1" />
                    </MudItem>
                    <MudItem xs="6">
                        <MudTextField T="string" @bind-Value="_editingRule.DefaultNegativePrompt" Label="Default Negative Prompt"
                                      Variant="Variant.Outlined" Margin="Margin.Dense" Lines="2" />
                    </MudItem>
                    <MudItem xs="3">
                        <MudNumericField T="double?" @bind-Value="_editingRule.DenoisingStrength" Label="Denoising"
                                         Variant="Variant.Outlined" Margin="Margin.Dense" Min="0" Max="1" Step="0.05" />
                    </MudItem>
                    <MudItem xs="3">
                        <MudSwitch T="bool?" @bind-Value="_editingRule.HiresFixEnabled" Label="Hires Fix" Color="Color.Primary" />
                    </MudItem>
                </MudGrid>
                <div class="d-flex gap-2 mt-3">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveEditingRule">Save</MudButton>
                    <MudButton Variant="Variant.Outlined" OnClick="CancelEditingRule">Cancel</MudButton>
                </div>
            </MudPaper>
        }
    </MudTabPanel>

    <MudTabPanel Text="Performance / Backend" Icon="@Icons.Material.Filled.Speed">
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
            Control how the inference engine uses your hardware. These settings affect VRAM usage, speed, and stability.
            Changes take effect the next time a model is loaded.
        </MudText>

        <MudText Typo="Typo.subtitle2" Class="mb-1">Quick Presets</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">
            Pick a preset to auto-configure all settings below for your GPU's VRAM. You can fine-tune individual settings after.
        </MudText>
        <MudChipSet T="string" Class="mb-4">
            <MudChip T="string" Color="Color.Success" OnClick="ApplyHighVRAM">High VRAM (16GB+)</MudChip>
            <MudChip T="string" Color="Color.Primary" OnClick="ApplyDefaultVRAM">Default (8-12GB)</MudChip>
            <MudChip T="string" Color="Color.Warning" OnClick="ApplyLowVRAM">Low VRAM (&lt;8GB)</MudChip>
        </MudChipSet>

        <MudNumericField T="int" Label="CPU Threads" @bind-Value="_inferenceSettings_ThreadCount"
                         Min="0" Max="128" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-4"
                         HelperText="@($"Number of CPU threads for computation. 0 = auto-detect ({Environment.ProcessorCount} on this machine). Lower values free CPU for other tasks.")" />

        <MudText Typo="Typo.subtitle2" Class="mt-2 mb-1">Speed Optimizations</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">
            These reduce memory usage and increase speed. Safe to enable on most modern GPUs.
        </MudText>

        <div class="mb-2">
            <MudSwitch T="bool" @bind-Value="_inferenceSettings_FlashAttention" Label="Flash Attention" Color="Color.Primary" />
            <MudText Typo="Typo.caption" Color="Color.Secondary" Style="margin-top:-8px; padding-left:48px">
                Faster, more memory-efficient attention calculation. Recommended for all GPUs. Required for some large models.
            </MudText>
        </div>
        <div class="mb-2">
            <MudSwitch T="bool" @bind-Value="_inferenceSettings_DiffusionFlashAttention" Label="Diffusion Flash Attention" Color="Color.Primary" />
            <MudText Typo="Typo.caption" Color="Color.Secondary" Style="margin-top:-8px; padding-left:48px">
                Uses half-precision (fp16) for attention keys/values in the diffusion model. Saves VRAM with minimal quality impact.
            </MudText>
        </div>
        <div class="mb-2">
            <MudSwitch T="bool" @bind-Value="_inferenceSettings_VaeTiling" Label="VAE Tiling" Color="Color.Primary" />
            <MudText Typo="Typo.caption" Color="Color.Secondary" Style="margin-top:-8px; padding-left:48px">
                Decodes the final image in tiles instead of all at once. Uses much less VRAM at high resolutions. Enable if you get out-of-memory errors during the final decode step.
            </MudText>
        </div>
        <div class="mb-2">
            <MudSwitch T="bool" @bind-Value="_inferenceSettings_EnableMmap" Label="Memory-Mapped File I/O" Color="Color.Primary" />
            <MudText Typo="Typo.caption" Color="Color.Secondary" Style="margin-top:-8px; padding-left:48px">
                Load model weights via memory mapping instead of reading into RAM. Can speed up model loading on fast SSDs but may cause issues on some systems.
            </MudText>
        </div>

        <MudDivider Class="my-3" />

        <MudText Typo="Typo.subtitle2" Class="mb-1">Startup</MudText>
        <div class="mb-4">
            <MudSwitch T="bool" @bind-Value="_inferenceSettings_PreloadLastModel" Label="Preload last used model on launch" Color="Color.Primary" />
            <MudText Typo="Typo.caption" Color="Color.Secondary" Style="margin-top:-8px; padding-left:48px">
                Automatically load your most recently used model in the background when the app starts. Makes the first generation much faster since the model is already in memory. Uses VRAM immediately on startup.
            </MudText>
        </div>

        <MudDivider Class="my-3" />

        <MudText Typo="Typo.subtitle2" Class="mb-1">GPU/CPU Offloading</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">
            Move parts of the model from GPU to CPU to free VRAM. Useful when your GPU doesn't have enough memory for the full model.
            Trade-off: saves VRAM but slows generation. On NVIDIA GPUs with CUDA, offloading is automatically disabled to prevent crashes on hybrid Intel CPUs.
        </MudText>

        <div class="mb-2">
            <MudSwitch T="bool" @bind-Value="_inferenceSettings_KeepClipOnCPU" Label="CLIP Text Encoder on CPU" Color="Color.Primary" />
            <MudText Typo="Typo.caption" Color="Color.Secondary" Style="margin-top:-8px; padding-left:48px">
                Run the text encoder (which converts your prompt to tokens) on CPU. Frees ~1-2 GB VRAM. Slightly slower prompt processing.
            </MudText>
        </div>
        <div class="mb-2">
            <MudSwitch T="bool" @bind-Value="_inferenceSettings_KeepVaeOnCPU" Label="VAE Decoder on CPU" Color="Color.Primary" />
            <MudText Typo="Typo.caption" Color="Color.Secondary" Style="margin-top:-8px; padding-left:48px">
                Run the VAE (which converts latent noise to the final image) on CPU. Frees ~1-2 GB VRAM. Slower final decode step.
            </MudText>
        </div>
        <div class="mb-2">
            <MudSwitch T="bool" @bind-Value="_inferenceSettings_KeepControlNetOnCPU" Label="ControlNet on CPU" Color="Color.Primary" />
            <MudText Typo="Typo.caption" Color="Color.Secondary" Style="margin-top:-8px; padding-left:48px">
                Run ControlNet models on CPU. Frees significant VRAM when using ControlNet guidance. No effect if ControlNet is not in use.
            </MudText>
        </div>
        <div class="mb-2">
            <MudSwitch T="bool" @bind-Value="_inferenceSettings_OffloadParamsToCPU" Label="Offload Model Parameters to CPU" Color="Color.Primary" />
            <MudText Typo="Typo.caption" Color="Color.Secondary" Style="margin-top:-8px; padding-left:48px">
                Keep model weights in system RAM and stream them to the GPU during computation. Dramatically reduces VRAM usage but significantly slows generation. Last resort for very low VRAM GPUs.
            </MudText>
        </div>
        <div class="mb-4">
            <MudSwitch T="bool" @bind-Value="_inferenceSettings_VaeDecodeOnly" Label="VAE Decode Only" Color="Color.Primary" />
            <MudText Typo="Typo.caption" Color="Color.Secondary" Style="margin-top:-8px; padding-left:48px">
                Skip building the VAE encoder (only build the decoder). Saves a small amount of VRAM but breaks img2img and inpainting, which need the encoder. Leave off unless you only use txt2img.
            </MudText>
        </div>

        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveInferenceSettings">
            Save Performance Settings
        </MudButton>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
            Changes apply the next time a model is loaded. If a model is already loaded, generate once to trigger a reload.
        </MudText>
    </MudTabPanel>

    <MudTabPanel Text="Content Safety" Icon="@Icons.Material.Filled.Shield">
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
            Locally detect and filter NSFW content. All classification runs on your machine — no data leaves your system.
        </MudText>

        <MudText Typo="Typo.subtitle2" Class="mb-2">Filter Mode</MudText>
        <MudRadioGroup T="NsfwFilterMode" Value="_nsfwFilterMode" ValueChanged="OnFilterModeChanged">
            <MudRadio T="NsfwFilterMode" Value="NsfwFilterMode.Off" Color="Color.Default">
                <MudText Typo="Typo.body2">Off</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">No content filtering. All images shown as generated.</MudText>
            </MudRadio>
            <MudRadio T="NsfwFilterMode" Value="NsfwFilterMode.Blur" Color="Color.Warning" Class="mt-2">
                <MudText Typo="Typo.body2">Blur &amp; Reveal</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">NSFW images are blurred. You can reveal individual images by clicking them.</MudText>
            </MudRadio>
            <MudRadio T="NsfwFilterMode" Value="NsfwFilterMode.BlockAndDelete" Color="Color.Error" Class="mt-2">
                <MudText Typo="Typo.body2">Block &amp; Delete</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">NSFW images are automatically deleted immediately after generation. Cannot be recovered.</MudText>
            </MudRadio>
        </MudRadioGroup>

        <MudDivider Class="my-4" />

        <MudText Typo="Typo.subtitle2" Class="mb-2">Sensitivity</MudText>
        <MudSlider T="double" Value="_nsfwThreshold" ValueChanged="OnNsfwThresholdChanged"
                   Min="0.1" Max="0.9" Step="0.05" Color="Color.Warning">
            NSFW Threshold: <span class="param-value">@_nsfwThreshold.ToString("P0")</span>
        </MudSlider>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-3">
            Lower = more strict (blocks more). Higher = more lenient. Default: 50%
        </MudText>

        <MudSlider T="double" Value="_questionableThreshold" ValueChanged="OnQuestionableThresholdChanged"
                   Min="0.05" Max="0.5" Step="0.05" Color="Color.Info">
            Questionable Threshold: <span class="param-value">@_questionableThreshold.ToString("P0")</span>
        </MudSlider>
        <MudText Typo="Typo.caption" Color="Color.Secondary">
            Content above this score but below NSFW threshold is marked as questionable.
        </MudText>

        <MudDivider Class="my-4" />

        <MudText Typo="Typo.subtitle2" Class="mb-2">About</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary">
            Content safety is powered by NsfwSpy, an ML.NET model that runs entirely on your machine.
            No images or data are sent to any external service. Classification categories: Neutral, Sexy, Hentai, Pornography.
        </MudText>
    </MudTabPanel>

    <MudTabPanel Text="Output" Icon="@Icons.Material.Filled.SaveAlt">
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
            Control where and how generated images are saved to disk. By default, images are saved in the app's local data directory organized by project and job.
        </MudText>

        <MudTextField T="string" Label="Custom Output Directory"
                      Value="_outputCustomDir" ValueChanged="v => _outputCustomDir = v"
                      Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-3"
                      Placeholder="e.g., D:\StableDiffusion\Output"
                      HelperText="Override the default save location. Leave empty to use the app's data directory. Images are organized into project/job subfolders automatically." />

        <MudTextField T="string" Label="Filename Pattern" Value="_outputFilenamePattern" ValueChanged="v => _outputFilenamePattern = v"
                      Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-3"
                      HelperText="Tokens: [seed] = generation seed, [prompt] = first 50 chars of prompt, [date] = timestamp, [model] = model name. Example: [seed]-[date] → 12345-20260321-143022.png" />

        <div class="mb-2">
            <MudSwitch T="bool" @bind-Value="_outputAutoSave" Label="Auto-save images after generation" Color="Color.Primary" />
            <MudText Typo="Typo.caption" Color="Color.Secondary" Style="margin-top:-8px; padding-left:48px">
                Automatically save every generated image to disk. If off, images only exist in the gallery until the app restarts.
            </MudText>
        </div>
        <div class="mb-4">
            <MudSwitch T="bool" @bind-Value="_outputSaveGrid" Label="Save image grid for batch generations" Color="Color.Primary" />
            <MudText Typo="Typo.caption" Color="Color.Secondary" Style="margin-top:-8px; padding-left:48px">
                When generating multiple images in a batch, also save a single grid image combining all results side by side.
            </MudText>
        </div>

        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveOutputSettings">
            Save Output Settings
        </MudButton>
    </MudTabPanel>

    <MudTabPanel Text="Interrogation" Icon="@Icons.Material.Filled.ImageSearch">
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
            Configure the vision model used to generate prompts from images. Requires a running
            <MudLink Href="https://ollama.com" Target="_blank">Ollama</MudLink> instance with a vision model installed
            (e.g., <code>ollama pull llava</code> or <code>ollama pull llama3.2-vision</code>).
        </MudText>

        <MudTextField T="string" Label="Ollama URL" Value="_interrogateUrl" ValueChanged="v => _interrogateUrl = v"
                      Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-3"
                      Placeholder="http://localhost:11434"
                      HelperText="The address where Ollama is running. Default is localhost:11434. Change this if Ollama runs on a different machine or port." />

        <MudTextField T="string" Label="Vision Model" Value="_interrogateModel" ValueChanged="v => _interrogateModel = v"
                      Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-3"
                      HelperText="Which Ollama model to use for image analysis. Popular choices: llava (good quality, ~5GB), moondream (fast, ~2GB), llama3.2-vision (best quality, ~8GB). Install with: ollama pull <model>" />

        <MudTextField T="string" Label="System Prompt" Lines="4" Value="_interrogateSystemPrompt"
                      ValueChanged="v => _interrogateSystemPrompt = v"
                      Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-3"
                      HelperText="Instructions that tell the vision model HOW to describe the image. The default produces comma-separated tags suitable for Stable Diffusion prompts. Customize for different output styles." />

        <div class="d-flex gap-2">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveInterrogationSettings">
                Save Interrogation Settings
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="TestOllamaConnection">
                Test Connection
            </MudButton>
        </div>
    </MudTabPanel>

    <MudTabPanel Text="Prompt Assistant" Icon="@Icons.Material.Filled.AutoFixHigh">
        <MudText Typo="Typo.h6" Class="mb-4">AI Prompt Assistant</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
            Use a local Ollama model to generate and refine prompts. Configure the instance,
            model, and system prompts below. Use template variables to give context about the current generation setup.
        </MudText>

        <MudTextField T="string" @bind-Value="_promptAssistantUrl" Label="Ollama URL"
                      Placeholder="http://localhost:11434" Variant="Variant.Outlined" Class="mb-3"
                      HelperText="The address where Ollama is running. Can be the same instance as the interrogation model." />

        <MudTextField T="string" @bind-Value="_promptAssistantModel" Label="Text Model"
                      Variant="Variant.Outlined" Class="mb-3"
                      HelperText="A text-only model (e.g., llama3.2, mistral, gemma2). Does not need vision capabilities." />

        <MudText Typo="Typo.subtitle2" Class="mb-2 mt-4">Prompt Templates</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-3">
            Available variables: <code>{{model}}</code> <code>{{family}}</code> <code>{{vae}}</code>
            <code>{{loras}}</code> <code>{{width}}</code> <code>{{height}}</code>
            <code>{{steps}}</code> <code>{{cfg}}</code> <code>{{sampler}}</code>
            <code>{{scheduler}}</code> <code>{{prompt}}</code> <code>{{negative}}</code>
        </MudText>

        <MudTextField T="string" @bind-Value="_promptAssistantGenerate" Label="Generate Positive Prompt"
                      Lines="3" Variant="Variant.Outlined" Class="mb-3"
                      HelperText="Template used when generating a random prompt from scratch." />

        <MudTextField T="string" @bind-Value="_promptAssistantRefine" Label="Refine Positive Prompt"
                      Lines="3" Variant="Variant.Outlined" Class="mb-3"
                      HelperText="Template used when improving an existing prompt. Use {{prompt}} for the current text." />

        <MudTextField T="string" @bind-Value="_promptAssistantGenerateNeg" Label="Generate Negative Prompt"
                      Lines="3" Variant="Variant.Outlined" Class="mb-3"
                      HelperText="Template used when generating a negative prompt from scratch." />

        <MudTextField T="string" @bind-Value="_promptAssistantRefineNeg" Label="Refine Negative Prompt"
                      Lines="3" Variant="Variant.Outlined" Class="mb-3"
                      HelperText="Template used when improving an existing negative prompt. Use {{negative}} for the current text." />

        <div class="d-flex gap-2 mt-4">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SavePromptAssistantSettings">
                Save Prompt Assistant Settings
            </MudButton>
            <MudButton Variant="Variant.Outlined" OnClick="TestPromptAssistantConnection">
                Test Connection
            </MudButton>
        </div>

        <MudDivider Class="my-4" />
        <MudText Typo="Typo.caption" Color="Color.Secondary">
            Prompt generation uses a text-only Ollama model (no vision needed). The model receives the template
            with variables substituted for your current generation setup, so it can tailor prompts to your specific
            checkpoint, LoRAs, and resolution.
        </MudText>
    </MudTabPanel>

    <MudTabPanel Text="Appearance" Icon="@Icons.Material.Filled.Palette">
        <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-3">
            Appearance settings will be available in a future update.
        </MudText>
        <MudAlert Severity="Severity.Info" Dense="true">
            The application currently uses a dark theme by default.
        </MudAlert>
    </MudTabPanel>

    <MudTabPanel Text="Plugins" Icon="@Icons.Material.Filled.Extension">
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
            Plugins extend Stable Diffusion Studio with additional capabilities such as post-processing, custom model sources, and more.
            Place plugin DLLs in the Plugins directory and restart the application.
        </MudText>

        @if (_loadedPlugins is not null && _loadedPlugins.Count > 0)
        {
            <MudSimpleTable Dense="true" Hover="true" Striped="true" Elevation="1" Class="mb-4">
                <thead>
                    <tr><th>Name</th><th>Version</th><th>Type</th><th>Description</th></tr>
                </thead>
                <tbody>
                    @foreach (var plugin in _loadedPlugins)
                    {
                        <tr>
                            <td><MudText Typo="Typo.subtitle2">@plugin.Name</MudText></td>
                            <td><MudChip T="string" Size="Size.Small" Color="Color.Info">@plugin.Version</MudChip></td>
                            <td>@GetPluginType(plugin)</td>
                            <td><MudText Typo="Typo.body2" Color="Color.Secondary">@plugin.Description</MudText></td>
                        </tr>
                    }
                </tbody>
            </MudSimpleTable>
        }
        else
        {
            <EmptyState Title="No plugins loaded"
                        Subtitle="Place plugin DLLs in the Plugins directory and restart the application"
                        Icon="@Icons.Material.Filled.ExtensionOff" />
        }
    </MudTabPanel>

    <MudTabPanel Text="Diagnostics" Icon="@Icons.Material.Filled.BugReport">
        <MudText Typo="Typo.subtitle2" Class="mb-2">System Information</MudText>
        <MudSimpleTable Dense="true" Hover="true" Elevation="0" Class="mb-4">
            <tbody>
                <tr><td><strong>Runtime</strong></td><td>@System.Runtime.InteropServices.RuntimeInformation.FrameworkDescription</td></tr>
                <tr><td><strong>OS</strong></td><td>@System.Runtime.InteropServices.RuntimeInformation.OSDescription</td></tr>
                <tr><td><strong>Storage Roots</strong></td><td>@(_roots?.Count ?? 0)</td></tr>
            </tbody>
        </MudSimpleTable>

        <MudText Typo="Typo.subtitle2" Class="mb-2">Database Health</MudText>
        @if (_dbHealthStatus is null)
        {
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                       OnClick="CheckDatabaseHealth" Disabled="_checkingDbHealth" Class="mb-3">
                @if (_checkingDbHealth)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    <span>Checking...</span>
                }
                else
                {
                    <span>Run Health Check</span>
                }
            </MudButton>
        }
        else
        {
            <MudAlert Severity="@(_dbHealthy ? Severity.Success : Severity.Error)" Dense="true" Class="mb-3">
                @_dbHealthStatus
            </MudAlert>
            @if (_dbTableCounts is not null)
            {
                <MudSimpleTable Dense="true" Hover="true" Striped="true" Elevation="0" Class="mb-3">
                    <thead>
                        <tr><th>Table</th><th>Row Count</th><th>Status</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var (table, count, error) in _dbTableCounts)
                        {
                            <tr>
                                <td>@table</td>
                                <td>@(error is not null ? "N/A" : count.ToString())</td>
                                <td>
                                    @if (error is not null)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Error">@error</MudChip>
                                    }
                                    else
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Success">OK</MudChip>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>
            }
            <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="CheckDatabaseHealth"
                       Disabled="_checkingDbHealth">
                Re-check
            </MudButton>
        }
    </MudTabPanel>

    <MudTabPanel Text="Export / Import" Icon="@Icons.Material.Filled.ImportExport">
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
            Export all settings to a JSON file or import settings from a previously exported file.
        </MudText>

        <div class="d-flex gap-3 mb-4">
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Download"
                       OnClick="ExportSettings" Disabled="_exporting">
                @if (_exporting)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    <span>Exporting...</span>
                }
                else
                {
                    <span>Export Settings</span>
                }
            </MudButton>

            <MudFileUpload T="IBrowserFile" Accept=".json" FilesChanged="ImportSettings" MaximumFileCount="1">
                <ActivatorContent>
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Upload">
                        Import Settings
                    </MudButton>
                </ActivatorContent>
            </MudFileUpload>
        </div>

        <MudAlert Severity="Severity.Info" Dense="true">
            Exported settings include all configuration stored in the database (storage roots, inference settings,
            content safety, output settings, provider credentials). Importing will overwrite existing values.
        </MudAlert>
    </MudTabPanel>

    <MudTabPanel Text="Data Management" Icon="@Icons.Material.Filled.DeleteSweep">
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
            Manage and clean up application data. Deletions are permanent and cannot be undone.
        </MudText>

        @if (_usageSummary is null)
        {
            <MudProgressLinear Indeterminate="true" />
        }
        else
        {
            <MudText Typo="Typo.subtitle2" Class="mb-2">Data Usage</MudText>
            <MudSimpleTable Dense="true" Striped="true" Class="mb-4">
                <tbody>
                    <tr><td>Projects</td><td>@_usageSummary.ProjectCount</td><td></td></tr>
                    <tr><td>Model Records</td><td>@_usageSummary.ModelRecordCount</td>
                        <td><MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Error"
                                       OnClick="@(() => ConfirmAndDelete("all model records", DataManagement.DeleteAllModelRecordsAsync))">
                                Clear
                            </MudButton></td></tr>
                    <tr><td>Generation Jobs</td><td>@_usageSummary.GenerationJobCount</td>
                        <td><MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Error"
                                       OnClick="@(() => ConfirmAndDelete("all generation jobs and images", DataManagement.DeleteGenerationJobsAsync))">
                                Clear
                            </MudButton></td></tr>
                    <tr><td>Generated Images</td><td>@_usageSummary.GeneratedImageCount</td>
                        <td><MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Error"
                                       OnClick="@(() => ConfirmAndDelete("all generated images", DataManagement.DeleteAllGeneratedImagesAsync))">
                                Clear
                            </MudButton></td></tr>
                    <tr><td>Background Jobs</td><td>@_usageSummary.JobRecordCount</td>
                        <td>
                            <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Warning"
                                       OnClick="@(() => ConfirmAndDelete("completed job records", DataManagement.DeleteCompletedJobRecordsAsync))">
                                Clear Completed
                            </MudButton>
                            <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Error"
                                       OnClick="@(() => ConfirmAndDelete("failed job records", DataManagement.DeleteFailedJobRecordsAsync))">
                                Clear Failed
                            </MudButton>
                            <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Error"
                                       OnClick="@(() => ConfirmAndDelete("all job records", DataManagement.DeleteAllJobRecordsAsync))">
                                Clear All
                            </MudButton>
                        </td></tr>
                    <tr><td>Disk Usage (Assets)</td>
                        <td>@FormatBytes(_usageSummary.AssetsDiskUsageBytes)</td>
                        <td><MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Warning"
                                       OnClick="CleanOrphanedAssets">
                                Clean Orphaned Files
                            </MudButton></td></tr>
                </tbody>
            </MudSimpleTable>

            <MudText Typo="Typo.subtitle2" Class="mb-2">Per-Project Cleanup</MudText>
            <MudSelect T="Guid?" Label="Select Project" @bind-Value="_selectedProjectForCleanup"
                       Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true" Class="mb-2">
                @if (_projectList is not null)
                {
                    @foreach (var p in _projectList)
                    {
                        <MudSelectItem T="Guid?" Value="@p.Id">@p.Name (@p.Id.ToString()[..8]...)</MudSelectItem>
                    }
                }
            </MudSelect>

            @if (_selectedProjectForCleanup.HasValue)
            {
                <div class="d-flex gap-2 mb-4">
                    <MudButton Variant="Variant.Outlined" Color="Color.Warning" Size="Size.Small"
                               OnClick="DeleteProjectImages">Delete Images</MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                               OnClick="DeleteProjectGenerations">Delete All Generations</MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Error" Size="Size.Small"
                               OnClick="DeleteSelectedProject">Delete Entire Project</MudButton>
                </div>
            }

            <MudDivider Class="my-4" />

            <MudText Typo="Typo.subtitle2" Class="mb-2" Color="Color.Error">Danger Zone</MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Error"
                       StartIcon="@Icons.Material.Filled.Warning"
                       OnClick="ResetAllData">
                Reset All Data
            </MudButton>
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
                Deletes all projects, generations, images, model records, and job history. Settings are preserved.
            </MudText>
        }
    </MudTabPanel>
</MudTabs>

@code {
    private IReadOnlyList<StorageRoot>? _roots;
    private IReadOnlyList<ModelProviderInfo>? _providerInfos;
    private readonly Dictionary<string, string> _tokenValues = new();
    private readonly HashSet<string> _configuredProviders = new();
    private bool _validating;
    private string? _loadError;

    // Data management fields
    private DataUsageSummary? _usageSummary;
    private IReadOnlyList<ProjectDto>? _projectList;
    private Guid? _selectedProjectForCleanup;

    // Content safety fields
    private NsfwFilterMode _nsfwFilterMode;
    private double _nsfwThreshold = 0.5;
    private double _questionableThreshold = 0.3;

    // Output settings fields
    private string _outputCustomDir = string.Empty;
    private string _outputFilenamePattern = "[seed]";
    private bool _outputAutoSave = true;
    private bool _outputSaveGrid;

    // Download location settings
    private DownloadLocationSettings _downloadLocationSettings = DownloadLocationSettings.Default;
    private readonly Dictionary<string, string> _downloadRootValues = new();

    // Interrogation settings fields
    private string _interrogateUrl = "http://localhost:11434";
    private string _interrogateModel = "llava";
    private string _interrogateSystemPrompt = StableDiffusionStudio.Domain.ValueObjects.InterrogationSettings.Default.SystemPrompt;

    // Prompt assistant settings fields
    private string _promptAssistantUrl = "http://localhost:11434";
    private string _promptAssistantModel = "llama3.2";
    private string _promptAssistantGenerate = "";
    private string _promptAssistantRefine = "";
    private string _promptAssistantGenerateNeg = "";
    private string _promptAssistantRefineNeg = "";

    // Model rules fields
    private IReadOnlyDictionary<string, ModelRuleSet>? _familyRules;
    private string? _ruleEditFamily;
    private MutableRuleSet? _editingRule;
    private string? _editingRuleTarget;
    private bool _editingRuleIsCheckpoint;

    // Mutable wrapper for editing (records are immutable)
    private class MutableRuleSet
    {
        public int? Steps { get; set; }
        public double? CfgScale { get; set; }
        public Domain.Enums.Sampler? Sampler { get; set; }
        public Domain.Enums.Scheduler? Scheduler { get; set; }
        public int? ClipSkip { get; set; }
        public double? Eta { get; set; }
        public int? Width { get; set; }
        public int? Height { get; set; }
        public double? DenoisingStrength { get; set; }
        public bool? HiresFixEnabled { get; set; }
        public string? DefaultNegativePrompt { get; set; }

        public static MutableRuleSet From(ModelRuleSet r) => new()
        {
            Steps = r.Steps, CfgScale = r.CfgScale, Sampler = r.Sampler, Scheduler = r.Scheduler,
            ClipSkip = r.ClipSkip, Eta = r.Eta, Width = r.Width, Height = r.Height,
            DenoisingStrength = r.DenoisingStrength, HiresFixEnabled = r.HiresFixEnabled,
            DefaultNegativePrompt = r.DefaultNegativePrompt
        };

        public ModelRuleSet ToRuleSet() => new()
        {
            Steps = Steps, CfgScale = CfgScale, Sampler = Sampler, Scheduler = Scheduler,
            ClipSkip = ClipSkip, Eta = Eta, Width = Width, Height = Height,
            DenoisingStrength = DenoisingStrength, HiresFixEnabled = HiresFixEnabled,
            DefaultNegativePrompt = DefaultNegativePrompt
        };
    }

    // Inference settings fields
    private int _inferenceSettings_ThreadCount;
    private bool _inferenceSettings_FlashAttention;
    private bool _inferenceSettings_DiffusionFlashAttention;
    private bool _inferenceSettings_VaeTiling;
    private bool _inferenceSettings_VaeDecodeOnly;
    private bool _inferenceSettings_KeepClipOnCPU;
    private bool _inferenceSettings_KeepVaeOnCPU;
    private bool _inferenceSettings_KeepControlNetOnCPU;
    private bool _inferenceSettings_OffloadParamsToCPU;
    private bool _inferenceSettings_EnableMmap;
    private bool _inferenceSettings_PreloadLastModel;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await LoadRoots();
            await LoadDownloadLocations();
            await LoadModelRules();
            await LoadProviders();
            await LoadContentSafety();
            await LoadInferenceSettings();
            await LoadOutputSettings();
            await LoadInterrogationSettings();
            await LoadPromptAssistantSettings();
            await LoadDataManagement();
            await LoadPlugins();
        }
        catch (Exception ex)
        {
            _loadError = $"Failed to load settings: {ex.Message}";
            Logger.LogError(ex, "Failed to load settings");
        }
    }

    private async Task LoadRoots()
    {
        _roots = await StorageRootProvider.GetRootsAsync();
    }

    private async Task LoadDownloadLocations()
    {
        _downloadLocationSettings = await SettingsProvider.GetAsync<DownloadLocationSettings>("DownloadLocations")
                                     ?? DownloadLocationSettings.Default;
        _downloadRootValues.Clear();
        foreach (var kvp in _downloadLocationSettings.ProviderRoots)
            _downloadRootValues[kvp.Key] = kvp.Value;
    }

    private string GetDownloadRoot(string providerId)
        => _downloadRootValues.TryGetValue(providerId, out var val) ? val : "";

    private void SetDownloadRoot(string providerId, string value)
        => _downloadRootValues[providerId] = value;

    private async Task SaveDownloadLocations()
    {
        var roots = _downloadRootValues
            .Where(kvp => !string.IsNullOrWhiteSpace(kvp.Value))
            .ToDictionary(kvp => kvp.Key, kvp => kvp.Value.Trim());
        _downloadLocationSettings = new DownloadLocationSettings { ProviderRoots = roots };
        await SettingsProvider.SetAsync("DownloadLocations", _downloadLocationSettings);
        Snackbar.Add("Download locations saved.", MudBlazor.Severity.Success);
    }

    private async Task LoadModelRules()
    {
        _familyRules = await ModelRuleService.ListFamilyRulesAsync();
    }

    private async Task<IEnumerable<string>> SearchFamilies(string? value, CancellationToken ct)
    {
        var families = await ModelRuleService.GetKnownFamiliesAsync(ct);
        if (string.IsNullOrWhiteSpace(value)) return families;
        return families.Where(f => f.Contains(value, StringComparison.OrdinalIgnoreCase));
    }

    private async Task EditFamilyRule()
    {
        if (string.IsNullOrWhiteSpace(_ruleEditFamily)) return;
        await EditFamilyRuleByName(_ruleEditFamily);
    }

    private async Task EditFamilyRuleByName(string family)
    {
        var existing = await ModelRuleService.GetFamilyRuleAsync(family);
        _editingRule = existing is not null ? MutableRuleSet.From(existing) : new MutableRuleSet();
        _editingRuleTarget = family;
        _editingRuleIsCheckpoint = false;
        _ruleEditFamily = family;
    }

    private async Task SaveEditingRule()
    {
        if (_editingRule is null || _editingRuleTarget is null) return;
        var ruleSet = _editingRule.ToRuleSet();

        if (_editingRuleIsCheckpoint && Guid.TryParse(_editingRuleTarget, out var cpId))
            await ModelRuleService.SetCheckpointRuleAsync(cpId, ruleSet);
        else
            await ModelRuleService.SetFamilyRuleAsync(_editingRuleTarget, ruleSet);

        _editingRule = null;
        _editingRuleTarget = null;
        await LoadModelRules();
        Snackbar.Add("Model rule saved.", MudBlazor.Severity.Success);
    }

    private void CancelEditingRule()
    {
        _editingRule = null;
        _editingRuleTarget = null;
    }

    private async Task DeleteFamilyRule(string family)
    {
        await ModelRuleService.DeleteFamilyRuleAsync(family);
        await LoadModelRules();
        Snackbar.Add($"Rule for '{family}' deleted.", MudBlazor.Severity.Info);
    }

    private async Task LoadProviders()
    {
        _providerInfos = CatalogService.GetProviders();
        foreach (var provider in _providerInfos.Where(p => p.Capabilities.CanSearch))
        {
            var existingToken = await CredentialStore.GetTokenAsync(provider.ProviderId);
            if (existingToken is not null)
            {
                _tokenValues[provider.ProviderId] = existingToken;
                _configuredProviders.Add(provider.ProviderId);
            }
            else
            {
                _tokenValues[provider.ProviderId] = string.Empty;
            }
        }
    }

    private string GetTokenValue(string providerId) =>
        _tokenValues.TryGetValue(providerId, out var val) ? val : string.Empty;

    private void SetTokenValue(string providerId, string value) =>
        _tokenValues[providerId] = value;

    private bool HasToken(string providerId) =>
        _configuredProviders.Contains(providerId);

    private async Task SaveToken(string providerId)
    {
        var token = GetTokenValue(providerId);
        if (string.IsNullOrWhiteSpace(token))
        {
            Snackbar.Add("Token cannot be empty", MudBlazor.Severity.Warning);
            return;
        }

        await CredentialStore.SetTokenAsync(providerId, token);
        _configuredProviders.Add(providerId);
        Snackbar.Add("Token saved", MudBlazor.Severity.Success);
    }

    private async Task ValidateToken(string providerId)
    {
        _validating = true;
        StateHasChanged();
        try
        {
            // Ensure token is saved before validating
            var token = GetTokenValue(providerId);
            if (!string.IsNullOrWhiteSpace(token))
            {
                await CredentialStore.SetTokenAsync(providerId, token);
                _configuredProviders.Add(providerId);
            }

            var providers = CatalogService.GetProviders();
            var provider = providers.FirstOrDefault(p => p.ProviderId == providerId);
            if (provider is null)
            {
                Snackbar.Add("Provider not found", MudBlazor.Severity.Error);
                return;
            }

            // Use search with empty query as a credential validation test
            var result = await CatalogService.SearchAsync(new ModelSearchQuery(providerId, "test", PageSize: 1));
            Snackbar.Add("Credentials are valid", MudBlazor.Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Validation failed: {ex.Message}", MudBlazor.Severity.Error);
        }
        finally
        {
            _validating = false;
        }
    }

    private async Task RemoveToken(string providerId)
    {
        await CredentialStore.RemoveTokenAsync(providerId);
        _tokenValues[providerId] = string.Empty;
        _configuredProviders.Remove(providerId);
        Snackbar.Add("Token removed", MudBlazor.Severity.Info);
    }

    private async Task AddRoot()
    {
        var dialog = await DialogService.ShowAsync<Dialogs.AddStorageRootDialog>("Add Model Directory");
        var result = await dialog.Result;
        if (result is not null && !result.Canceled)
        {
            await LoadRoots();
            Snackbar.Add("Directory added", MudBlazor.Severity.Success);
        }
    }

    private async Task RemoveRoot(StorageRoot root)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Remove Directory",
            $"Remove '{root.DisplayName}' from storage roots? This will not delete any files.",
            yesText: "Remove", cancelText: "Cancel");

