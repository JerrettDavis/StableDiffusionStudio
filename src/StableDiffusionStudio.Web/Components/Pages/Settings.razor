@page "/settings"
@using StableDiffusionStudio.Application.DTOs
@using StableDiffusionStudio.Application.Interfaces
@using StableDiffusionStudio.Application.Services
@using StableDiffusionStudio.Domain.Enums
@using StableDiffusionStudio.Domain.ValueObjects
@inject IStorageRootProvider StorageRootProvider
@inject IDataManagementService DataManagement
@inject IProjectService ProjectService
@inject IProviderCredentialStore CredentialStore
@inject IInferenceSettingsProvider InferenceSettingsProvider
@inject IModelCatalogService CatalogService
@inject IContentSafetyService ContentSafety
@inject IOutputSettingsProvider OutputSettingsProvider
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject ILogger<Settings> Logger
@using Microsoft.EntityFrameworkCore
@inject StableDiffusionStudio.Infrastructure.Persistence.AppDbContext DbContext

@if (_loadError is not null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4" ShowCloseIcon="true"
              CloseIconClicked="() => _loadError = null">
        @_loadError
    </MudAlert>
}

<MudText Typo="Typo.h4" Class="mb-4">Settings</MudText>

<MudTabs Elevation="1" Rounded="true">
    <MudTabPanel Text="Storage Roots" Icon="@Icons.Material.Filled.Folder">
        <MudText Typo="Typo.body1" Class="mb-3">
            Configure directories where your model files are stored.
        </MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add" OnClick="AddRoot" Class="mb-4">
            Add Directory
        </MudButton>

        @if (_roots is null)
        {
            <MudProgressLinear Indeterminate="true" />
        }
        else if (_roots.Count == 0)
        {
            <EmptyState Title="No directories configured"
                        Subtitle="Add a model directory to get started scanning for models"
                        Icon="@Icons.Material.Filled.FolderOff" />
        }
        else
        {
            <MudList T="StorageRoot">
                @foreach (var root in _roots)
                {
                    <MudListItem T="StorageRoot" Icon="@Icons.Material.Filled.Folder">
                        <div class="d-flex align-center justify-space-between" style="width: 100%;">
                            <div class="d-flex align-center gap-2">
                                <div>
                                    <MudText Typo="Typo.subtitle1">@root.DisplayName</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@root.Path</MudText>
                                </div>
                                @if (root.ModelTypeTag.HasValue)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Primary">@root.ModelTypeTag</MudChip>
                                }
                            </div>
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
                                           Size="Size.Small" OnClick="() => RemoveRoot(root)" />
                        </div>
                    </MudListItem>
                }
            </MudList>
        }
    </MudTabPanel>

    <MudTabPanel Text="Model Sources" Icon="@Icons.Material.Filled.Cloud">
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
            Configure credentials for remote model providers.
        </MudText>

        @if (_providerInfos is not null)
        {
            @foreach (var provider in _providerInfos.Where(p => p.Capabilities.CanSearch))
            {
                <MudCard Elevation="1" Class="mb-3">
                    <MudCardContent>
                        <div class="d-flex align-center justify-space-between mb-2">
                            <MudText Typo="Typo.subtitle1">@provider.DisplayName</MudText>
                            <MudChip T="string" Size="Size.Small"
                                     Color="@(HasToken(provider.ProviderId) ? Color.Success : Color.Default)">
                                @(HasToken(provider.ProviderId) ? "Connected" : "Not configured")
                            </MudChip>
                        </div>
                        <MudTextField Value="@GetTokenValue(provider.ProviderId)"
                                      ValueChanged="@((string val) => SetTokenValue(provider.ProviderId, val))"
                                      Label="@(provider.ProviderId == "huggingface" ? "HF Token" : "API Key")"
                                      InputType="InputType.Password"
                                      Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2" />
                        <div class="d-flex gap-2">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                       OnClick="() => SaveToken(provider.ProviderId)">Save</MudButton>
                            <MudButton Variant="Variant.Outlined" Size="Size.Small"
                                       OnClick="() => ValidateToken(provider.ProviderId)"
                                       Disabled="_validating">Validate</MudButton>
                            @if (HasToken(provider.ProviderId))
                            {
                                <MudButton Variant="Variant.Text" Color="Color.Error" Size="Size.Small"
                                           OnClick="() => RemoveToken(provider.ProviderId)">Remove</MudButton>
                            }
                        </div>
                    </MudCardContent>
                </MudCard>
            }
        }
    </MudTabPanel>

    <MudTabPanel Text="Performance / Backend" Icon="@Icons.Material.Filled.Speed">
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
            Configure hardware utilization and memory management for image generation.
        </MudText>

        <MudText Typo="Typo.subtitle2" Class="mb-2">VRAM Presets</MudText>
        <MudChipSet T="string" Class="mb-3">
            <MudChip T="string" Color="Color.Success" OnClick="ApplyHighVRAM">High VRAM (16GB+)</MudChip>
            <MudChip T="string" Color="Color.Primary" OnClick="ApplyDefaultVRAM">Default (8-16GB)</MudChip>
            <MudChip T="string" Color="Color.Warning" OnClick="ApplyLowVRAM">Low VRAM (&lt;8GB)</MudChip>
        </MudChipSet>

        <MudGrid>
            <MudItem xs="6">
                <MudNumericField T="int" Label="CPU Threads (0 = auto)" @bind-Value="_inferenceSettings_ThreadCount"
                                 Min="0" Max="128" Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="6">
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-3">
                    Auto = @Environment.ProcessorCount threads
                </MudText>
            </MudItem>
        </MudGrid>

        <MudText Typo="Typo.subtitle2" Class="mt-4 mb-2">Memory Optimization</MudText>
        <MudGrid>
            <MudItem xs="6">
                <MudSwitch T="bool" @bind-Value="_inferenceSettings_FlashAttention" Label="Flash Attention" Color="Color.Primary" />
            </MudItem>
            <MudItem xs="6">
                <MudSwitch T="bool" @bind-Value="_inferenceSettings_DiffusionFlashAttention" Label="Diffusion Flash Attention (fp16 K/V)" Color="Color.Primary" />
            </MudItem>
            <MudItem xs="6">
                <MudSwitch T="bool" @bind-Value="_inferenceSettings_VaeTiling" Label="VAE Tiling" Color="Color.Primary" />
            </MudItem>
            <MudItem xs="6">
                <MudSwitch T="bool" @bind-Value="_inferenceSettings_VaeDecodeOnly" Label="VAE Decode Only" Color="Color.Primary" />
            </MudItem>
            <MudItem xs="6">
                <MudSwitch T="bool" @bind-Value="_inferenceSettings_KeepClipOnCPU" Label="CLIP on CPU" Color="Color.Primary" />
            </MudItem>
            <MudItem xs="6">
                <MudSwitch T="bool" @bind-Value="_inferenceSettings_KeepVaeOnCPU" Label="VAE on CPU" Color="Color.Primary" />
            </MudItem>
            <MudItem xs="6">
                <MudSwitch T="bool" @bind-Value="_inferenceSettings_KeepControlNetOnCPU" Label="ControlNet on CPU" Color="Color.Primary" />
            </MudItem>
            <MudItem xs="6">
                <MudSwitch T="bool" @bind-Value="_inferenceSettings_OffloadParamsToCPU" Label="Offload Params to CPU" Color="Color.Primary" />
            </MudItem>
            <MudItem xs="6">
                <MudSwitch T="bool" @bind-Value="_inferenceSettings_EnableMmap" Label="Enable Memory Mapping" Color="Color.Primary" />
            </MudItem>
        </MudGrid>

        <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-3" OnClick="SaveInferenceSettings">
            Save Performance Settings
        </MudButton>
    </MudTabPanel>

    <MudTabPanel Text="Content Safety" Icon="@Icons.Material.Filled.Shield">
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
            Locally detect and filter NSFW content. All classification runs on your machine — no data leaves your system.
        </MudText>

        <MudText Typo="Typo.subtitle2" Class="mb-2">Filter Mode</MudText>
        <MudRadioGroup T="NsfwFilterMode" Value="_nsfwFilterMode" ValueChanged="OnFilterModeChanged">
            <MudRadio T="NsfwFilterMode" Value="NsfwFilterMode.Off" Color="Color.Default">
                <MudText Typo="Typo.body2">Off</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">No content filtering. All images shown as generated.</MudText>
            </MudRadio>
            <MudRadio T="NsfwFilterMode" Value="NsfwFilterMode.Blur" Color="Color.Warning" Class="mt-2">
                <MudText Typo="Typo.body2">Blur &amp; Reveal</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">NSFW images are blurred. You can reveal individual images by clicking them.</MudText>
            </MudRadio>
            <MudRadio T="NsfwFilterMode" Value="NsfwFilterMode.BlockAndDelete" Color="Color.Error" Class="mt-2">
                <MudText Typo="Typo.body2">Block &amp; Delete</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">NSFW images are automatically deleted immediately after generation. Cannot be recovered.</MudText>
            </MudRadio>
        </MudRadioGroup>

        <MudDivider Class="my-4" />

        <MudText Typo="Typo.subtitle2" Class="mb-2">Sensitivity</MudText>
        <MudSlider T="double" Value="_nsfwThreshold" ValueChanged="OnNsfwThresholdChanged"
                   Min="0.1" Max="0.9" Step="0.05" Color="Color.Warning">
            NSFW Threshold: <span class="param-value">@_nsfwThreshold.ToString("P0")</span>
        </MudSlider>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-3">
            Lower = more strict (blocks more). Higher = more lenient. Default: 50%
        </MudText>

        <MudSlider T="double" Value="_questionableThreshold" ValueChanged="OnQuestionableThresholdChanged"
                   Min="0.05" Max="0.5" Step="0.05" Color="Color.Info">
            Questionable Threshold: <span class="param-value">@_questionableThreshold.ToString("P0")</span>
        </MudSlider>
        <MudText Typo="Typo.caption" Color="Color.Secondary">
            Content above this score but below NSFW threshold is marked as questionable.
        </MudText>

        <MudDivider Class="my-4" />

        <MudText Typo="Typo.subtitle2" Class="mb-2">About</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary">
            Content safety is powered by NsfwSpy, an ML.NET model that runs entirely on your machine.
            No images or data are sent to any external service. Classification categories: Neutral, Sexy, Hentai, Pornography.
        </MudText>
    </MudTabPanel>

    <MudTabPanel Text="Output" Icon="@Icons.Material.Filled.SaveAlt">
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
            Configure how generated images are saved to disk.
        </MudText>

        <MudTextField T="string" Label="Custom Output Directory (leave empty for default)"
                      Value="_outputCustomDir" ValueChanged="v => _outputCustomDir = v"
                      Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-3"
                      Placeholder="e.g., D:\StableDiffusion\Output" />

        <MudText Typo="Typo.subtitle2" Class="mb-1">Filename Pattern</MudText>
        <MudTextField T="string" Label="Pattern" Value="_outputFilenamePattern" ValueChanged="v => _outputFilenamePattern = v"
                      Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-1" />
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-3">
            Available tokens: [seed], [prompt], [date], [model]. Example: [seed]-[date] produces 12345-20260321-143022.png
        </MudText>

        <MudSwitch T="bool" @bind-Value="_outputAutoSave" Label="Auto-save images after generation" Color="Color.Primary" Class="mb-2" />
        <MudSwitch T="bool" @bind-Value="_outputSaveGrid" Label="Save image grid for batch generations" Color="Color.Primary" Class="mb-3" />

        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveOutputSettings">
            Save Output Settings
        </MudButton>
    </MudTabPanel>

    <MudTabPanel Text="Appearance" Icon="@Icons.Material.Filled.Palette">
        <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-3">
            Appearance settings will be available in a future update.
        </MudText>
        <MudAlert Severity="Severity.Info" Dense="true">
            The application currently uses a dark theme by default.
        </MudAlert>
    </MudTabPanel>

    <MudTabPanel Text="Diagnostics" Icon="@Icons.Material.Filled.BugReport">
        <MudText Typo="Typo.subtitle2" Class="mb-2">System Information</MudText>
        <MudSimpleTable Dense="true" Hover="true" Elevation="0" Class="mb-4">
            <tbody>
                <tr><td><strong>Runtime</strong></td><td>@System.Runtime.InteropServices.RuntimeInformation.FrameworkDescription</td></tr>
                <tr><td><strong>OS</strong></td><td>@System.Runtime.InteropServices.RuntimeInformation.OSDescription</td></tr>
                <tr><td><strong>Storage Roots</strong></td><td>@(_roots?.Count ?? 0)</td></tr>
            </tbody>
        </MudSimpleTable>

        <MudText Typo="Typo.subtitle2" Class="mb-2">Database Health</MudText>
        @if (_dbHealthStatus is null)
        {
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                       OnClick="CheckDatabaseHealth" Disabled="_checkingDbHealth" Class="mb-3">
                @if (_checkingDbHealth)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    <span>Checking...</span>
                }
                else
                {
                    <span>Run Health Check</span>
                }
            </MudButton>
        }
        else
        {
            <MudAlert Severity="@(_dbHealthy ? Severity.Success : Severity.Error)" Dense="true" Class="mb-3">
                @_dbHealthStatus
            </MudAlert>
            @if (_dbTableCounts is not null)
            {
                <MudSimpleTable Dense="true" Hover="true" Striped="true" Elevation="0" Class="mb-3">
                    <thead>
                        <tr><th>Table</th><th>Row Count</th><th>Status</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var (table, count, error) in _dbTableCounts)
                        {
                            <tr>
                                <td>@table</td>
                                <td>@(error is not null ? "N/A" : count.ToString())</td>
                                <td>
                                    @if (error is not null)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Error">@error</MudChip>
                                    }
                                    else
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Success">OK</MudChip>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>
            }
            <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="CheckDatabaseHealth"
                       Disabled="_checkingDbHealth">
                Re-check
            </MudButton>
        }
    </MudTabPanel>

    <MudTabPanel Text="Data Management" Icon="@Icons.Material.Filled.DeleteSweep">
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
            Manage and clean up application data. Deletions are permanent and cannot be undone.
        </MudText>

        @if (_usageSummary is null)
        {
            <MudProgressLinear Indeterminate="true" />
        }
        else
        {
            <MudText Typo="Typo.subtitle2" Class="mb-2">Data Usage</MudText>
            <MudSimpleTable Dense="true" Striped="true" Class="mb-4">
                <tbody>
                    <tr><td>Projects</td><td>@_usageSummary.ProjectCount</td><td></td></tr>
                    <tr><td>Model Records</td><td>@_usageSummary.ModelRecordCount</td>
                        <td><MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Error"
                                       OnClick="@(() => ConfirmAndDelete("all model records", DataManagement.DeleteAllModelRecordsAsync))">
                                Clear
                            </MudButton></td></tr>
                    <tr><td>Generation Jobs</td><td>@_usageSummary.GenerationJobCount</td>
                        <td><MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Error"
                                       OnClick="@(() => ConfirmAndDelete("all generation jobs and images", DataManagement.DeleteGenerationJobsAsync))">
                                Clear
                            </MudButton></td></tr>
                    <tr><td>Generated Images</td><td>@_usageSummary.GeneratedImageCount</td>
                        <td><MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Error"
                                       OnClick="@(() => ConfirmAndDelete("all generated images", DataManagement.DeleteAllGeneratedImagesAsync))">
                                Clear
                            </MudButton></td></tr>
                    <tr><td>Background Jobs</td><td>@_usageSummary.JobRecordCount</td>
                        <td>
                            <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Warning"
                                       OnClick="@(() => ConfirmAndDelete("completed job records", DataManagement.DeleteCompletedJobRecordsAsync))">
                                Clear Completed
                            </MudButton>
                            <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Error"
                                       OnClick="@(() => ConfirmAndDelete("failed job records", DataManagement.DeleteFailedJobRecordsAsync))">
                                Clear Failed
                            </MudButton>
                            <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Error"
                                       OnClick="@(() => ConfirmAndDelete("all job records", DataManagement.DeleteAllJobRecordsAsync))">
                                Clear All
                            </MudButton>
                        </td></tr>
                    <tr><td>Disk Usage (Assets)</td>
                        <td>@FormatBytes(_usageSummary.AssetsDiskUsageBytes)</td>
                        <td><MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Warning"
                                       OnClick="CleanOrphanedAssets">
                                Clean Orphaned Files
                            </MudButton></td></tr>
                </tbody>
            </MudSimpleTable>

            <MudText Typo="Typo.subtitle2" Class="mb-2">Per-Project Cleanup</MudText>
            <MudSelect T="Guid?" Label="Select Project" @bind-Value="_selectedProjectForCleanup"
                       Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true" Class="mb-2">
                @if (_projectList is not null)
                {
                    @foreach (var p in _projectList)
                    {
                        <MudSelectItem T="Guid?" Value="@p.Id">@p.Name (@p.Id.ToString()[..8]...)</MudSelectItem>
                    }
                }
            </MudSelect>

            @if (_selectedProjectForCleanup.HasValue)
            {
                <div class="d-flex gap-2 mb-4">
                    <MudButton Variant="Variant.Outlined" Color="Color.Warning" Size="Size.Small"
                               OnClick="DeleteProjectImages">Delete Images</MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                               OnClick="DeleteProjectGenerations">Delete All Generations</MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Error" Size="Size.Small"
                               OnClick="DeleteSelectedProject">Delete Entire Project</MudButton>
                </div>
            }

            <MudDivider Class="my-4" />

            <MudText Typo="Typo.subtitle2" Class="mb-2" Color="Color.Error">Danger Zone</MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Error"
                       StartIcon="@Icons.Material.Filled.Warning"
                       OnClick="ResetAllData">
                Reset All Data
            </MudButton>
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
                Deletes all projects, generations, images, model records, and job history. Settings are preserved.
            </MudText>
        }
    </MudTabPanel>
</MudTabs>

@code {
    private IReadOnlyList<StorageRoot>? _roots;
    private IReadOnlyList<ModelProviderInfo>? _providerInfos;
    private readonly Dictionary<string, string> _tokenValues = new();
    private readonly HashSet<string> _configuredProviders = new();
    private bool _validating;
    private string? _loadError;

    // Data management fields
    private DataUsageSummary? _usageSummary;
    private IReadOnlyList<ProjectDto>? _projectList;
    private Guid? _selectedProjectForCleanup;

    // Content safety fields
    private NsfwFilterMode _nsfwFilterMode;
    private double _nsfwThreshold = 0.5;
    private double _questionableThreshold = 0.3;

    // Output settings fields
    private string _outputCustomDir = string.Empty;
    private string _outputFilenamePattern = "[seed]";
    private bool _outputAutoSave = true;
    private bool _outputSaveGrid;

    // Inference settings fields
    private int _inferenceSettings_ThreadCount;
    private bool _inferenceSettings_FlashAttention;
    private bool _inferenceSettings_DiffusionFlashAttention;
    private bool _inferenceSettings_VaeTiling;
    private bool _inferenceSettings_VaeDecodeOnly;
    private bool _inferenceSettings_KeepClipOnCPU;
    private bool _inferenceSettings_KeepVaeOnCPU;
    private bool _inferenceSettings_KeepControlNetOnCPU;
    private bool _inferenceSettings_OffloadParamsToCPU;
    private bool _inferenceSettings_EnableMmap;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await LoadRoots();
            await LoadProviders();
            await LoadContentSafety();
            await LoadInferenceSettings();
            await LoadOutputSettings();
            await LoadDataManagement();
        }
        catch (Exception ex)
        {
            _loadError = $"Failed to load settings: {ex.Message}";
            Logger.LogError(ex, "Failed to load settings");
        }
    }

    private async Task LoadRoots()
    {
        _roots = await StorageRootProvider.GetRootsAsync();
    }

    private async Task LoadProviders()
    {
        _providerInfos = CatalogService.GetProviders();
        foreach (var provider in _providerInfos.Where(p => p.Capabilities.CanSearch))
        {
            var existingToken = await CredentialStore.GetTokenAsync(provider.ProviderId);
            if (existingToken is not null)
            {
                _tokenValues[provider.ProviderId] = existingToken;
                _configuredProviders.Add(provider.ProviderId);
            }
            else
            {
                _tokenValues[provider.ProviderId] = string.Empty;
            }
        }
    }

    private string GetTokenValue(string providerId) =>
        _tokenValues.TryGetValue(providerId, out var val) ? val : string.Empty;

    private void SetTokenValue(string providerId, string value) =>
        _tokenValues[providerId] = value;

    private bool HasToken(string providerId) =>
        _configuredProviders.Contains(providerId);

    private async Task SaveToken(string providerId)
    {
        var token = GetTokenValue(providerId);
        if (string.IsNullOrWhiteSpace(token))
        {
            Snackbar.Add("Token cannot be empty", MudBlazor.Severity.Warning);
            return;
        }

        await CredentialStore.SetTokenAsync(providerId, token);
        _configuredProviders.Add(providerId);
        Snackbar.Add("Token saved", MudBlazor.Severity.Success);
    }

    private async Task ValidateToken(string providerId)
    {
        _validating = true;
        StateHasChanged();
        try
        {
            // Ensure token is saved before validating
            var token = GetTokenValue(providerId);
            if (!string.IsNullOrWhiteSpace(token))
            {
                await CredentialStore.SetTokenAsync(providerId, token);
                _configuredProviders.Add(providerId);
            }

            var providers = CatalogService.GetProviders();
            var provider = providers.FirstOrDefault(p => p.ProviderId == providerId);
            if (provider is null)
            {
                Snackbar.Add("Provider not found", MudBlazor.Severity.Error);
                return;
            }

            // Use search with empty query as a credential validation test
            var result = await CatalogService.SearchAsync(new ModelSearchQuery(providerId, "test", PageSize: 1));
            Snackbar.Add("Credentials are valid", MudBlazor.Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Validation failed: {ex.Message}", MudBlazor.Severity.Error);
        }
        finally
        {
            _validating = false;
        }
    }

    private async Task RemoveToken(string providerId)
    {
        await CredentialStore.RemoveTokenAsync(providerId);
        _tokenValues[providerId] = string.Empty;
        _configuredProviders.Remove(providerId);
        Snackbar.Add("Token removed", MudBlazor.Severity.Info);
    }

    private async Task AddRoot()
    {
        var dialog = await DialogService.ShowAsync<Dialogs.AddStorageRootDialog>("Add Model Directory");
        var result = await dialog.Result;
        if (result is not null && !result.Canceled)
        {
            await LoadRoots();
            Snackbar.Add("Directory added", MudBlazor.Severity.Success);
        }
    }

    private async Task RemoveRoot(StorageRoot root)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Remove Directory",
            $"Remove '{root.DisplayName}' from storage roots? This will not delete any files.",
            yesText: "Remove", cancelText: "Cancel");

        if (confirmed == true)
        {
            await StorageRootProvider.RemoveRootAsync(root.Path);
            await LoadRoots();
            Snackbar.Add("Directory removed", MudBlazor.Severity.Info);
        }
    }

    private async Task LoadContentSafety()
    {
        _nsfwFilterMode = await ContentSafety.GetFilterModeAsync();
        var thresholds = await ContentSafety.GetThresholdsAsync();
        _nsfwThreshold = thresholds.NsfwThreshold;
        _questionableThreshold = thresholds.QuestionableThreshold;
    }

