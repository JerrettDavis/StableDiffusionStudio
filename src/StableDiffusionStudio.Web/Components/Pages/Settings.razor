    // Export/import state
    private bool _exporting;

    private async Task ExportSettings()
    {
        _exporting = true;
        StateHasChanged();
        try
        {
            var json = await SettingsExportService.ExportAllAsync();
            var bytes = System.Text.Encoding.UTF8.GetBytes(json);
            var base64 = Convert.ToBase64String(bytes);
            await JS.InvokeVoidAsync("downloadFile", "sds-settings.json", "application/json", base64);
            Snackbar.Add("Settings exported", MudBlazor.Severity.Success);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to export settings");
            Snackbar.Add($"Export failed: {ex.Message}", MudBlazor.Severity.Error);
        }
        finally
        {
            _exporting = false;
        }
    }

    private async Task ImportSettings(IBrowserFile file)
    {
        try
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            using var reader = new StreamReader(stream);
            var json = await reader.ReadToEndAsync();
            await SettingsExportService.ImportAllAsync(json);

            // Reload all settings sections
            await LoadRoots();
            await LoadContentSafety();
            await LoadInferenceSettings();
            await LoadOutputSettings();

            Snackbar.Add("Settings imported successfully", MudBlazor.Severity.Success);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to import settings");
            Snackbar.Add($"Import failed: {ex.Message}", MudBlazor.Severity.Error);
        }
    }

