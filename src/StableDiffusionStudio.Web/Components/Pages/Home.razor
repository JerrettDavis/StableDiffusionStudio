@page "/"
@using StableDiffusionStudio.Application.DTOs
@using StableDiffusionStudio.Application.Interfaces
@using StableDiffusionStudio.Application.Services
@inject IProjectService ProjectService
@inject IModelCatalogService ModelCatalogService
@inject IInferenceBackend InferenceBackend
@inject NavigationManager Nav
@inject ILogger<Home> Logger

@if (_loadError is not null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4" ShowCloseIcon="true"
              CloseIconClicked="() => _loadError = null">
        @_loadError
    </MudAlert>
}

<div class="d-flex align-center justify-space-between mb-6">
    <div>
        <MudText Typo="Typo.h4">Welcome back</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            @_modelCount models · @_projectCount projects · @InferenceBackend.DisplayName
        </MudText>
    </div>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/generate"
               StartIcon="@Icons.Material.Filled.AutoAwesome" Size="Size.Large">
        Generate
    </MudButton>
</div>

<!-- Quick Actions -->
<MudText Typo="Typo.subtitle2" Color="Color.Secondary" Class="mb-2">Quick Actions</MudText>
<div class="d-flex gap-3 mb-6">
    <MudButton Variant="Variant.Outlined" Href="/projects" StartIcon="@Icons.Material.Filled.Add">
        New Project
    </MudButton>
    <MudButton Variant="Variant.Outlined" Href="/models" StartIcon="@Icons.Material.Filled.Search">
        Browse Models
    </MudButton>
    <MudButton Variant="Variant.Outlined" Href="/settings" StartIcon="@Icons.Material.Filled.Tune">
        Settings
    </MudButton>
</div>

<!-- Recent Projects — horizontal scroll -->
@if (_recentProjects is not null && _recentProjects.Count > 0)
{
    <MudText Typo="Typo.subtitle2" Color="Color.Secondary" Class="mb-2">Recent Projects</MudText>
    <div class="d-flex gap-3 mb-6" style="overflow-x:auto; padding-bottom:8px">
        @foreach (var project in _recentProjects)
        {
            <MudCard Elevation="0" Style="min-width:200px; border:1px solid var(--mud-palette-lines-default); cursor:pointer"
                     @onclick="() => NavigateToProject(project.Id)">
                <MudCardContent Class="pa-3">
                    <MudText Typo="Typo.subtitle1">@project.Name</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        Updated @project.UpdatedAt.ToString("MMM d")
                    </MudText>
                </MudCardContent>
            </MudCard>
        }
    </div>
}
else
{
    <MudText Typo="Typo.subtitle2" Color="Color.Secondary" Class="mb-2">Recent Projects</MudText>
    <EmptyState Title="No projects yet"
                Subtitle="Create your first project to get started"
                Icon="@Icons.Material.Filled.Folder" />
    <div class="mb-6"></div>
}

<!-- Backend Status -->
<MudText Typo="Typo.subtitle2" Color="Color.Secondary" Class="mb-2">System</MudText>
<MudPaper Elevation="0" Style="border:1px solid var(--mud-palette-lines-default)" Class="pa-4">
    <div class="d-flex align-center gap-3">
        <span class="status-dot @(_backendAvailable ? "online" : "offline")"></span>
        <div>
            <MudText Typo="Typo.body2">@InferenceBackend.DisplayName</MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary">
                @(InferenceBackend.Capabilities.SupportsLoRA ? "LoRA" : "")
                @(InferenceBackend.Capabilities.SupportsVAE ? "· VAE" : "")
                · Max @(InferenceBackend.Capabilities.MaxWidth)x@(InferenceBackend.Capabilities.MaxHeight)
            </MudText>
        </div>
    </div>
</MudPaper>

@code {
    private IReadOnlyList<ProjectDto>? _recentProjects;
    private int _projectCount;
    private int _modelCount;
    private bool _backendAvailable;
    private string? _loadError;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var projects = await ProjectService.ListAsync(new ProjectFilter());
            _projectCount = projects.Count;
            _recentProjects = projects.Take(5).ToList();

            var models = await ModelCatalogService.ListAsync(new ModelFilter());
            _modelCount = models.Count;

            _backendAvailable = await InferenceBackend.IsAvailableAsync();
        }
        catch (Exception ex)
        {
            _loadError = $"Failed to load dashboard: {ex.Message}";
            Logger.LogError(ex, "Failed to load dashboard");
        }
    }

    private void NavigateToProject(Guid id) => Nav.NavigateTo($"/projects/{id}");
}
