@using StableDiffusionStudio.Application.DTOs
@using StableDiffusionStudio.Application.Interfaces
@inject IDataManagementService DataManagement
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent><MudText Typo="Typo.h6">Generated Image</MudText></TitleContent>
    <DialogContent>
        <MudImage Src="@GetImageUrl()" Style="max-width:100%;max-height:500px" Class="mb-3" />
        <MudSimpleTable Dense="true" Striped="true">
            <tbody>
                <tr><td><strong>Seed</strong></td><td>@Image.Seed</td></tr>
                <tr><td><strong>Size</strong></td><td>@Image.Width x @Image.Height</td></tr>
                <tr><td><strong>Time</strong></td><td>@Image.GenerationTimeSeconds.ToString("F1")s</td></tr>
                <tr><td><strong>Sampler</strong></td><td>@Job.Parameters.Sampler</td></tr>
                <tr><td><strong>Scheduler</strong></td><td>@Job.Parameters.Scheduler</td></tr>
                <tr><td><strong>Steps</strong></td><td>@Job.Parameters.Steps</td></tr>
                <tr><td><strong>CFG</strong></td><td>@Job.Parameters.CfgScale</td></tr>
                <tr><td><strong>CLIP Skip</strong></td><td>@Job.Parameters.ClipSkip</td></tr>
                <tr><td><strong>Prompt</strong></td><td style="word-break:break-all">@Job.Parameters.PositivePrompt</td></tr>
                @if (!string.IsNullOrWhiteSpace(Job.Parameters.NegativePrompt))
                {
                    <tr><td><strong>Negative</strong></td><td style="word-break:break-all">@Job.Parameters.NegativePrompt</td></tr>
                }
            </tbody>
        </MudSimpleTable>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="DeleteImage" Color="Color.Error" Variant="Variant.Text"
                   StartIcon="@Icons.Material.Filled.Delete">Delete Image</MudButton>
        <MudButton OnClick="DeleteGeneration" Color="Color.Error" Variant="Variant.Text"
                   StartIcon="@Icons.Material.Filled.DeleteSweep">Delete Generation</MudButton>
        <MudSpacer />
        <MudButton OnClick="Close">Close</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="ReuseSettings">
            Reuse Settings
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public required GeneratedImageDto Image { get; set; }
    [Parameter] public required GenerationJobDto Job { get; set; }

    private string GetImageUrl()
    {
        var assetsBase = Path.Combine(
            Environment.GetFolderPath(Environment.SpecialFolder.LocalApplicationData),
            "StableDiffusionStudio", "Assets");

        if (Image.FilePath.StartsWith(assetsBase, StringComparison.OrdinalIgnoreCase))
        {
            var relativePath = Image.FilePath[assetsBase.Length..]
                .TrimStart(Path.DirectorySeparatorChar, Path.AltDirectorySeparatorChar)
                .Replace('\\', '/');
            return $"/assets/{relativePath}";
        }

        return $"/assets/{Image.Id}.png";
    }

    private void Close() => MudDialog.Close();
    private void ReuseSettings() => MudDialog.Close(DialogResult.Ok("reuse"));

    private async Task DeleteImage()
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Delete Image", "Delete this image? This cannot be undone.",
            yesText: "Delete", cancelText: "Cancel");
        if (confirmed == true)
        {
            await DataManagement.DeleteGeneratedImageAsync(Image.Id);
            Snackbar.Add("Image deleted", MudBlazor.Severity.Info);
            MudDialog.Close(DialogResult.Ok("deleted"));
        }
    }

    private async Task DeleteGeneration()
    {
        var imageCount = Job.Images.Count;
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Delete Generation",
            $"Delete this entire generation ({imageCount} image(s)) and all its parameters? This cannot be undone.",
            yesText: "Delete All", cancelText: "Cancel");
        if (confirmed == true)
        {
            await DataManagement.DeleteGenerationJobAsync(Job.Id);
            Snackbar.Add($"Generation deleted ({imageCount} image(s))", MudBlazor.Severity.Info);
            MudDialog.Close(DialogResult.Ok("deleted"));
        }
    }
}
