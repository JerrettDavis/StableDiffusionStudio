@using StableDiffusionStudio.Application.DTOs
@using StableDiffusionStudio.Application.Interfaces
@using StableDiffusionStudio.Application.Services
@using StableDiffusionStudio.Domain.Enums
@inject IDataManagementService DataManagement
@inject IAppPaths AppPaths
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime
@inject IGenerationService GenerationService

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center">
            <MudText Typo="Typo.h6">Generated Image</MudText>
            <MudIconButton Icon="@(_isFavorite ? Icons.Material.Filled.Favorite : Icons.Material.Outlined.FavoriteBorder)"
                           Color="@(_isFavorite ? Color.Error : Color.Default)"
                           OnClick="ToggleFavorite" Class="ml-2" />
        </div>
    </TitleContent>
    <DialogContent>
        <MudImage Src="@GetImageUrl()" Style="max-width:100%;max-height:500px" Class="mb-3" />
        <MudSimpleTable Dense="true" Striped="true">
            <tbody>
                <tr><td><strong>Seed</strong></td><td>@Image.Seed</td></tr>
                <tr><td><strong>Size</strong></td><td>@Image.Width x @Image.Height</td></tr>
                <tr><td><strong>Time</strong></td><td>@Image.GenerationTimeSeconds.ToString("F1")s</td></tr>
                <tr><td><strong>Sampler</strong></td><td>@Job.Parameters.Sampler</td></tr>
                <tr><td><strong>Scheduler</strong></td><td>@Job.Parameters.Scheduler</td></tr>
                <tr><td><strong>Steps</strong></td><td>@Job.Parameters.Steps</td></tr>
                <tr><td><strong>CFG</strong></td><td>@Job.Parameters.CfgScale</td></tr>
                <tr><td><strong>CLIP Skip</strong></td><td>@Job.Parameters.ClipSkip</td></tr>
                <tr><td><strong>Prompt</strong></td><td style="word-break:break-all">@Job.Parameters.PositivePrompt</td></tr>
                @if (!string.IsNullOrWhiteSpace(Job.Parameters.NegativePrompt))
                {
                    <tr><td><strong>Negative</strong></td><td style="word-break:break-all">@Job.Parameters.NegativePrompt</td></tr>
                }
                <tr>
                    <td><strong>Content Rating</strong></td>
                    <td>
                        @Image.ContentRating
                        @if (Image.ContentRating != ContentRating.Unknown && Image.ContentRating != ContentRating.Safe)
                        {
                            <MudChip T="string" Size="Size.Small" Class="ml-2"
                                     Color="@(Image.ContentRating == ContentRating.Nsfw ? Color.Error : Color.Warning)">
                                @((Image.NsfwScore * 100).ToString("F1"))% confidence
                            </MudChip>
                        }
                    </td>
                </tr>
                <tr><td><strong>File Path</strong></td><td style="word-break:break-all">@Image.FilePath</td></tr>
            </tbody>
        </MudSimpleTable>

        <div class="d-flex gap-2 mt-3">
            <MudButton Size="Size.Small" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.ContentCopy"
                       OnClick="CopySeed">Copy Seed</MudButton>
            <MudButton Size="Size.Small" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.ContentCopy"
                       OnClick="CopyPrompt">Copy Prompt</MudButton>
            <MudButton Size="Size.Small" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.FolderOpen"
                       OnClick="CopyFilePath">Copy File Path</MudButton>
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="DeleteImage" Color="Color.Error" Variant="Variant.Text"
                   StartIcon="@Icons.Material.Filled.Delete">Delete Image</MudButton>
        <MudButton OnClick="DeleteGeneration" Color="Color.Error" Variant="Variant.Text"
                   StartIcon="@Icons.Material.Filled.DeleteSweep">Delete Generation</MudButton>
        @if (Image.ContentRating is ContentRating.Nsfw or ContentRating.Questionable)
        {
            @if (Image.IsRevealed)
            {
                <MudButton OnClick="ConcealImage" Color="Color.Warning" Variant="Variant.Text"
                           StartIcon="@Icons.Material.Filled.VisibilityOff">Conceal</MudButton>
            }
            else
            {
                <MudButton OnClick="RevealImage" Color="Color.Warning" Variant="Variant.Text"
                           StartIcon="@Icons.Material.Filled.Visibility">Reveal</MudButton>
            }
        }
        <MudSpacer />
        <MudButton OnClick="Close">Close</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="ReuseSettings">
            Reuse Settings
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public required GeneratedImageDto Image { get; set; }
    [Parameter] public required GenerationJobDto Job { get; set; }

    private bool _isFavorite;

    protected override void OnInitialized()
    {
        _isFavorite = Image.IsFavorite;
    }

    private string GetImageUrl()
        => AppPaths.GetImageUrl(Image.FilePath);

    private void Close() => MudDialog.Close();
    private void ReuseSettings() => MudDialog.Close(DialogResult.Ok("reuse"));

    private async Task ToggleFavorite()
    {
        await GenerationService.ToggleFavoriteAsync(Image.Id);
        _isFavorite = !_isFavorite;
        StateHasChanged();
    }

    private async Task CopySeed()
    {
        await JSRuntime.InvokeVoidAsync("clipboardHelper.copy", Image.Seed.ToString());
        Snackbar.Add("Seed copied to clipboard", MudBlazor.Severity.Info);
    }

    private async Task CopyPrompt()
    {
        await JSRuntime.InvokeVoidAsync("clipboardHelper.copy", Job.Parameters.PositivePrompt);
        Snackbar.Add("Prompt copied to clipboard", MudBlazor.Severity.Info);
    }

    private async Task CopyFilePath()
    {
        await JSRuntime.InvokeVoidAsync("clipboardHelper.copy", Image.FilePath);
        Snackbar.Add("File path copied to clipboard", MudBlazor.Severity.Info);
    }

    private async Task RevealImage()
    {
        await GenerationService.RevealImageAsync(Image.Id);
        Image = Image with { IsRevealed = true };
        StateHasChanged();
    }

    private async Task ConcealImage()
    {
        await GenerationService.ConcealImageAsync(Image.Id);
        Image = Image with { IsRevealed = false };
        StateHasChanged();
    }

    private async Task DeleteImage()
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Delete Image", "Delete this image? This cannot be undone.",
            yesText: "Delete", cancelText: "Cancel");
        if (confirmed == true)
        {
            await DataManagement.DeleteGeneratedImageAsync(Image.Id);
            Snackbar.Add("Image deleted", MudBlazor.Severity.Info);
            MudDialog.Close(DialogResult.Ok("deleted"));
        }
    }

    private async Task DeleteGeneration()
    {
        var imageCount = Job.Images.Count;
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Delete Generation",
            $"Delete this entire generation ({imageCount} image(s)) and all its parameters? This cannot be undone.",
            yesText: "Delete All", cancelText: "Cancel");
        if (confirmed == true)
        {
            await DataManagement.DeleteGenerationJobAsync(Job.Id);
            Snackbar.Add($"Generation deleted ({imageCount} image(s))", MudBlazor.Severity.Info);
            MudDialog.Close(DialogResult.Ok("deleted"));
        }
    }
}
