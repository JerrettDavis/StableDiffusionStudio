@using StableDiffusionStudio.Application.DTOs
@using StableDiffusionStudio.Application.Interfaces
@using StableDiffusionStudio.Domain.Enums
@using System.Text.Json
@inject IJobQueue JobQueue
@inject IDataManagementService DataManagement
@inject IGenerationService GenerationService
@inject IExperimentService ExperimentService
@inject IAppPaths AppPaths
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Nav
@inject IJSRuntime JS

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudText Typo="Typo.h6">@Job.Type</MudText>
            <MudChip T="string" Size="Size.Small" Color="StatusColor">@Job.Status.ToString()</MudChip>
        </div>
    </TitleContent>
    <DialogContent>
        @if (Job.Status is JobStatus.Running or JobStatus.Pending)
        {
            <MudProgressLinear Value="Job.Progress" Max="100" Color="Color.Primary" Striped="true" Class="mb-2" />
            @if (Job.Phase is not null)
            {
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-3">@Job.Phase</MudText>
            }
        }

        <MudSimpleTable Dense="true" Striped="true" Class="mb-3">
            <tbody>
                <tr>
                    <td><strong>Job ID</strong></td>
                    <td style="font-family:'JetBrains Mono',monospace; font-size:0.8rem">@Job.Id</td>
                </tr>
                <tr>
                    <td><strong>Type</strong></td>
                    <td>@Job.Type</td>
                </tr>
                <tr>
                    <td><strong>Status</strong></td>
                    <td>@Job.Status</td>
                </tr>
                <tr>
                    <td><strong>Progress</strong></td>
                    <td><span class="param-value">@Job.Progress%</span></td>
                </tr>
                @if (Job.Phase is not null)
                {
                    <tr>
                        <td><strong>Phase</strong></td>
                        <td>@Job.Phase</td>
                    </tr>
                }
                <tr>
                    <td><strong>Created</strong></td>
                    <td>@Job.CreatedAt.ToString("g")</td>
                </tr>
                @if (Job.StartedAt.HasValue)
                {
                    <tr>
                        <td><strong>Started</strong></td>
                        <td>@Job.StartedAt.Value.ToString("g")</td>
                    </tr>
                }
                @if (Job.CompletedAt.HasValue)
                {
                    <tr>
                        <td><strong>Completed</strong></td>
                        <td>@Job.CompletedAt.Value.ToString("g")</td>
                    </tr>
                    <tr>
                        <td><strong>Duration</strong></td>
                        <td>@FormatDuration(Job.StartedAt, Job.CompletedAt)</td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>

        @if (Job.ErrorMessage is not null)
        {
            <MudText Typo="Typo.subtitle2" Color="Color.Error" Class="mb-1">Error</MudText>
            <MudPaper Class="pa-3 mb-3" Style="background:rgba(214,92,92,0.1); border:1px solid var(--mud-palette-error); border-radius:8px; max-height:200px; overflow-y:auto">
                <MudText Typo="Typo.caption" Style="font-family:'JetBrains Mono',monospace; white-space:pre-wrap; word-break:break-all">
                    @Job.ErrorMessage
                </MudText>
            </MudPaper>
        }

        @* Generation job images *@
        @if (_generationImages is not null && _generationImages.Count > 0)
        {
            <MudText Typo="Typo.subtitle2" Class="mb-2">Generated Images (@_generationImages.Count)</MudText>
            <div class="d-flex flex-wrap gap-2 mb-3">
                @foreach (var img in _generationImages)
                {
                    <div style="width:120px;">
                        <div style="aspect-ratio:1; overflow:hidden; border-radius:4px; background:var(--mud-palette-background-gray);">
                            <img src="@AppPaths.GetImageUrl(img.FilePath)" alt="Seed @img.Seed"
                                 style="width:100%; height:100%; object-fit:cover; display:block; cursor:pointer"
                                 @onclick="() => DownloadImage(img)" />
                        </div>
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Align="Align.Center" Class="mt-1">
                            Seed: @img.Seed
                        </MudText>
                    </div>
                }
            </div>
        }

        @* Experiment run images *@
        @if (_experimentImages is not null && _experimentImages.Count > 0)
        {
            <MudText Typo="Typo.subtitle2" Class="mb-2">Experiment Images (@_experimentImages.Count)</MudText>
            <div class="d-flex flex-wrap gap-2 mb-3">
                @foreach (var img in _experimentImages)
                {
                    <div style="width:120px;">
                        <div style="aspect-ratio:1; overflow:hidden; border-radius:4px; background:var(--mud-palette-background-gray); @(img.IsWinner ? "border:2px solid var(--mud-palette-warning);" : "")">
                            <img src="@AppPaths.GetImageUrl(img.FilePath)" alt="Grid @img.GridX,@img.GridY"
                                 style="width:100%; height:100%; object-fit:cover; display:block; cursor:pointer"
                                 @onclick="() => DownloadExperimentImage(img)" />
                        </div>
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Align="Align.Center" Class="mt-1">
                            @img.GridX,@img.GridY @(img.IsWinner ? "★" : "")
                        </MudText>
                    </div>
                }
            </div>
        }
    </DialogContent>
    <DialogActions>
        @if (Job.Status is JobStatus.Pending or JobStatus.Running)
        {
            <MudButton Color="Color.Warning" Variant="Variant.Text" OnClick="CancelJob"
                       StartIcon="@Icons.Material.Filled.Cancel">Cancel</MudButton>
        }
        <MudButton Color="Color.Error" Variant="Variant.Text" OnClick="DeleteJob"
                   StartIcon="@Icons.Material.Filled.Delete">Delete</MudButton>
        @if (Job.Type == "generation" && _generationJob is not null)
        {
            <MudButton Color="Color.Primary" Variant="Variant.Outlined" OnClick="StartNewSession"
                       StartIcon="@Icons.Material.Filled.Replay">New Session with Settings</MudButton>
            @if (_generationJob.Images.Count > 0)
            {
                <MudButton Color="Color.Secondary" Variant="Variant.Outlined" OnClick="SendToImg2Img"
                           StartIcon="@Icons.Material.Filled.Transform">Send to img2img</MudButton>
            }
        }
        @if (Job.Type == "experiment" && _experimentId is not null)
        {
            <MudButton Color="Color.Info" Variant="Variant.Outlined" OnClick="OpenInLab"
                       StartIcon="@Icons.Material.Filled.Science">View in Lab</MudButton>
        }
        <MudSpacer />
        <MudButton OnClick="Close">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public required JobRecordDto Job { get; set; }

    private IReadOnlyList<GeneratedImageDto>? _generationImages;
    private IReadOnlyList<ExperimentRunImageDto>? _experimentImages;
    private GenerationJobDto? _generationJob;
    private Guid? _experimentId;

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrEmpty(Job.Data)) return;

        try
        {
            if (Job.Type == "generation")
            {
                var data = JsonSerializer.Deserialize<JsonElement>(Job.Data);
                if (data.TryGetProperty("GenerationJobId", out var jobIdProp))
                {
                    var genJobId = jobIdProp.GetGuid();
                    var genJob = await GenerationService.GetJobAsync(genJobId);
                    if (genJob is not null)
                    {
                        _generationJob = genJob;
                        _generationImages = genJob.Images;
                    }
                }
            }
            else if (Job.Type == "experiment")
            {
                var data = JsonSerializer.Deserialize<JsonElement>(Job.Data);
                if (data.TryGetProperty("RunId", out var runIdProp))
                {
                    var runId = runIdProp.GetGuid();
                    var run = await ExperimentService.GetRunAsync(runId);
                    if (run is not null)
                    {
                        _experimentImages = run.Images;
                        _experimentId = run.ExperimentId;
                    }
                }
            }
        }
        catch { /* Non-critical — images just won't show */ }
    }

    private Color StatusColor => Job.Status switch
    {
        JobStatus.Pending => Color.Default,
        JobStatus.Running => Color.Primary,
        JobStatus.Completed => Color.Success,
        JobStatus.Failed => Color.Error,
        JobStatus.Cancelled => Color.Warning,
        _ => Color.Default
    };

    private string FormatDuration(DateTimeOffset? start, DateTimeOffset? end)
    {
        if (start is null || end is null) return "-";
        var d = end.Value - start.Value;
        return d.TotalMinutes >= 1 ? $"{(int)d.TotalMinutes}m {d.Seconds}s" : $"{d.TotalSeconds:F1}s";
    }

    private async Task DownloadImage(GeneratedImageDto img)
    {
        try
        {
            var bytes = await File.ReadAllBytesAsync(img.FilePath);
            var base64 = Convert.ToBase64String(bytes);
            var fileName = Path.GetFileName(img.FilePath);
            await JS.InvokeVoidAsync("downloadFile", fileName, "image/png", base64);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Download failed: {ex.Message}", Severity.Error);
        }
    }

    private async Task DownloadExperimentImage(ExperimentRunImageDto img)
    {
        try
        {
            var bytes = await File.ReadAllBytesAsync(img.FilePath);
            var base64 = Convert.ToBase64String(bytes);
            var fileName = Path.GetFileName(img.FilePath);
            await JS.InvokeVoidAsync("downloadFile", fileName, "image/png", base64);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Download failed: {ex.Message}", Severity.Error);
        }
    }

    private void OpenInLab()
    {
        MudDialog.Close();
        Nav.NavigateTo($"/lab?experimentId={_experimentId}");
    }

    private async Task CancelJob()
    {
        await JobQueue.CancelAsync(Job.Id);
        Snackbar.Add("Job cancelled", Severity.Warning);
        MudDialog.Close(DialogResult.Ok("refresh"));
    }

    private async Task DeleteJob()
    {
        var confirmed = await DialogService.ShowMessageBoxAsync("Delete Job",
            "Delete this job record?", yesText: "Delete", cancelText: "Cancel");
        if (confirmed == true)
        {
            await DataManagement.DeleteJobRecordAsync(Job.Id);
            Snackbar.Add("Job deleted", Severity.Info);
            MudDialog.Close(DialogResult.Ok("refresh"));
        }
    }

    private void StartNewSession()
    {
        if (_generationJob is null) return;
        var p = _generationJob.Parameters;
        var queryParams = new Dictionary<string, string?>
        {
            ["model"] = p.CheckpointModelId.ToString(),
            ["prompt"] = p.PositivePrompt,
            ["negative"] = p.NegativePrompt,
            ["steps"] = p.Steps.ToString(),
            ["cfg"] = p.CfgScale.ToString(System.Globalization.CultureInfo.InvariantCulture),
            ["width"] = p.Width.ToString(),
            ["height"] = p.Height.ToString(),
            ["seed"] = p.Seed.ToString(),
            ["sampler"] = p.Sampler.ToString(),
            ["clipSkip"] = p.ClipSkip.ToString(),
            ["denoise"] = p.DenoisingStrength.ToString(System.Globalization.CultureInfo.InvariantCulture)
        };
        var qs = string.Join("&", queryParams
            .Where(kv => kv.Value is not null)
            .Select(kv => $"{kv.Key}={Uri.EscapeDataString(kv.Value!)}"));
        MudDialog.Close();
        Nav.NavigateTo($"/generate?{qs}");
    }

    private void SendToImg2Img()
    {
        if (_generationJob is null || _generationJob.Images.Count == 0) return;
        var p = _generationJob.Parameters;
        var firstImage = _generationJob.Images[0];
        var queryParams = new Dictionary<string, string?>
        {
            ["model"] = p.CheckpointModelId.ToString(),
            ["prompt"] = p.PositivePrompt,
            ["negative"] = p.NegativePrompt,
            ["steps"] = p.Steps.ToString(),
            ["cfg"] = p.CfgScale.ToString(System.Globalization.CultureInfo.InvariantCulture),
            ["width"] = p.Width.ToString(),
            ["height"] = p.Height.ToString(),
            ["seed"] = firstImage.Seed.ToString(),
            ["sampler"] = p.Sampler.ToString(),
            ["mode"] = "img2img",
            ["denoise"] = "0.75",
            ["initImage"] = firstImage.FilePath
        };
        var qs = string.Join("&", queryParams
            .Where(kv => kv.Value is not null)
            .Select(kv => $"{kv.Key}={Uri.EscapeDataString(kv.Value!)}"));
        MudDialog.Close();
        Nav.NavigateTo($"/generate?{qs}");
    }

    private void Close() => MudDialog.Close();
}
