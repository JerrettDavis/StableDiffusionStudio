@using StableDiffusionStudio.Application.Interfaces
@using StableDiffusionStudio.Domain.Enums
@using StableDiffusionStudio.Domain.ValueObjects
@inject IStorageRootProvider StorageRootProvider

<MudDialog>
    <TitleContent><MudText Typo="Typo.h6">Add Model Directory</MudText></TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_path" Label="Directory Path" Required="true"
                      Placeholder="C:\Models\StableDiffusion" Class="mb-3" AutoFocus="true" />
        <MudTextField @bind-Value="_displayName" Label="Display Name" Required="true" Placeholder="My Models" />
        <MudSelect T="ModelType?" Label="Model Type (optional)" @bind-Value="_modelTypeTag"
                   Variant="Variant.Outlined" Clearable="true" Class="mt-3"
                   HelperText="Tag this folder for a specific model type">
            <MudSelectItem T="ModelType?" Value="@((ModelType?)null)">Auto-detect</MudSelectItem>
            @foreach (var t in Enum.GetValues<ModelType>().Where(t => t != ModelType.Unknown))
            {
                <MudSelectItem T="ModelType?" Value="@t">@t</MudSelectItem>
            }
        </MudSelect>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                   OnClick="Submit" Disabled="@(!IsValid)">Add</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    private string _path = string.Empty;
    private string _displayName = string.Empty;
    private ModelType? _modelTypeTag;
    private bool IsValid => !string.IsNullOrWhiteSpace(_path) && !string.IsNullOrWhiteSpace(_displayName);

    private async Task Submit()
    {
        await StorageRootProvider.AddRootAsync(new StorageRoot(_path, _displayName, _modelTypeTag));
        MudDialog.Close(DialogResult.Ok(true));
    }
    private void Cancel() => MudDialog.Cancel();
}
