@inherits LayoutComponentBase
@using StableDiffusionStudio.Application.Interfaces
@using StableDiffusionStudio.Web.Theme
@inject IInferenceBackend InferenceBackend
@inject IContentSafetyService ContentSafety

<MudThemeProvider Theme="_theme" IsDarkMode="_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<CascadingValue Value="_nsfwShieldEnabled" Name="NsfwShieldEnabled">
<CascadingValue Value="_nsfwThreshold" Name="NsfwThreshold">
<MudLayout>
    <MudAppBar Elevation="0" Dense="true" Style="border-bottom: 1px solid var(--mud-palette-lines-default)">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="ToggleDrawer" />
        <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Size="Size.Small" Color="Color.Primary" Class="mr-2" />
        <MudText Typo="Typo.subtitle1" Style="font-weight:600">Stable Diffusion Studio</MudText>
        <MudSpacer />

        <MudTooltip Text="@_backendStatus">
            <span class="status-dot @(_backendOnline ? "online" : "offline")" style="margin-right:8px"></span>
        </MudTooltip>

        <MudTooltip Text="@(_nsfwShieldEnabled ? "NSFW Shield: ON — blurring explicit content" : "NSFW Shield: OFF — showing all content")">
            <MudIconButton Icon="@(_nsfwShieldEnabled ? Icons.Material.Filled.Shield : Icons.Material.Outlined.Shield)"
                           Color="@(_nsfwShieldEnabled ? Color.Warning : Color.Inherit)"
                           OnClick="ToggleNsfwShield" />
        </MudTooltip>

        <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                       Color="Color.Inherit" OnClick="ToggleTheme" />
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Elevation="0" ClipMode="DrawerClipMode.Always"
               Style="border-right: 1px solid var(--mud-palette-lines-default)">
        <NavMenu />
    </MudDrawer>

    <MudMainContent Class="pa-4" Style="min-height: 100vh; padding-top: 64px !important;">
        <ErrorBoundaryHandler>
            @Body
        </ErrorBoundaryHandler>
    </MudMainContent>
</MudLayout>
</CascadingValue>
</CascadingValue>

@code {
    private MudTheme _theme = StudioTheme.Create();
    private bool _drawerOpen = true;
    private bool _isDarkMode = true;
    private bool _backendOnline;
    private string _backendStatus = "Checking backend...";
    private bool _nsfwShieldEnabled;
    private double _nsfwThreshold = 0.5;

    protected override async Task OnInitializedAsync()
    {
        _backendOnline = await InferenceBackend.IsAvailableAsync();
        _backendStatus = _backendOnline
            ? $"Backend: {InferenceBackend.DisplayName}"
            : "Backend: Mock (no GPU)";
        _nsfwShieldEnabled = await ContentSafety.GetNsfwShieldEnabledAsync();
        var thresholds = await ContentSafety.GetThresholdsAsync();
        _nsfwThreshold = thresholds.NsfwThreshold;
    }

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;
    private void ToggleTheme() => _isDarkMode = !_isDarkMode;

    private async Task ToggleNsfwShield()
    {
        _nsfwShieldEnabled = !_nsfwShieldEnabled;
        await ContentSafety.SetNsfwShieldEnabledAsync(_nsfwShieldEnabled);
    }
}
