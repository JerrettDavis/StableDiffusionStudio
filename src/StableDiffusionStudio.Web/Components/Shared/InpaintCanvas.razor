@using Microsoft.JSInterop

@inject IJSRuntime JS

<MudPaper Class="mt-2 pa-2" Elevation="0" Style="border:1px solid var(--mud-palette-lines-default); border-radius:4px">
    <MudText Typo="Typo.subtitle2" Class="mb-2">Paint Mask (White = Regenerate)</MudText>

    <canvas id="@_canvasId" style="max-width:100%; cursor:crosshair; display:block; margin:auto; border:1px solid var(--mud-palette-lines-default)"></canvas>

    <div class="d-flex align-center gap-3 mt-2">
        <MudSlider T="int" Value="_brushSize" ValueChanged="OnBrushSizeChanged"
                   Min="5" Max="100" Step="5" Style="flex:1">
            Brush: @_brushSize px
        </MudSlider>
        <MudButton Variant="Variant.Outlined" Color="Color.Warning" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Clear" OnClick="ClearMask">
            Clear Mask
        </MudButton>
    </div>
</MudPaper>

@code {
    [Parameter, EditorRequired] public byte[]? InitImageBytes { get; set; }
    [Parameter] public EventCallback<byte[]?> MaskBytesChanged { get; set; }

    private readonly string _canvasId = $"inpaint-canvas-{Guid.NewGuid():N}";
    private int _brushSize = 20;
    private string? _lastImageUrl;
    private bool _initialized;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (InitImageBytes is not null)
        {
            var imageUrl = $"data:image/png;base64,{Convert.ToBase64String(InitImageBytes)}";
            if (imageUrl != _lastImageUrl)
            {
                _lastImageUrl = imageUrl;
                _initialized = false;
            }

            if (!_initialized)
            {
                _initialized = true;
                // Small delay to ensure canvas element is rendered
                await Task.Delay(100);
                await JS.InvokeVoidAsync("inpaintCanvas.init", _canvasId, imageUrl);
            }
        }
    }

    private async Task OnBrushSizeChanged(int size)
    {
        _brushSize = size;
        await JS.InvokeVoidAsync("inpaintCanvas.setBrushSize", _canvasId, size);
    }

    private async Task ClearMask()
    {
        if (InitImageBytes is null) return;
        var imageUrl = $"data:image/png;base64,{Convert.ToBase64String(InitImageBytes)}";
        await JS.InvokeVoidAsync("inpaintCanvas.clearMask", _canvasId, imageUrl);
        await MaskBytesChanged.InvokeAsync(null);
    }

    /// <summary>
    /// Reads the current mask from the canvas and returns it as PNG bytes.
    /// Called externally before generation to capture the mask state.
    /// </summary>
    public async Task<byte[]?> GetMaskBytesAsync()
    {
        var dataUrl = await JS.InvokeAsync<string?>("inpaintCanvas.getMaskData", _canvasId);
        if (dataUrl is null) return null;

        // Data URL format: data:image/png;base64,<base64data>
        const string prefix = "data:image/png;base64,";
        if (!dataUrl.StartsWith(prefix)) return null;

        var base64 = dataUrl[prefix.Length..];
        return Convert.FromBase64String(base64);
    }
}
