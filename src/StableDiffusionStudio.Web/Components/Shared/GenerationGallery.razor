@using StableDiffusionStudio.Application.DTOs
@using StableDiffusionStudio.Application.Interfaces
@using StableDiffusionStudio.Application.Services
@using StableDiffusionStudio.Domain.Enums
@using Microsoft.AspNetCore.SignalR.Client
@inject IGenerationService GenerationService
@inject IDataManagementService DataManagement
@inject IAppPaths AppPaths
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Nav
@implements IAsyncDisposable

@if (_jobs is not null && (_jobs.Any(j => j.Images.Count > 0) || _previewImageSrc is not null || _previewStep > 0))
{
    <div class="d-flex align-center mb-2">
        <MudToggleIconButton @bind-Toggled="_showFavoritesOnly"
                             Icon="@Icons.Material.Outlined.FavoriteBorder"
                             ToggledIcon="@Icons.Material.Filled.Favorite"
                             Color="Color.Default" ToggledColor="Color.Error"
                             Size="Size.Small" />
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-1">
            @(_showFavoritesOnly ? "Favorites only" : "All images")
        </MudText>
    </div>
}

@if (_jobs is null)
{
    <MudProgressLinear Indeterminate="true" />
}
else if (_jobs.All(j => j.Images.Count == 0) && _previewImageSrc is null && _previewStep <= 0)
{
    <EmptyState Title="No images yet" Subtitle="Generate your first image to see it here"
                Icon="@Icons.Material.Filled.Image" />
}
else
{
    <MudGrid>
        @* Live preview card — appears as the first item while generating *@
        @if (_previewStep > 0 || _previewImageSrc is not null)
        {
            <MudItem xs="6" sm="4" md="3">
                <div class="gallery-card position-relative">
                    <MudCard Elevation="0" Style="overflow:hidden; border: 2px solid var(--mud-palette-primary); border-radius: var(--studio-radius-lg)">
                        <div style="position:relative; overflow:hidden; aspect-ratio: 1; background: var(--mud-palette-surface);">
                            @if (_previewImageSrc is not null && _previewImageSrc.Length > 0)
                            {
                                <img src="@_previewImageSrc" style="width:100%; height:100%; object-fit:cover; display:block;" alt="Preview" />
                            }
                            else
                            {
                                <!-- Skeleton placeholder with step progress -->
                                <div style="display:flex; flex-direction:column; align-items:center; justify-content:center; height:100%; gap:8px">
                                    <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="false"
                                                          Value="@((_previewStep * 100.0) / Math.Max(_previewTotalSteps, 1))" />
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        Step @_previewStep / @_previewTotalSteps
                                    </MudText>
                                </div>
                            }
                            <div style="position:absolute; top:4px; left:4px">
                                <MudChip T="string" Size="Size.Small" Color="Color.Primary" Class="generating-pulse">
                                    Generating
                                </MudChip>
                            </div>
                            @if (_previewTotalSteps > 0)
                            {
                                <div style="position:absolute; bottom:0; left:0; right:0; padding:4px 8px; background:linear-gradient(transparent, rgba(0,0,0,0.6))">
                                    <MudProgressLinear Value="_previewStep" Max="_previewTotalSteps" Color="Color.Primary"
                                                       Size="Size.Small" Style="border-radius:2px" />
                                </div>
                            }
                        </div>
                    </MudCard>
                </div>
            </MudItem>
        }
        @foreach (var job in _jobs.Where(j => j.Images.Count > 0))
        {
            @foreach (var image in GetFilteredImages(job))
            {
                var shouldBlur = ShouldBlurImage(image);
                <MudItem xs="6" sm="4" md="3">
                    <div class="gallery-card position-relative" style="cursor:pointer" @onclick="() => ShowDetail(image, job)">
                        <MudCard Elevation="0" Style="overflow:hidden; border: 1px solid var(--mud-palette-lines-default); border-radius: var(--studio-radius-lg)">
                            <div style="position:relative; overflow:hidden; aspect-ratio: 1;">
                                @{
                                    var blurAmount = image.ContentRating == ContentRating.Nsfw ? 20 : 10;
                                }
                                <MudImage Src="@GetImageUrl(image)"
                                          Style="@($"width:100%; height:100%; object-fit:cover;{(shouldBlur ? $" filter: blur({blurAmount}px); transform: scale(1.1);" : "")}")" />

                                @if (shouldBlur)
                                {
                                    <div style="position:absolute; inset:0; display:flex; flex-direction:column; align-items:center; justify-content:center; background:rgba(0,0,0,0.3); gap:4px">
                                        <MudIcon Icon="@Icons.Material.Filled.Shield" Color="Color.Warning" />
                                        <MudText Typo="Typo.caption" Style="color:#fff">
                                            @(image.ContentRating) @((image.NsfwScore * 100).ToString("F0"))%
                                        </MudText>
                                        <div @onclick:stopPropagation="true">
                                            <MudButton Variant="Variant.Filled" Size="Size.Small" Color="Color.Warning"
                                                       OnClick="() => RevealImage(image)">
                                                Reveal
                                            </MudButton>
                                        </div>
                                    </div>
                                }

                                @if (!shouldBlur && image.ContentRating is ContentRating.Nsfw or ContentRating.Questionable)
                                {
                                    <MudChip T="string" Size="Size.Small" Style="position:absolute; top:4px; right:4px; opacity:0.8"
                                             Color="@(image.ContentRating == ContentRating.Nsfw ? Color.Error : Color.Warning)">
                                        @((image.NsfwScore * 100).ToString("F0"))%
                                    </MudChip>
                                }
                                <div class="image-overlay">
                                    <div style="width:100%">
                                        <MudText Typo="Typo.caption" Style="color:#fff">Seed: @image.Seed</MudText>
                                        <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.7)">@image.GenerationTimeSeconds.ToString("F1")s</MudText>
                                    </div>
                                </div>
                            </div>
                        </MudCard>
                        <div class="d-flex justify-space-between align-center mt-1 px-1">
                            <MudIconButton Icon="@(image.IsFavorite ? Icons.Material.Filled.Favorite : Icons.Material.Outlined.FavoriteBorder)"
                                           Size="Size.Small" Color="@(image.IsFavorite ? Color.Error : Color.Default)"
                                           OnClick="() => ToggleFavorite(image)" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Default"
                                           OnClick="() => DeleteImage(image)" />
                        </div>
                    </div>
                </MudItem>
            }
        }
    </MudGrid>

    @if (_jobs.Any(j => j.Images.Count > 0))
    {
        <div class="d-flex justify-end mt-3">
            <MudButton Variant="Variant.Text" Color="Color.Error" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.DeleteSweep"
                       OnClick="DeleteAllForProject">
                Delete All Images
            </MudButton>
        </div>
    }
}

@code {
    [Parameter] public Guid ProjectId { get; set; }
    [Parameter] public EventCallback<GenerationJobDto> OnReuseSettings { get; set; }
    [CascadingParameter(Name = "NsfwShieldEnabled")] public bool NsfwShieldEnabled { get; set; }
    [CascadingParameter(Name = "NsfwThreshold")] public double NsfwThreshold { get; set; } = 0.5;

    private IReadOnlyList<GenerationJobDto>? _jobs;
    private bool _showFavoritesOnly;
    private HubConnection? _hubConnection;
    private string? _previewImageSrc;
    private int _previewStep;
    private int _previewTotalSteps;

    protected override async Task OnInitializedAsync()
    {
        await Refresh();

        // Connect to SignalR for live previews
        try
        {
            _hubConnection = new HubConnectionBuilder()
                .WithUrl(Nav.ToAbsoluteUri("/hubs/studio"))
                .WithAutomaticReconnect()
                .Build();

            _hubConnection.On<string, int, int, string>("GenerationPreview",
                (projectId, step, totalSteps, imageDataUrl) =>
                {
                    if (projectId == ProjectId.ToString())
                    {
                        _previewStep = step;
                        _previewTotalSteps = totalSteps;
                        _previewImageSrc = string.IsNullOrEmpty(imageDataUrl) ? null : imageDataUrl;
                        InvokeAsync(StateHasChanged);
                    }
                });

            _hubConnection.On<string>("GenerationComplete",
                (projectId) =>
                {
                    if (projectId == ProjectId.ToString())
                    {
                        _previewImageSrc = null;
                        _previewStep = 0;
                        _previewTotalSteps = 0;
                        InvokeAsync(async () =>
                        {
                            await Refresh();
                            StateHasChanged();
                        });
                    }
                });

            _hubConnection.On<string, string>("GenerationFailed",
                (projectId, _) =>
                {
                    if (projectId == ProjectId.ToString())
                    {
                        _previewImageSrc = null;
                        _previewStep = 0;
                        _previewTotalSteps = 0;
                        InvokeAsync(StateHasChanged);
                    }
                });

            await _hubConnection.StartAsync();
        }
        catch (Exception)
        {
            // SignalR connection failed — previews won't work but gallery still functions
        }
    }

    public async Task Refresh()
    {
        _jobs = await GenerationService.ListJobsForProjectAsync(ProjectId);
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection is not null)
            await _hubConnection.DisposeAsync();
    }

    private string GetImageUrl(GeneratedImageDto image)
        => AppPaths.GetImageUrl(image.FilePath);

    private async Task ShowDetail(GeneratedImageDto image, GenerationJobDto job)
    {
        var parameters = new DialogParameters<Dialogs.ImageDetailDialog>
        {
            { x => x.Image, image },
            { x => x.Job, job }
        };
        var dialog = await DialogService.ShowAsync<Dialogs.ImageDetailDialog>("Image Details", parameters,
            new DialogOptions { MaxWidth = MaxWidth.Large, FullWidth = true });
        var result = await dialog.Result;
        if (result is not null && !result.Canceled)
        {
            var action = result.Data as string;
            if (action == "reuse")
                await OnReuseSettings.InvokeAsync(job);
            else if (action == "deleted")
                await Refresh();
        }
    }

    private IEnumerable<GeneratedImageDto> GetFilteredImages(GenerationJobDto job)
    {
        return _showFavoritesOnly ? job.Images.Where(i => i.IsFavorite) : job.Images;
    }

    private bool ShouldBlurImage(GeneratedImageDto image)
    {
        // Compare the actual NSFW score against the user's configured threshold
        // This respects threshold changes even for previously classified images
        return NsfwShieldEnabled && !image.IsRevealed && image.NsfwScore >= NsfwThreshold;
    }

    private async Task RevealImage(GeneratedImageDto image)
    {
        await GenerationService.RevealImageAsync(image.Id);
        await Refresh();
    }

    private async Task ToggleFavorite(GeneratedImageDto image)
    {
        await GenerationService.ToggleFavoriteAsync(image.Id);
        await Refresh();
    }

    private async Task DeleteImage(GeneratedImageDto image)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Delete Image", "Delete this generated image? This cannot be undone.",
            yesText: "Delete", cancelText: "Cancel");
        if (confirmed == true)
        {
            await DataManagement.DeleteGeneratedImageAsync(image.Id);
            Snackbar.Add("Image deleted", MudBlazor.Severity.Info);
            await Refresh();
        }
    }

    private async Task DeleteAllForProject()
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Delete All Images", "Delete ALL generated images for this project? This cannot be undone.",
            yesText: "Delete All", cancelText: "Cancel");
        if (confirmed == true)
        {
            var count = await DataManagement.DeleteGeneratedImagesForProjectAsync(ProjectId);
            Snackbar.Add($"Deleted {count} image(s)", MudBlazor.Severity.Info);
            await Refresh();
        }
    }
}
