@using StableDiffusionStudio.Application.DTOs
@using StableDiffusionStudio.Application.Interfaces
@using StableDiffusionStudio.Application.Services
@inject IGenerationService GenerationService
@inject IDataManagementService DataManagement
@inject IAppPaths AppPaths
@inject IDialogService DialogService
@inject ISnackbar Snackbar

@if (_jobs is not null && _jobs.Any(j => j.Images.Count > 0))
{
    <div class="d-flex align-center mb-2">
        <MudToggleIconButton @bind-Toggled="_showFavoritesOnly"
                             Icon="@Icons.Material.Outlined.FavoriteBorder"
                             ToggledIcon="@Icons.Material.Filled.Favorite"
                             Color="Color.Default" ToggledColor="Color.Error"
                             Size="Size.Small" />
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-1">
            @(_showFavoritesOnly ? "Favorites only" : "All images")
        </MudText>
    </div>
}

@if (_jobs is null)
{
    <MudProgressLinear Indeterminate="true" />
}
else if (_jobs.All(j => j.Images.Count == 0))
{
    <EmptyState Title="No images yet" Subtitle="Generate your first image to see it here"
                Icon="@Icons.Material.Filled.Image" />
}
else
{
    <MudGrid>
        @foreach (var job in _jobs.Where(j => j.Images.Count > 0))
        {
            @foreach (var image in GetFilteredImages(job))
            {
                <MudItem xs="6" sm="4" md="3">
                    <MudCard Elevation="1" Class="position-relative">
                        <div class="cursor-pointer" @onclick="() => ShowDetail(image, job)">
                            <MudCardMedia Image="@GetImageUrl(image)" Height="200" />
                        </div>
                        <MudCardContent Class="pa-2">
                            <div class="d-flex align-center justify-space-between">
                                <div>
                                    <MudText Typo="Typo.caption">Seed: @image.Seed</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@image.GenerationTimeSeconds.ToString("F1")s</MudText>
                                </div>
                                <div class="d-flex">
                                    <MudIconButton Icon="@(image.IsFavorite ? Icons.Material.Filled.Favorite : Icons.Material.Outlined.FavoriteBorder)"
                                                   Size="Size.Small"
                                                   Color="@(image.IsFavorite ? Color.Error : Color.Default)"
                                                   OnClick="() => ToggleFavorite(image)" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                   Color="Color.Error" OnClick="() => DeleteImage(image)" />
                                </div>
                            </div>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }
        }
    </MudGrid>

    @if (_jobs.Any(j => j.Images.Count > 0))
    {
        <div class="d-flex justify-end mt-3">
            <MudButton Variant="Variant.Text" Color="Color.Error" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.DeleteSweep"
                       OnClick="DeleteAllForProject">
                Delete All Images
            </MudButton>
        </div>
    }
}

@code {
    [Parameter] public Guid ProjectId { get; set; }
    [Parameter] public EventCallback<GenerationJobDto> OnReuseSettings { get; set; }

    private IReadOnlyList<GenerationJobDto>? _jobs;
    private bool _showFavoritesOnly;

    protected override async Task OnInitializedAsync() => await Refresh();

    public async Task Refresh()
    {
        _jobs = await GenerationService.ListJobsForProjectAsync(ProjectId);
        StateHasChanged();
    }

    private string GetImageUrl(GeneratedImageDto image)
        => AppPaths.GetImageUrl(image.FilePath);

    private async Task ShowDetail(GeneratedImageDto image, GenerationJobDto job)
    {
        var parameters = new DialogParameters<Dialogs.ImageDetailDialog>
        {
            { x => x.Image, image },
            { x => x.Job, job }
        };
        var dialog = await DialogService.ShowAsync<Dialogs.ImageDetailDialog>("Image Details", parameters,
            new DialogOptions { MaxWidth = MaxWidth.Large, FullWidth = true });
        var result = await dialog.Result;
        if (result is not null && !result.Canceled)
        {
            var action = result.Data as string;
            if (action == "reuse")
                await OnReuseSettings.InvokeAsync(job);
            else if (action == "deleted")
                await Refresh();
        }
    }

    private IEnumerable<GeneratedImageDto> GetFilteredImages(GenerationJobDto job)
    {
        return _showFavoritesOnly ? job.Images.Where(i => i.IsFavorite) : job.Images;
    }

    private async Task ToggleFavorite(GeneratedImageDto image)
    {
        await GenerationService.ToggleFavoriteAsync(image.Id);
        await Refresh();
    }

    private async Task DeleteImage(GeneratedImageDto image)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Delete Image", "Delete this generated image? This cannot be undone.",
            yesText: "Delete", cancelText: "Cancel");
        if (confirmed == true)
        {
            await DataManagement.DeleteGeneratedImageAsync(image.Id);
            Snackbar.Add("Image deleted", MudBlazor.Severity.Info);
            await Refresh();
        }
    }

    private async Task DeleteAllForProject()
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Delete All Images", "Delete ALL generated images for this project? This cannot be undone.",
            yesText: "Delete All", cancelText: "Cancel");
        if (confirmed == true)
        {
            var count = await DataManagement.DeleteGeneratedImagesForProjectAsync(ProjectId);
            Snackbar.Add($"Deleted {count} image(s)", MudBlazor.Severity.Info);
            await Refresh();
        }
    }
}
