    private void OnInitImageDimensions((int Width, int Height) dims)
    {
        _initImageWidth = dims.Width;
        _initImageHeight = dims.Height;

        if (dims.Width <= 0 || dims.Height <= 0)
        {
            _suggestedResolution = null;
            return;
        }

        var sourceRatio = (double)dims.Width / dims.Height;

        // Find the standard resolution pair closest to the source aspect ratio
        var best = StandardResolutions
            .OrderBy(r => Math.Abs((double)r.W / r.H - sourceRatio))
            .First();

        // Only suggest if it differs from current settings
        if (best.W != _width || best.H != _height)
            _suggestedResolution = best;
        else
            _suggestedResolution = null;

        StateHasChanged();
    }

    private void ApplySuggestedResolution()
    {
        if (_suggestedResolution is null) return;
        _width = _suggestedResolution.Value.W;
        _height = _suggestedResolution.Value.H;
        _suggestedResolution = null;
        Snackbar.Add($"Resolution set to {_width}x{_height} to match image aspect ratio", Severity.Info);
        StateHasChanged();
    }

