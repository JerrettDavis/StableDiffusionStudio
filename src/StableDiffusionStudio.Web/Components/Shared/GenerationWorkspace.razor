@using StableDiffusionStudio.Application.Commands
@using StableDiffusionStudio.Application.DTOs
@using StableDiffusionStudio.Application.Interfaces
@using StableDiffusionStudio.Application.Services
@using StableDiffusionStudio.Domain.Enums
@using StableDiffusionStudio.Domain.ValueObjects
@using StableDiffusionStudio.Domain.Services
@using Microsoft.AspNetCore.SignalR.Client
@using Microsoft.JSInterop

@inject NavigationManager Nav
@inject IGenerationService GenerationService
@inject IModelCatalogService ModelCatalogService
@inject IInferenceBackend InferenceBackend
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IPromptHistoryService PromptHistoryService
@inject IImageInterrogator ImageInterrogator
@inject IJSRuntime JS
@implements IAsyncDisposable

<MudGrid>
    <!-- Left panel: Generation controls -->
    <MudItem xs="12" md="4">
        <MudPaper Class="pa-4" Elevation="1">
            <MudText Typo="Typo.h6" Class="mb-3">Generation Workspace</MudText>

            <MudToggleGroup T="Domain.Enums.GenerationMode" @bind-Value="_generationMode" Class="mb-3"
                            Color="Color.Primary" Outlined="true" Dense="true">
                <MudToggleItem T="Domain.Enums.GenerationMode" Value="Domain.Enums.GenerationMode.TextToImage">txt2img</MudToggleItem>
                <MudToggleItem T="Domain.Enums.GenerationMode" Value="Domain.Enums.GenerationMode.ImageToImage">img2img</MudToggleItem>
                <MudToggleItem T="Domain.Enums.GenerationMode" Value="Domain.Enums.GenerationMode.Inpainting">Inpaint</MudToggleItem>
            </MudToggleGroup>

            @if (_generationMode == Domain.Enums.GenerationMode.ImageToImage)
            {
                <ImageUpload @bind-ImageBytes="_initImageBytes" />
                @if (_initImageBytes is not null)
                {
                    <MudButton Variant="Variant.Outlined" Color="Color.Secondary" FullWidth="true"
                               Size="Size.Small" Class="mb-2"
                               StartIcon="@Icons.Material.Filled.ImageSearch"
                               Disabled="_isInterrogating"
                               OnClick="() => InterrogateImage(_initImageBytes)">
                        @if (_isInterrogating)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            @:Interrogating...
                        }
                        else
                        {
                            @:Interrogate — generate prompt from image
                        }
                    </MudButton>
                }
            }

            @if (_generationMode == Domain.Enums.GenerationMode.Inpainting)
            {
                <ImageUpload @bind-ImageBytes="_initImageBytes" />
                @if (_initImageBytes is not null)
                {
                    <MudButton Variant="Variant.Outlined" Color="Color.Secondary" FullWidth="true"
                               Size="Size.Small" Class="mb-2"
                               StartIcon="@Icons.Material.Filled.ImageSearch"
                               Disabled="_isInterrogating"
                               OnClick="() => InterrogateImage(_initImageBytes)">
                        @if (_isInterrogating)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            @:Interrogating...
                        }
                        else
                        {
                            @:Interrogate — generate prompt from image
                        }
                    </MudButton>
                    <InpaintCanvas @ref="_inpaintCanvas" InitImageBytes="_initImageBytes" />
                }
            }

            @if (_generationMode == Domain.Enums.GenerationMode.TextToImage)
            {
                <InterrogateDropZone OnPromptGenerated="OnInterrogateResult" />
            }

            <RecentModelsBar @ref="_recentModelsBar" SelectedModelId="_checkpointId"
                             OnModelSelected="OnCheckpointChanged" />

            <ModelSelector Label="Checkpoint" ModelTypeFilter="ModelType.Checkpoint"
                           SelectedModelId="_checkpointId" SelectedModelIdChanged="OnCheckpointChanged"
                           Required="true" />

            @if (_activePreset is not null)
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Info" Class="mt-1">
                    @_activePreset.Name
                </MudChip>
            }

            <div class="mt-2">
                <PresetSelector ModelId="_checkpointId" ModelFamily="_currentModelFamily"
                                OnPresetApplied="ApplyUserPreset" OnSaveRequested="SavePreset" />
            </div>

            <div class="mt-3">
                <ModelSelector Label="VAE (optional)" ModelTypeFilter="ModelType.VAE"
                               SelectedModelId="_vaeId" SelectedModelIdChanged="v => _vaeId = v" />
            </div>

            <div class="mt-3">
                <LoraSelector SelectedLoras="_loras" SelectedLorasChanged="v => _loras = v" />
            </div>

            <MudTextField T="string" Label="Prompt" Lines="4" Value="_positivePrompt"
                          ValueChanged="OnPositivePromptChanged"
                          Variant="Variant.Outlined" Class="mt-3"
                          Placeholder="Describe what you want to generate..." />
            <MudText Typo="Typo.caption" Class="mt-1"
                     Color="@(_positiveTokenCount > _tokenLimit ? Color.Error : Color.Secondary)">
                <span class="param-value">@_positiveTokenCount</span>/@_tokenLimit tokens
            </MudText>

            <MudTextField T="string" Label="Negative Prompt" Lines="2" Value="_negativePrompt"
                          ValueChanged="OnNegativePromptChanged"
                          Variant="Variant.Outlined" Class="mt-3"
                          Placeholder="What to avoid..." />
            <MudText Typo="Typo.caption" Class="mt-1"
                     Color="@(_negativeTokenCount > _tokenLimit ? Color.Error : Color.Secondary)">
                <span class="param-value">@_negativeTokenCount</span>/@_tokenLimit tokens
            </MudText>

            <NegativePromptHelper NegativePrompt="_negativePrompt"
                                  NegativePromptChanged="v => { _negativePrompt = v; StateHasChanged(); }" />

            <PromptHistoryPanel @ref="_promptHistoryPanel" OnPromptSelected="OnPromptHistorySelected" />

            <PngInfoDropZone OnParametersParsed="OnPngInfoParsed" />

            <div class="mt-3">
                <ParameterPanel Params_Sampler="_sampler" Params_SamplerChanged="v => _sampler = v"
                                Params_Scheduler="_scheduler" Params_SchedulerChanged="v => _scheduler = v"
                                Params_Steps="_steps" Params_StepsChanged="v => _steps = v"
                                Params_CfgScale="_cfgScale" Params_CfgScaleChanged="v => _cfgScale = v"
                                Params_Seed="_seed" Params_SeedChanged="v => _seed = v"
                                Params_Width="_width" Params_WidthChanged="v => _width = v"
                                Params_Height="_height" Params_HeightChanged="v => _height = v"
                                Params_BatchSize="_batchSize" Params_BatchSizeChanged="v => _batchSize = v"
                                Params_ClipSkip="_clipSkip" Params_ClipSkipChanged="v => _clipSkip = v"
                                Params_BatchCount="_batchCount" Params_BatchCountChanged="v => _batchCount = v"
                                Params_Eta="_eta" Params_EtaChanged="v => _eta = v"
                                Params_DenoisingStrength="_denoisingStrength" Params_DenoisingStrengthChanged="v => _denoisingStrength = v"
                                Params_HiresFixEnabled="_hiresFixEnabled" Params_HiresFixEnabledChanged="v => _hiresFixEnabled = v"
                                Params_HiresUpscaleFactor="_hiresUpscaleFactor" Params_HiresUpscaleFactorChanged="v => _hiresUpscaleFactor = v"
                                Params_HiresSteps="_hiresSteps" Params_HiresStepsChanged="v => _hiresSteps = v"
                                Params_HiresDenoisingStrength="_hiresDenoisingStrength" Params_HiresDenoisingStrengthChanged="v => _hiresDenoisingStrength = v" />
            </div>

            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Class="mt-4"
                       StartIcon="@Icons.Material.Filled.AutoAwesome"
                       Disabled="@(_isGenerating || _checkpointId is null || string.IsNullOrWhiteSpace(_positivePrompt) || (_generationMode == Domain.Enums.GenerationMode.ImageToImage && _initImageBytes is null) || (_generationMode == Domain.Enums.GenerationMode.Inpainting && _initImageBytes is null))"
                       OnClick="Generate">
                @if (_isGenerating)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    @:Generating...
                }
                else
                {
                    @:Generate
                }
            </MudButton>
            <MudText Typo="Typo.caption" Align="Align.Center" Color="Color.Secondary" Class="mt-1">Ctrl+Enter</MudText>

            @if (_isGenerating)
            {
                <MudButton Variant="Variant.Outlined" Color="Color.Warning" FullWidth="true" Class="mt-2"
                           OnClick="CancelGeneration">Cancel</MudButton>
            }

            @if (_isGenerating && _generationStatus is not null)
            {
                <MudPaper Class="pa-3 mt-2" Elevation="0" Outlined="true">
                    <div class="d-flex align-center justify-space-between">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@_generationStatus</MudText>
                        @if (_generationElapsed > 0)
                        {
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@FormatElapsed(_generationElapsed)</MudText>
                        }
                    </div>
                    <MudProgressLinear Value="_generationProgress" Max="100" Color="Color.Primary"
                                       Striped="true" Class="mt-1" />
                </MudPaper>
            }

            @if (_generationError is not null)
            {
                <MudAlert Severity="Severity.Error" Class="mt-2" ShowCloseIcon="true"
                          CloseIconClicked="() => _generationError = null">
                    @_generationError
                </MudAlert>
            }
        </MudPaper>
    </MudItem>

    <!-- Right panel: Output gallery -->
    <MudItem xs="12" md="8">
        <MudPaper Class="pa-4" Elevation="1">
            <MudText Typo="Typo.h6" Class="mb-3">Generated Images</MudText>

            <GenerationGallery @ref="_gallery" ProjectId="ProjectId"
                               OnReuseSettings="ReuseSettings"
                               OnSendToImg2Img="OnSendToImg2Img" />
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    [Parameter, EditorRequired] public Guid ProjectId { get; set; }
    [Parameter] public string? ProjectName { get; set; }

    // Generation workspace state
    private Guid? _checkpointId;
    private Guid? _vaeId;
    private List<LoraReference> _loras = [];
    private string _positivePrompt = string.Empty;
    private string _negativePrompt = string.Empty;
    private Sampler _sampler = Sampler.EulerA;
    private Scheduler _scheduler = Scheduler.Normal;
    private int _steps = 20;
    private double _cfgScale = 7.0;
    private long _seed = -1;
    private int _width = 512;
    private int _height = 512;
    private int _batchSize = 1;
    private int _clipSkip = 1;
    private int _batchCount = 1;
    private double _eta = 0.0;
    private double _denoisingStrength = 1.0;
    private bool _hiresFixEnabled;
    private double _hiresUpscaleFactor = 2.0;
    private int _hiresSteps;
    private double _hiresDenoisingStrength = 0.55;
    private Domain.Enums.GenerationMode _generationMode = Domain.Enums.GenerationMode.TextToImage;
    private byte[]? _initImageBytes;
    private InpaintCanvas? _inpaintCanvas;
    private bool _isGenerating;
    private string? _generationError;
    private string? _generationStatus;
    private int _generationProgress;
    private double _generationElapsed;
    private GenerationGallery? _gallery;
    private PromptHistoryPanel? _promptHistoryPanel;
    private GenerationPreset? _activePreset;
    private ModelFamily? _currentModelFamily;
    private DotNetObjectReference<GenerationWorkspace>? _dotNetRef;
    private RecentModelsBar? _recentModelsBar;
    private CancellationTokenSource? _generationCts;
    private Guid? _currentJobId;
    private int _positiveTokenCount;
    private int _negativeTokenCount;
    private int _tokenLimit = 77;
    private HubConnection? _hubConnection;
    private Timer? _progressTimer;
    private bool _isInterrogating;

    protected override async Task OnInitializedAsync()
    {
        // Connect to SignalR for live generation status updates
        try
        {
            _hubConnection = new HubConnectionBuilder()
                .WithUrl(Nav.ToAbsoluteUri("/hubs/studio"))
                .WithAutomaticReconnect()
                .Build();

            _hubConnection.On<string, int, int, string>("GenerationPreview",
                (projectId, step, totalSteps, _) =>
                {
                    if (projectId == ProjectId.ToString() && _isGenerating)
                    {
                        _generationProgress = totalSteps > 0 ? (int)(step * 100.0 / totalSteps) : 0;
                        _generationStatus = $"Step {step}/{totalSteps}...";
                        InvokeAsync(StateHasChanged);
                    }
                });

            _hubConnection.On<string>("GenerationComplete",
                projectId =>
                {
                    if (projectId == ProjectId.ToString() && _isGenerating)
                    {
                        _isGenerating = false;
                        _generationStatus = null;
                        _generationProgress = 100;
                        _currentJobId = null;
                        StopProgressTimer();
                        InvokeAsync(async () =>
                        {
                            if (_gallery is not null)
                                await _gallery.Refresh();
                            Snackbar.Add("Generation complete", Severity.Success);
                            StateHasChanged();
                        });
                    }
                });

            _hubConnection.On<string, string>("GenerationFailed",
                (projectId, error) =>
                {
                    if (projectId == ProjectId.ToString() && _isGenerating)
                    {
                        _isGenerating = false;
                        _generationError = error;
                        _generationStatus = null;
                        _currentJobId = null;
                        StopProgressTimer();
                        InvokeAsync(StateHasChanged);
                    }
                });

            await _hubConnection.StartAsync();
        }
        catch (Exception)
        {
            // SignalR connection failed — fall back to polling only
        }

        // Check if there's already a running generation for this project
        var jobs = await GenerationService.ListJobsForProjectAsync(ProjectId, take: 1);
        if (jobs.Any(j => j.Status is GenerationJobStatus.Pending or GenerationJobStatus.Running))
        {
            _isGenerating = true;
            _generationStatus = "Generation in progress...";
            StartProgressTimer();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("shortcutHelper.registerGenerateShortcut", _dotNetRef);
        }
    }

    [JSInvokable]
    public async Task OnGenerateShortcut()
    {
        if (!_isGenerating && _checkpointId is not null && !string.IsNullOrWhiteSpace(_positivePrompt))
        {
            await Generate();
        }
    }

    public async ValueTask DisposeAsync()
    {
        _dotNetRef?.Dispose();
        StopProgressTimer();
        // DON'T cancel generation — it continues in the background
        // _generationCts?.Cancel();
        _generationCts?.Dispose();
        if (_hubConnection is not null)
            await _hubConnection.DisposeAsync();
    }

    private async Task OnCheckpointChanged(Guid? modelId)
    {
        _checkpointId = modelId;

        if (modelId.HasValue)
        {
            if (_recentModelsBar is not null)
                await _recentModelsBar.TrackModel(modelId.Value);

            var model = await ModelCatalogService.GetByIdAsync(modelId.Value);
            if (model is not null)
            {
                _currentModelFamily = model.ModelFamily;
                _tokenLimit = PromptTokenEstimator.GetTokenLimit(model.ModelFamily.ToString());
                var preset = ModelFamilyPresets.GetPreset(model.ModelFamily);
                ApplyPreset(preset);
                Snackbar.Add($"Applied {preset.Name} preset", Severity.Info);
            }
        }
        else
        {
            _activePreset = null;
            _currentModelFamily = null;
        }
    }

    private void ApplyPreset(GenerationPreset preset)
    {
        _activePreset = preset;
        _sampler = preset.Sampler;
        _scheduler = preset.Scheduler;
        _steps = preset.Steps;
        _cfgScale = preset.CfgScale;
        _width = preset.Width;
        _height = preset.Height;
        if (string.IsNullOrWhiteSpace(_negativePrompt))
            _negativePrompt = preset.NegativePrompt;
    }

    private void ApplyUserPreset(Application.DTOs.GenerationPresetDto preset)
    {
        _sampler = preset.Sampler;
        _scheduler = preset.Scheduler;
        _steps = preset.Steps;
        _cfgScale = preset.CfgScale;
        _width = preset.Width;
        _height = preset.Height;
        _batchSize = preset.BatchSize;
        _clipSkip = preset.ClipSkip;

        if (preset.ApplyMode == Domain.Enums.PresetApplyMode.AppendToPrompt)
        {
            if (!string.IsNullOrWhiteSpace(preset.PositivePromptTemplate))
                _positivePrompt = string.IsNullOrWhiteSpace(_positivePrompt)
                    ? preset.PositivePromptTemplate
                    : $"{_positivePrompt}, {preset.PositivePromptTemplate}";
            if (!string.IsNullOrWhiteSpace(preset.NegativePrompt))
                _negativePrompt = string.IsNullOrWhiteSpace(_negativePrompt)
                    ? preset.NegativePrompt
                    : $"{_negativePrompt}, {preset.NegativePrompt}";
        }
        else if (preset.ApplyMode == Domain.Enums.PresetApplyMode.PrependToPrompt)
        {
            if (!string.IsNullOrWhiteSpace(preset.PositivePromptTemplate))
                _positivePrompt = string.IsNullOrWhiteSpace(_positivePrompt)
                    ? preset.PositivePromptTemplate
                    : $"{preset.PositivePromptTemplate}, {_positivePrompt}";
            if (!string.IsNullOrWhiteSpace(preset.NegativePrompt))
                _negativePrompt = string.IsNullOrWhiteSpace(_negativePrompt)
                    ? preset.NegativePrompt
                    : $"{preset.NegativePrompt}, {_negativePrompt}";
        }
        else // Replace (existing behavior)
        {
            if (!string.IsNullOrWhiteSpace(preset.NegativePrompt))
                _negativePrompt = preset.NegativePrompt;
            if (!string.IsNullOrWhiteSpace(preset.PositivePromptTemplate))
                _positivePrompt = preset.PositivePromptTemplate;
        }

        RecalculateTokenCounts();
        Snackbar.Add($"Applied preset: {preset.Name}", Severity.Success);
        StateHasChanged();
    }

    private async Task SavePreset()
    {
        var parameters = new DialogParameters<Dialogs.SavePresetDialog>
        {
            { x => x.ModelId, _checkpointId },
            { x => x.ModelFamily, _currentModelFamily },
            { x => x.PositivePrompt, _positivePrompt },
            { x => x.NegativePrompt, _negativePrompt },
            { x => x.Sampler, _sampler },
            { x => x.Scheduler, _scheduler },
            { x => x.Steps, _steps },
            { x => x.CfgScale, _cfgScale },
            { x => x.Width, _width },
            { x => x.Height, _height },
            { x => x.BatchSize, _batchSize },
            { x => x.ClipSkip, _clipSkip }
        };
        await DialogService.ShowAsync<Dialogs.SavePresetDialog>("Save Preset", parameters);
    }

    private async Task CancelGeneration()
    {
        if (_currentJobId.HasValue)
        {
            try
            {
                await GenerationService.CancelGenerationAsync(_currentJobId.Value);
            }
            catch { /* Best-effort cancel */ }
        }
        _generationCts?.Cancel();
    }

    private async Task Generate()
    {
        if (_checkpointId is null || string.IsNullOrWhiteSpace(_positivePrompt)) return;

        _generationCts?.Cancel();
        _generationCts?.Dispose();
        _generationCts = new CancellationTokenSource();
        var ct = _generationCts.Token;

        _isGenerating = true;
        _generationError = null;
        _generationStatus = "Submitting generation job...";
        _generationProgress = 0;
        _generationElapsed = 0;
        _currentJobId = null;
        StateHasChanged();

        try
        {
            var parameters = new GenerationParameters
            {
                PositivePrompt = _positivePrompt,
                NegativePrompt = _negativePrompt,
                CheckpointModelId = _checkpointId.Value,
                VaeModelId = _vaeId,
                Loras = _loras,
                Sampler = _sampler,
                Scheduler = _scheduler,
                Steps = _steps,
                CfgScale = _cfgScale,
                Seed = _seed,
                Width = _width,
                Height = _height,
                BatchSize = _batchSize,
                ClipSkip = _clipSkip,
                BatchCount = _batchCount,
                Eta = _eta,
                DenoisingStrength = _denoisingStrength,
                Mode = _generationMode,
                HiresFixEnabled = _hiresFixEnabled,
                HiresUpscaleFactor = _hiresUpscaleFactor,
                HiresSteps = _hiresSteps,
                HiresDenoisingStrength = _hiresDenoisingStrength
            };

            // Capture mask bytes from inpaint canvas if in inpainting mode
            byte[]? maskBytes = null;
            if (_generationMode == Domain.Enums.GenerationMode.Inpainting && _inpaintCanvas is not null)
            {
                maskBytes = await _inpaintCanvas.GetMaskBytesAsync();
            }

            var command = new CreateGenerationCommand(ProjectId, parameters, _initImageBytes, maskBytes);
            var genJobs = await GenerationService.CreateWithMatrixAsync(command, ct);
            var genJob = genJobs[0];
            _currentJobId = genJob.Id;

            // Record prompt in history
            await PromptHistoryService.RecordUsageAsync(_positivePrompt, _negativePrompt);
            if (_promptHistoryPanel is not null)
                await _promptHistoryPanel.RefreshAsync();

            // SignalR handles real-time updates (GenerationPreview/Complete/Failed)
            // Start a fallback polling timer for progress in case SignalR events are delayed
            _generationStatus = "Generating...";
            StartProgressTimer();
            StateHasChanged();
        }
        catch (OperationCanceledException)
        {
            _isGenerating = false;
            _generationStatus = null;
            _currentJobId = null;
            StopProgressTimer();
            Snackbar.Add("Generation cancelled", Severity.Warning);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            _isGenerating = false;
            _generationError = ex.Message;
            _generationStatus = null;
            _currentJobId = null;
            StopProgressTimer();
            StateHasChanged();
        }
    }

    private void StartProgressTimer()
    {
        StopProgressTimer();
        var startTime = System.Diagnostics.Stopwatch.StartNew();
        _progressTimer = new Timer(async _ =>
        {
            try
            {
                if (!_isGenerating || _currentJobId is null) return;

                var status = await GenerationService.GetJobAsync(_currentJobId.Value, CancellationToken.None);
                if (status is null) return;

                await InvokeAsync(() =>
                {
                    _generationElapsed = startTime.Elapsed.TotalSeconds;

                    if (status.Status is GenerationJobStatus.Completed)
                    {
                        _isGenerating = false;
                        _generationStatus = null;
                        _generationProgress = 100;
                        _currentJobId = null;
                        StopProgressTimer();
                        _ = _gallery?.Refresh();
                        Snackbar.Add($"Generated {status.Images.Count} image(s)", Severity.Success);
                    }
                    else if (status.Status is GenerationJobStatus.Failed)
                    {
                        _isGenerating = false;
                        _generationError = status.ErrorMessage ?? "Generation failed";
                        _generationStatus = null;
                        _currentJobId = null;
                        StopProgressTimer();
                    }
                    else if (status.Status is GenerationJobStatus.Cancelled)
                    {
                        _isGenerating = false;
                        _generationStatus = null;
                        _currentJobId = null;
                        StopProgressTimer();
                        Snackbar.Add("Generation cancelled", Severity.Warning);
                    }

                    StateHasChanged();
                });
            }
            catch (Exception)
            {
                // Swallow polling errors — SignalR is the primary update mechanism
            }
        }, null, TimeSpan.FromSeconds(2), TimeSpan.FromSeconds(2));
    }

    private void StopProgressTimer()
    {
        _progressTimer?.Dispose();
        _progressTimer = null;
    }

    private void ReuseSettings(GenerationJobDto job)
    {
        _checkpointId = job.Parameters.CheckpointModelId;
        _vaeId = job.Parameters.VaeModelId;
        _loras = job.Parameters.Loras.Select(l => new LoraReference(l.ModelId, l.Weight)).ToList();
        _positivePrompt = job.Parameters.PositivePrompt;
        _negativePrompt = job.Parameters.NegativePrompt;
        _sampler = job.Parameters.Sampler;
        _scheduler = job.Parameters.Scheduler;
        _steps = job.Parameters.Steps;
        _cfgScale = job.Parameters.CfgScale;
        _seed = job.Parameters.Seed;
        _width = job.Parameters.Width;
        _height = job.Parameters.Height;
        _batchSize = job.Parameters.BatchSize;
        _clipSkip = job.Parameters.ClipSkip;
        _batchCount = job.Parameters.BatchCount;
        _eta = job.Parameters.Eta;
        _denoisingStrength = job.Parameters.DenoisingStrength;
        _hiresFixEnabled = job.Parameters.HiresFixEnabled;
        _hiresUpscaleFactor = job.Parameters.HiresUpscaleFactor;
        _hiresSteps = job.Parameters.HiresSteps;
        _hiresDenoisingStrength = job.Parameters.HiresDenoisingStrength;
        _generationMode = job.Parameters.Mode;
        // Clear init image when reusing — the user must re-upload or use Send to img2img
        _initImageBytes = null;
        RecalculateTokenCounts();
        Snackbar.Add("Settings loaded from previous generation", Severity.Success);
        StateHasChanged();
    }

    private void OnSendToImg2Img(byte[] imageBytes)
    {
        _generationMode = Domain.Enums.GenerationMode.ImageToImage;
        _initImageBytes = imageBytes;
        _denoisingStrength = 0.75; // Sensible default for img2img
        Snackbar.Add("Image loaded for img2img. Adjust denoising strength and generate.", Severity.Success);
        StateHasChanged();
    }

    private void OnPromptHistorySelected((string Positive, string Negative) prompts)
    {
        _positivePrompt = prompts.Positive;
        _negativePrompt = prompts.Negative;
        RecalculateTokenCounts();
        StateHasChanged();
    }

    private void OnPngInfoParsed(Infrastructure.Services.A1111ParameterParser.ParsedParameters parsed)
    {
        _positivePrompt = parsed.PositivePrompt;
        _negativePrompt = parsed.NegativePrompt;
        if (parsed.Steps.HasValue) _steps = parsed.Steps.Value;
        if (parsed.CfgScale.HasValue) _cfgScale = parsed.CfgScale.Value;
        if (parsed.Seed.HasValue) _seed = parsed.Seed.Value;
        if (parsed.Width.HasValue) _width = parsed.Width.Value;
        if (parsed.Height.HasValue) _height = parsed.Height.Value;
        if (parsed.ClipSkip.HasValue) _clipSkip = parsed.ClipSkip.Value;
        RecalculateTokenCounts();
        Snackbar.Add("Parameters loaded from PNG metadata", Severity.Success);
        StateHasChanged();
    }

    private void OnPositivePromptChanged(string value)
    {
        _positivePrompt = value;
        _positiveTokenCount = PromptTokenEstimator.EstimateTokens(value);
    }

    private void OnNegativePromptChanged(string value)
    {
        _negativePrompt = value;
        _negativeTokenCount = PromptTokenEstimator.EstimateTokens(value);
    }

    private void RecalculateTokenCounts()
    {
        _positiveTokenCount = PromptTokenEstimator.EstimateTokens(_positivePrompt);
        _negativeTokenCount = PromptTokenEstimator.EstimateTokens(_negativePrompt);
        _tokenLimit = PromptTokenEstimator.GetTokenLimit(_currentModelFamily?.ToString());
    }

    private async Task InterrogateImage(byte[]? imageBytes)
    {
        if (imageBytes is null) return;
        _isInterrogating = true;
        StateHasChanged();
        try
        {
            var prompt = await ImageInterrogator.InterrogateAsync(imageBytes);
            OnInterrogateResult(prompt);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Interrogation failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isInterrogating = false;
            StateHasChanged();
        }
    }

    private void OnInterrogateResult(string prompt)
    {
        if (string.IsNullOrWhiteSpace(prompt)) return;
        _positivePrompt = prompt;
        RecalculateTokenCounts();
        Snackbar.Add("Prompt generated from image", Severity.Success);
        StateHasChanged();
    }

    private static string FormatElapsed(double totalSeconds)
    {
        var minutes = (int)(totalSeconds / 60);
        var seconds = (int)(totalSeconds % 60);
        return minutes > 0 ? $"{minutes}m {seconds}s" : $"{seconds}s";
    }
}
