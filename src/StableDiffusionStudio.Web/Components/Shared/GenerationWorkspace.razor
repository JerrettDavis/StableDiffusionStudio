    }

    private async Task<PromptAssistantContext> BuildPromptContextAsync()
    {
        // Resolve checkpoint display name
        string? modelName = null;
        string? vaeName = null;
        List<string> loraNames = [];

        if (_checkpointId.HasValue)
        {
            var model = await ModelCatalogService.GetByIdAsync(_checkpointId.Value);
            modelName = model?.Title;
        }

        if (_vaeId.HasValue)
        {
            var vae = await ModelCatalogService.GetByIdAsync(_vaeId.Value);
            vaeName = vae?.Title;
        }

        foreach (var lora in _loras)
        {
            var loraModel = await ModelCatalogService.GetByIdAsync(lora.ModelId);
            loraNames.Add(loraModel?.Title ?? lora.ModelId.ToString());
        }

        return new PromptAssistantContext(
            ModelName: modelName,
            ModelFamily: _currentModelFamily?.ToString(),
            VaeName: vaeName,
            LoraNames: loraNames,
            Width: _width,
            Height: _height,
            Steps: _steps,
            CfgScale: _cfgScale,
            Sampler: _sampler.ToString(),
            Scheduler: _scheduler.ToString(),
            CurrentPositivePrompt: _positivePrompt,
            CurrentNegativePrompt: _negativePrompt);
    }

