    private void ApplyModelRules(ModelRuleSet rules)
    {
        if (rules.Steps.HasValue) _steps = rules.Steps.Value;
        if (rules.CfgScale.HasValue) _cfgScale = rules.CfgScale.Value;
        if (rules.Sampler.HasValue) _sampler = rules.Sampler.Value;
        if (rules.Scheduler.HasValue) _scheduler = rules.Scheduler.Value;
        if (rules.ClipSkip.HasValue) _clipSkip = rules.ClipSkip.Value;
        if (rules.Eta.HasValue) _eta = rules.Eta.Value;
        if (rules.Width.HasValue) _width = rules.Width.Value;
        if (rules.Height.HasValue) _height = rules.Height.Value;
        if (rules.DenoisingStrength.HasValue) _denoisingStrength = rules.DenoisingStrength.Value;
        if (rules.HiresFixEnabled.HasValue) _hiresFixEnabled = rules.HiresFixEnabled.Value;
        if (rules.HiresUpscaleFactor.HasValue) _hiresUpscaleFactor = rules.HiresUpscaleFactor.Value;
        if (rules.HiresSteps.HasValue) _hiresSteps = rules.HiresSteps.Value;
        if (rules.HiresDenoisingStrength.HasValue) _hiresDenoisingStrength = rules.HiresDenoisingStrength.Value;
        if (!string.IsNullOrEmpty(rules.DefaultNegativePrompt) && string.IsNullOrEmpty(_negativePrompt))
            _negativePrompt = rules.DefaultNegativePrompt;
    }

