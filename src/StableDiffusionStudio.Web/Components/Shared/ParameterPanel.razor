@using StableDiffusionStudio.Domain.Enums

<MudExpansionPanels>
    <MudExpansionPanel Text="Generation Parameters">
        <MudGrid>
            <MudItem xs="6">
                <MudSelect T="Sampler" Label="Sampler" Value="Params_Sampler" ValueChanged="OnSamplerChanged" Variant="Variant.Outlined" Margin="Margin.Dense">
                    @foreach (var s in Enum.GetValues<Sampler>())
                    {
                        <MudSelectItem T="Sampler" Value="@s">@s</MudSelectItem>
                    }
                </MudSelect>
                @if (ShowHelp)
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
                        The algorithm used to remove noise from the image step by step. <strong>Euler A</strong> is fast and creative. <strong>DPM++ 2M</strong> produces high-quality results. <strong>DDIM</strong> is deterministic and consistent. Turbo/LCM models work best with <strong>DPM++ SDE</strong> or <strong>Euler</strong>.
                    </MudText>
                }
            </MudItem>
            <MudItem xs="6">
                <MudSelect T="Scheduler" Label="Scheduler" Value="Params_Scheduler" ValueChanged="OnSchedulerChanged" Variant="Variant.Outlined" Margin="Margin.Dense">
                    @foreach (var s in Enum.GetValues<Scheduler>())
                    {
                        <MudSelectItem T="Scheduler" Value="@s">@s</MudSelectItem>
                    }
                </MudSelect>
                @if (ShowHelp)
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
                        Controls how noise is distributed across steps. <strong>Normal</strong> is the standard linear schedule. <strong>Karras</strong> front-loads noise removal for sharper results. <strong>Exponential</strong> is smoother. <strong>SGM Uniform</strong> works well with certain models.
                    </MudText>
                }
            </MudItem>
            <MudItem xs="6">
                <div class="d-flex align-center justify-space-between mb-1">
                    <MudText Typo="Typo.body2">Steps</MudText>
                    <span class="param-value">@Params_Steps</span>
                </div>
                <MudSlider T="int" Value="Params_Steps" ValueChanged="OnStepsChanged" Min="1" Max="150" Step="1"
                           Color="Color.Primary" Size="Size.Small" />
                @if (ShowHelp)
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        How many denoising iterations to run. More steps = more detail but slower. <strong>20-30</strong> is good for most models. Turbo/LCM models only need <strong>4-8</strong> steps. Beyond 50 steps, returns diminish.
                    </MudText>
                }
            </MudItem>
            <MudItem xs="6">
                <div class="d-flex align-center justify-space-between mb-1">
                    <MudText Typo="Typo.body2">CFG Scale</MudText>
                    <span class="param-value">@Params_CfgScale.ToString("F1")</span>
                </div>
                <MudSlider T="double" Value="Params_CfgScale" ValueChanged="OnCfgScaleChanged" Min="1" Max="30" Step="0.5"
                           Color="Color.Primary" Size="Size.Small" />
                @if (ShowHelp)
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        Classifier-Free Guidance — how strongly the image follows your prompt. <strong>1-3</strong> = creative/dreamy. <strong>5-8</strong> = balanced (recommended). <strong>10+</strong> = strict prompt adherence but can look oversaturated or artificial. Flux models typically use <strong>1-4</strong>.
                    </MudText>
                }
            </MudItem>
            <MudItem xs="5">
                <MudTextField T="long" Label="Seed (-1 = random)" Value="Params_Seed" ValueChanged="OnSeedChanged"
                              Variant="Variant.Outlined" Margin="Margin.Dense" />
                @if (ShowHelp)
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
                        A number that determines the initial noise pattern. Same seed + same settings = same image every time. Use <strong>-1</strong> for a random seed each generation. Fix the seed when fine-tuning other parameters.
                    </MudText>
                }
            </MudItem>
            <MudItem xs="1" Class="d-flex align-center">
                <MudIconButton Icon="@Icons.Material.Filled.Casino" Size="Size.Small"
                               OnClick="RandomizeSeed" aria-label="Random seed" />
            </MudItem>
            <MudItem xs="12">
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary" Class="mb-2">Resolution</MudText>
                <div class="d-flex align-center gap-2">
                    <MudSelect T="int" Label="Width" Value="Params_Width" ValueChanged="OnWidthChanged" Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width:120px">
                        @foreach (var w in new[] { 256, 384, 512, 640, 768, 896, 1024, 1152, 1280, 1536 })
                        {
                            <MudSelectItem T="int" Value="@w">@w</MudSelectItem>
                        }
                    </MudSelect>
                    <MudIconButton Icon="@Icons.Material.Filled.SwapHoriz" Size="Size.Small"
                                   OnClick="SwapDimensions" aria-label="Swap width and height" />
                    <MudSelect T="int" Label="Height" Value="Params_Height" ValueChanged="OnHeightChanged" Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width:120px">
                        @foreach (var h in new[] { 256, 384, 512, 640, 768, 896, 1024, 1152, 1280, 1536 })
                        {
                            <MudSelectItem T="int" Value="@h">@h</MudSelectItem>
                        }
                    </MudSelect>
                    <span class="param-value" style="white-space:nowrap">@(Params_Width)x@(Params_Height)</span>
                </div>
                @if (ShowHelp)
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
                        Output image dimensions in pixels. Must be multiples of 64. <strong>SD 1.5</strong> works best at 512x512 or 512x768. <strong>SDXL</strong> is optimized for 1024x1024. <strong>Flux</strong> handles various sizes but prefers 1024x1024. Larger = more VRAM and slower.
                    </MudText>
                }
            </MudItem>
            <MudItem xs="6">
                <div class="d-flex align-center justify-space-between mb-1">
                    <MudText Typo="Typo.body2">Batch Size</MudText>
                    <span class="param-value">@Params_BatchSize</span>
                </div>
                <MudSlider T="int" Value="Params_BatchSize" ValueChanged="OnBatchSizeChanged" Min="1" Max="8" Step="1"
                           Color="Color.Primary" Size="Size.Small" />
                @if (ShowHelp)
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        How many images to generate at once in a single batch. Higher values use more VRAM but are faster than running separate generations. Each image in the batch gets a different seed.
                    </MudText>
                }
            </MudItem>
        </MudGrid>
    </MudExpansionPanel>

    <MudExpansionPanel Text="Advanced">
        <MudGrid>
            <MudItem xs="6">
                <div class="d-flex align-center justify-space-between mb-1">
                    <MudText Typo="Typo.body2">CLIP Skip</MudText>
                    <span class="param-value">@Params_ClipSkip</span>
                </div>
                <MudSlider T="int" Value="Params_ClipSkip" ValueChanged="OnClipSkipChanged" Min="1" Max="12" Step="1"
                           Color="Color.Primary" Size="Size.Small" />
                @if (ShowHelp)
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        Skips the last N layers of the CLIP text encoder. <strong>1</strong> = use all layers (most literal prompt interpretation). <strong>2</strong> = skip last layer (more creative, slightly softer). Some anime models (NAI-based) expect CLIP Skip 2. Most realistic models use 1.
                    </MudText>
                }
            </MudItem>
            <MudItem xs="6">
                <div class="d-flex align-center justify-space-between mb-1">
                    <MudText Typo="Typo.body2">Batch Count</MudText>
                    <span class="param-value">@Params_BatchCount</span>
                </div>
                <MudSlider T="int" Value="Params_BatchCount" ValueChanged="OnBatchCountChanged" Min="1" Max="10" Step="1"
                           Color="Color.Primary" Size="Size.Small" />
                @if (ShowHelp)
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        How many times to repeat the batch. Unlike batch size (which runs in parallel), batch count runs sequentially — each batch is a separate generation pass. Total images = Batch Size x Batch Count.
                    </MudText>
                }
            </MudItem>
        </MudGrid>

        <MudText Typo="Typo.subtitle2" Color="Color.Secondary" Class="mt-3 mb-2">Advanced Sampling</MudText>
        <MudGrid>
            <MudItem xs="6">
                <div class="d-flex align-center justify-space-between mb-1">
                    <MudText Typo="Typo.body2">Eta (DDIM)</MudText>
                    <span class="param-value">@Params_Eta.ToString("F2")</span>
                </div>
                <MudSlider T="double" Value="Params_Eta" ValueChanged="OnEtaChanged" Min="0" Max="1" Step="0.01"
                           Color="Color.Primary" Size="Size.Small" />
                @if (ShowHelp)
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        Controls randomness in the DDIM sampler. <strong>0</strong> = fully deterministic (same seed always gives same result). <strong>1</strong> = maximum randomness (similar to other samplers). Values in between blend deterministic and stochastic behavior. Only affects DDIM-based samplers.
                    </MudText>
                }
            </MudItem>
            <MudItem xs="6">
                <div class="d-flex align-center justify-space-between mb-1">
                    <MudText Typo="Typo.body2">Denoising Strength</MudText>
                    <span class="param-value">@Params_DenoisingStrength.ToString("F2")</span>
                </div>
                <MudSlider T="double" Value="Params_DenoisingStrength" ValueChanged="OnDenoisingStrengthChanged" Min="0" Max="1" Step="0.01"
                           Color="Color.Primary" Size="Size.Small" />
                @if (ShowHelp)
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        How much of the original image to replace with new content. Only used in img2img and inpainting modes. <strong>0.0</strong> = keep original image unchanged. <strong>0.75</strong> = replace 75% (good default for img2img). <strong>1.0</strong> = completely replace (like txt2img). Lower values preserve more of the original composition.
                    </MudText>
                }
            </MudItem>
        </MudGrid>

        <MudText Typo="Typo.subtitle2" Color="Color.Secondary" Class="mt-3 mb-2">Quick Resolution</MudText>
        <MudChipSet T="string" Class="mb-2">
            <MudChip T="string" OnClick="() => SetResolution(512, 512)" Class="quick-chip">512x512</MudChip>
            <MudChip T="string" OnClick="() => SetResolution(512, 768)" Class="quick-chip">512x768</MudChip>
            <MudChip T="string" OnClick="() => SetResolution(768, 512)" Class="quick-chip">768x512</MudChip>
            <MudChip T="string" OnClick="() => SetResolution(768, 768)" Class="quick-chip">768x768</MudChip>
            <MudChip T="string" OnClick="() => SetResolution(1024, 1024)" Class="quick-chip">1024x1024</MudChip>
            <MudChip T="string" OnClick="() => SetResolution(1024, 1536)" Class="quick-chip">1024x1536</MudChip>
            <MudChip T="string" OnClick="() => SetResolution(1536, 1024)" Class="quick-chip">1536x1024</MudChip>
        </MudChipSet>
    </MudExpansionPanel>

    <MudExpansionPanel Text="Hires Fix">
        @if (ShowHelp)
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">
                Hires Fix generates at a smaller resolution first, then upscales and refines the image with a second pass. This produces much higher quality results at large resolutions than generating directly at full size, which can produce duplicated subjects or distorted anatomy.
            </MudText>
        }
        <MudSwitch T="bool" Value="Params_HiresFixEnabled" ValueChanged="OnHiresFixEnabledChanged"
                   Label="Enable Hires Fix" Color="Color.Primary" />
        @if (Params_HiresFixEnabled)
        {
            <MudGrid Class="mt-2">
                <MudItem xs="12">
                    <div class="d-flex align-center justify-space-between mb-1">
                        <MudText Typo="Typo.body2">Upscale Factor</MudText>
                        <span class="param-value">@Params_HiresUpscaleFactor.ToString("F2")x</span>
                    </div>
                    <MudSlider T="double" Value="Params_HiresUpscaleFactor" ValueChanged="OnHiresUpscaleFactorChanged"
                               Min="1.5" Max="4" Step="0.25" Color="Color.Primary" Size="Size.Small" />
                    @if (ShowHelp)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            How much to enlarge the first-pass image. <strong>2x</strong> doubles both dimensions (4x the pixels). Higher values need more VRAM and time. For a 512x512 base with 2x upscale, the final image is 1024x1024.
                        </MudText>
                    }
                </MudItem>
                <MudItem xs="6">
                    <div class="d-flex align-center justify-space-between mb-1">
                        <MudText Typo="Typo.body2">Steps (0 = same)</MudText>
                        <span class="param-value">@Params_HiresSteps</span>
                    </div>
                    <MudSlider T="int" Value="Params_HiresSteps" ValueChanged="OnHiresStepsChanged"
                               Min="0" Max="150" Step="1" Color="Color.Primary" Size="Size.Small" />
                    @if (ShowHelp)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            Number of denoising steps for the upscale pass. <strong>0</strong> uses the same step count as the first pass. Lower values (10-15) are faster; higher values add more detail to the upscaled image.
                        </MudText>
                    }
                </MudItem>
                <MudItem xs="6">
                    <div class="d-flex align-center justify-space-between mb-1">
                        <MudText Typo="Typo.body2">Denoising</MudText>
                        <span class="param-value">@Params_HiresDenoisingStrength.ToString("F2")</span>
                    </div>
                    <MudSlider T="double" Value="Params_HiresDenoisingStrength" ValueChanged="OnHiresDenoisingStrengthChanged"
                               Min="0.1" Max="0.9" Step="0.05" Color="Color.Primary" Size="Size.Small" />
                    @if (ShowHelp)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            How much to change during the upscale pass. <strong>0.3-0.5</strong> adds detail while keeping the composition. <strong>0.6-0.7</strong> allows more creative changes. Too high and the upscaled image may diverge from the original.
                        </MudText>
                    }
                </MudItem>
            </MudGrid>
        }
    </MudExpansionPanel>
</MudExpansionPanels>

@code {
    [CascadingParameter(Name = "ShowHelpText")] private bool ShowHelp { get; set; }

    [Parameter] public Sampler Params_Sampler { get; set; } = Sampler.EulerA;
    [Parameter] public EventCallback<Sampler> Params_SamplerChanged { get; set; }
    [Parameter] public Scheduler Params_Scheduler { get; set; } = Scheduler.Normal;
    [Parameter] public EventCallback<Scheduler> Params_SchedulerChanged { get; set; }
    [Parameter] public int Params_Steps { get; set; } = 20;
    [Parameter] public EventCallback<int> Params_StepsChanged { get; set; }
    [Parameter] public double Params_CfgScale { get; set; } = 7.0;
    [Parameter] public EventCallback<double> Params_CfgScaleChanged { get; set; }
    [Parameter] public long Params_Seed { get; set; } = -1;
    [Parameter] public EventCallback<long> Params_SeedChanged { get; set; }
    [Parameter] public int Params_Width { get; set; } = 512;
    [Parameter] public EventCallback<int> Params_WidthChanged { get; set; }
    [Parameter] public int Params_Height { get; set; } = 512;
    [Parameter] public EventCallback<int> Params_HeightChanged { get; set; }
    [Parameter] public int Params_BatchSize { get; set; } = 1;
    [Parameter] public EventCallback<int> Params_BatchSizeChanged { get; set; }
    [Parameter] public int Params_ClipSkip { get; set; } = 1;
    [Parameter] public EventCallback<int> Params_ClipSkipChanged { get; set; }
    [Parameter] public int Params_BatchCount { get; set; } = 1;
    [Parameter] public EventCallback<int> Params_BatchCountChanged { get; set; }
    [Parameter] public double Params_Eta { get; set; } = 0.0;
    [Parameter] public EventCallback<double> Params_EtaChanged { get; set; }
    [Parameter] public double Params_DenoisingStrength { get; set; } = 1.0;
    [Parameter] public EventCallback<double> Params_DenoisingStrengthChanged { get; set; }
    [Parameter] public bool Params_HiresFixEnabled { get; set; }
    [Parameter] public EventCallback<bool> Params_HiresFixEnabledChanged { get; set; }
    [Parameter] public double Params_HiresUpscaleFactor { get; set; } = 2.0;
    [Parameter] public EventCallback<double> Params_HiresUpscaleFactorChanged { get; set; }
    [Parameter] public int Params_HiresSteps { get; set; }
    [Parameter] public EventCallback<int> Params_HiresStepsChanged { get; set; }
    [Parameter] public double Params_HiresDenoisingStrength { get; set; } = 0.55;
    [Parameter] public EventCallback<double> Params_HiresDenoisingStrengthChanged { get; set; }

    private async Task OnSamplerChanged(Sampler v) { Params_Sampler = v; await Params_SamplerChanged.InvokeAsync(v); }
    private async Task OnSchedulerChanged(Scheduler v) { Params_Scheduler = v; await Params_SchedulerChanged.InvokeAsync(v); }
    private async Task OnStepsChanged(int v) { Params_Steps = v; await Params_StepsChanged.InvokeAsync(v); }
    private async Task OnCfgScaleChanged(double v) { Params_CfgScale = v; await Params_CfgScaleChanged.InvokeAsync(v); }
    private async Task OnSeedChanged(long v) { Params_Seed = v; await Params_SeedChanged.InvokeAsync(v); }
    private async Task OnWidthChanged(int v) { Params_Width = v; await Params_WidthChanged.InvokeAsync(v); }
    private async Task OnHeightChanged(int v) { Params_Height = v; await Params_HeightChanged.InvokeAsync(v); }
    private async Task OnBatchSizeChanged(int v) { Params_BatchSize = v; await Params_BatchSizeChanged.InvokeAsync(v); }
    private async Task OnClipSkipChanged(int v) { Params_ClipSkip = v; await Params_ClipSkipChanged.InvokeAsync(v); }
    private async Task OnBatchCountChanged(int v) { Params_BatchCount = v; await Params_BatchCountChanged.InvokeAsync(v); }
    private async Task OnEtaChanged(double v) { Params_Eta = v; await Params_EtaChanged.InvokeAsync(v); }
    private async Task OnDenoisingStrengthChanged(double v) { Params_DenoisingStrength = v; await Params_DenoisingStrengthChanged.InvokeAsync(v); }
    private async Task OnHiresFixEnabledChanged(bool v) { Params_HiresFixEnabled = v; await Params_HiresFixEnabledChanged.InvokeAsync(v); }
    private async Task OnHiresUpscaleFactorChanged(double v) { Params_HiresUpscaleFactor = v; await Params_HiresUpscaleFactorChanged.InvokeAsync(v); }
    private async Task OnHiresStepsChanged(int v) { Params_HiresSteps = v; await Params_HiresStepsChanged.InvokeAsync(v); }
    private async Task OnHiresDenoisingStrengthChanged(double v) { Params_HiresDenoisingStrength = v; await Params_HiresDenoisingStrengthChanged.InvokeAsync(v); }

    private async Task SwapDimensions()
    {
        var oldWidth = Params_Width;
        var oldHeight = Params_Height;
        Params_Width = oldHeight;
        Params_Height = oldWidth;
        await Params_WidthChanged.InvokeAsync(Params_Width);
        await Params_HeightChanged.InvokeAsync(Params_Height);
    }

    private async Task RandomizeSeed()
    {
        Params_Seed = -1;
        await Params_SeedChanged.InvokeAsync(-1);
    }

    private async Task SetResolution(int width, int height)
    {
        Params_Width = width;
        Params_Height = height;
        await Params_WidthChanged.InvokeAsync(width);
        await Params_HeightChanged.InvokeAsync(height);
    }
}
